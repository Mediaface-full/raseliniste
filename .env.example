# ---- Database ----
# Heslo k Postgres — generuj: openssl rand -base64 24 | tr -d '/+='
DB_PASSWORD=CHANGE_ME

# Lokální vývoj: sahá na localhost Postgres; v produkci compose staví DATABASE_URL z DB_PASSWORD.
DATABASE_URL=postgresql://raseliniste:CHANGE_ME@localhost:5432/raseliniste

# ---- Session / auth ----
# Generuj: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_RANDOM

# ---- AI (Gemini) ----
#
# Máš 2 cesty, stačí jedna. Vertex má přednost, pokud je VERTEX_PROJECT vyplněný.
#
# (A) Vertex AI — doporučeno pro produkci (EU region, žádné trénování na
#     tvých datech, Google podepisuje DPA). Setup:
#       1) GCP projekt + zapnuté billing
#       2) Enable Vertex AI API v projektu
#       3) Service account s rolí "Vertex AI User" → stáhni JSON key
#       4) JSON nahraj na NAS (např. /volume1/docker/raseliniste/gcp-key.json)
#       5) V docker-compose.yml namountuj do kontejneru:
#            volumes:
#              - ./gcp-key.json:/app/gcp-key.json:ro
#       6) Vyplň následující:
VERTEX_PROJECT=
VERTEX_LOCATION=europe-west1
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-key.json
#
# (B) Google AI Studio API key — jednoduchý dev / fallback:
#     https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---- Anthropic Claude (ClaudeClaw Telegram bot) ----
# API key z console.anthropic.com. Default model = claude-haiku-4-5 (rychlý, laciný).
# Pro složitější use case přepnout na claude-sonnet-5 přes ANTHROPIC_MODEL.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# ---- Telegram bot (ClaudeClaw) ----
# Setup:
#   1. @BotFather → /newbot → jméno "ClaudeClaw" → username "claudeclaw_bot"
#      → dostaneš token, uložit sem:
TELEGRAM_BOT_TOKEN=
#   2. Napiš /start botovi → server log vypíše tvůj Telegram user ID, uložit sem:
TELEGRAM_ALLOWED_USER_ID=
#   3. Vygeneruj: openssl rand -hex 24. Bez tohoto webhook nefunguje.
TELEGRAM_WEBHOOK_SECRET=
#   4. Register webhook (jednorázově, po deployi):
#      curl "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#        -d url=https://www.raseliniste.cz/api/telegram/webhook \
#        -d secret_token=<WEBHOOK_SECRET>

# ---- App ----
APP_URL=https://www.raseliniste.cz

# ---- První admin user (použije prisma/seed) ----
ADMIN_USERNAME=Gideon
# Generuj: openssl rand -base64 18 | tr -d '/+=' | cut -c1-20
ADMIN_PASSWORD=CHANGE_ME

# ---- Email (Resend) ----
# https://resend.com → API Keys. Zdarma 3 000 mailů / měsíc.
# Bez klíče mailer jen loguje (systém nepadá).
RESEND_API_KEY=
# From musí být z ověřené domény v Resend (v dashboardu přidat DNS záznamy pro raseliniste.cz).
NOTIFICATION_FROM=reports@raseliniste.cz
# Kam posílat měsíční health reporty a případné další notifikace.
NOTIFICATION_EMAIL=petr@example.cz

# ---- Cron ----
# Shared secret pro /api/cron/* endpointy. Generuj: openssl rand -base64 32
# Synology Task Scheduler ho pošle v hlavičce `x-cron-key`.
CRON_SECRET=CHANGE_ME_CRON_SECRET

# ---- Google OAuth (Kalendář + Kontakty) ----
# 1) GCP Console → APIs & Services → Library → Enable: Google Calendar API + People API
# 2) APIs & Services → OAuth consent screen → User Type: Internal (Workspace)
#    Scopes: .../auth/calendar + .../auth/contacts.readonly
# 3) APIs & Services → Credentials → Create OAuth client ID → Web Application
#    Authorized redirect URI: https://www.raseliniste.cz/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Default už v compose.yml; přepiš jen pokud používáš jinou doménu:
# GOOGLE_REDIRECT_URI=https://www.raseliniste.cz/api/integrations/google/callback

# ---- Booking magic-link (potvrzení rezervace) ----
# Generuj: openssl rand -base64 32
BOOKING_MAGIC_LINK_SECRET=
BOOKING_MAGIC_LINK_TTL_HOURS=24

# ---- Siri Shortcut (POST /api/calendar/check) ----
# Generuj: openssl rand -base64 32 | tr -d '+/=' | cut -c1-32
SIRI_API_TOKEN=
