generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
  moduleFormat = "cjs"
  // pgvector — pro RAG (modul „Zeptat se")
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  passwordHash      String
  createdAt         DateTime @default(now())
  lastLoginAt       DateTime?

  // Preferences (konfigurovatelné z /settings)
  notificationEmail String?  // kam posílat health reporty; fallback na env NOTIFICATION_EMAIL
  // WhatsApp target — kam posílat upozornění (Petrovo vlastní číslo v E.164 formátu).
  // Twilio credentials jsou v UserIntegration(provider="twilio").
  whatsappNumber    String?

  sessions     Session[]
  passkeys     WebauthnCredential[]
  recordings   Recording[]
  apiTokens    ApiToken[]
  healthMetrics HealthMetric[]
  healthEcgs    HealthEcg[]
  healthAnalyses HealthAnalysis[]
  contacts      Contact[]
  callLogs      CallLog[]
  integrations  UserIntegration[]
  letterSenders LetterSender[]
  letterRecipients LetterRecipient[]
  letters       Letter[]
  projectBoxes  ProjectBox[]
  guestUsers    GuestUser[]
  tasks            Task[]
  taskAudioBatches TaskAudioBatch[]
  journalEntries   JournalEntry[]
  ragChunks        RagChunk[]
  anniversaries    Anniversary[]
  checkIns         CheckIn[]
  pushSubscriptions WebPushSubscription[]
  decisions        Decision[]
  todoistProjects  TodoistProjectMirror[]
  todoistLabels    TodoistLabelMirror[]
  thingsImports    ThingsImport[]

  // Todoist incremental sync (Sync API)
  todoistSyncToken  String?  @db.Text
  todoistSyncedAt   DateTime?
  todoistSyncError  String?  @db.Text
}

model WebauthnCredential {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId    String    @unique // base64url
  publicKey       Bytes
  counter         BigInt    @default(0)
  transports      String[]  // ["internal", "hybrid", "usb", ...]
  deviceType      String    // "singleDevice" | "multiDevice"
  backedUp        Boolean
  nickname        String?
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ---- Capture: ingest → klasifikace → triage ----

model Recording {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  source          RecordingSource
  rawText         String

  processedAt     DateTime?
  processingError String?

  createdAt       DateTime @default(now())

  entries         Entry[]

  @@index([userId, createdAt])
}

model Entry {
  id               String      @id @default(cuid())
  recordingId      String
  recording        Recording   @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  type             EntryType
  text             String
  rawExcerpt       String?

  // Pouze pro TASK
  suggestedProject String?
  suggestedWhen    TaskWhen?
  rationale        String?

  // Pouze pro KNOWLEDGE
  knowledgeCategory String?
  knowledgeUrl      String?
  knowledgeTags     String[] @default([])

  // Obecné hashtagy (teď hlavně pro JOURNAL po AI redakci)
  hashtags          String[] @default([])

  // Volitelná lokace odkud byl záznam pořízen (GPS z iPhone Shortcutu).
  // JSON: { lat: number, lng: number, name?: string, accuracy?: number }
  location          Json?

  status           EntryStatus @default(PENDING)

  // Push TASK položek do Todoistu (z /tasks stránky). Non-null = už je v TD.
  todoistTaskId    String?
  todoistProjectId String?

  // Ručně označeno jako hotové v /tasks nebo /notes (nezávisle na Todoistu).
  completedAt      DateTime?

  createdAt        DateTime    @default(now())
  confirmedAt      DateTime?

  @@index([recordingId])
  @@index([status])
  @@index([type, status, completedAt])
}

// ---- Zdravotní data (Apple Health přes Health Auto Export) ----

model HealthMetric {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Typ metriky = přesný název z HAE (step_count, weight_body_mass,
  // blood_pressure, sleep_analysis, heart_rate_variability, ...)
  type        String
  recordedAt  DateTime
  source      String   // "Petr – Apple Watch|Pacer" apod.
  unit        String?  // "kg", "count", "count/min", "kJ", "mmHg", "hr", ...

  // 14 z 17 metrik = simple scalar (step_count, weight, HRV, kroky, ...)
  qty         Float?

  // blood_pressure special-case
  bpSystolic  Float?
  bpDiastolic Float?

  // sleep_analysis: core/deep/rem/awake/asleep/inBed a časové rozsahy
  // — heterogenní pole, ukládáme jako JSONB pro fulltext/analýzu později.
  sleepData   Json?

  // Raw HAE položka (pro pozdější recovery kdyby se měnila schema).
  raw         Json?

  createdAt   DateTime @default(now())

  // ==== Unique constraint proti duplicitám ====
  // Jeden zdravotní záznam je definovaný trojicí (typ, čas, zdroj).
  // HAE tenhle tuple drží napříč exporty, takže re-ingest je bezpečný.
  @@unique([userId, type, recordedAt, source])
  @@index([userId, type, recordedAt])
}

model HealthAnalysis {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  periodFrom      DateTime
  periodTo        DateTime
  focus           String?
  trigger         AnalysisTrigger @default(MANUAL)

  text            String   // markdown odpověď z Gemini
  model           String   // "gemini-2.5-pro"
  promptChars     Int?
  totalSamples    Int?
  metricsWithData Int?

  emailSentAt     DateTime?
  emailError      String?

  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, periodFrom, periodTo])
}

enum AnalysisTrigger {
  MANUAL
  MONTHLY_AUTO
}

model HealthEcg {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  startedAt      DateTime
  source         String
  classification String?  // "sinusRhythm", "atrialFibrillation", ...
  averageHr      Float?

  // Voltage samples jsou velké pole (10k+ bodů) — JSONB se komprimuje líp
  // než samostatná tabulka, queries na EKG raw data dělat nebudeme.
  voltageData    Json
  symptoms       Json?

  raw            Json?
  createdAt      DateTime @default(now())

  @@unique([userId, startedAt, source])
  @@index([userId, startedAt])
}

// ---- Gideonův Firewall: kontakty + call-log + integrace ----

model Contact {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])

  displayName  String
  firstName    String?
  // 5. pád (vokativ) pro oslovení v emailech a na /call-log VIP variantě.
  // Volitelné — pokud chybí, použije se algoritmus s výjimkami; pokud algoritmus
  // selže (cizí jméno apod.), fallback na firstName v 1. pádu.
  firstNameVocative String?
  // VIP-only: úplné vlastní oslovení (např. „drahá dívko", „kamaráde", „šéfe").
  // Pokud je vyplněno, na /call-log VIP nahradí defaultní „Ahoj, <vokativ>"
  // celým tímhle stringem. Necháme styl Petrovi — žádné formátování server-side.
  greetingOverride  String?
  lastName     String?
  note         String?
  isVip        Boolean        @default(false)

  // Booking módy (kalendář): kontakt může mít víc tagů zároveň
  isClient            Boolean        @default(false)
  isFriend            Boolean        @default(false)
  isFamily            Boolean        @default(false)
  defaultBookingMode  BookingMode?

  // Narozeniny — stačí den a měsíc (rok obvykle neznámý)
  birthMonth   Int?
  birthDay     Int?
  // Reminder na narozeniny — null = žádné předem, 0 = jen na samý den (popřát),
  // 7 = týden předem (čas na dárek), atd.
  birthdayReminderDaysBefore Int?
  birthdayReminderChannels   String[]  @default([])

  // VIP token pro /call-log (privátní link na zadávání misí + výpis Giďoušových misí).
  // Generuje se automaticky když Contact.isVip = true. Stabilní (neměnný) dokud Petr
  // nezvolí regenerate (tlačítko v /contacts u VIP). 24 znaků base64url.
  callLogToken            String?    @unique
  callLogTokenCreatedAt   DateTime?

  importedFrom String?        // "vcard" | "manual" | "google"
  externalId   String?        // UID z vCard, pokud má

  // Google People API sync
  googleResourceName  String?        @unique
  googlePhotoUrl      String?
  lastGoogleSyncAt    DateTime?

  phones       Phone[]
  emails       ContactEmail[]
  callLogs     CallLog[]
  bookingInvites      BookingInvite[]
  assignedTasks       Task[]   @relation("TaskAssignee")

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([userId, isVip])
  @@index([userId, birthMonth, birthDay])
  @@index([userId, isClient])
  @@index([userId, isFriend])
}

enum BookingMode {
  CLIENT
  FRIEND
}

model Phone {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  number    String  // normalizovaný E.164 např. "+420777123456"
  label     String? // "mobile" | "work" | "home" | "other"

  @@unique([contactId, number])
  @@index([number]) // rychlé lookup při příchozím hovoru
}

model ContactEmail {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  email     String
  label     String?

  @@unique([contactId, email])
}

model CallLog {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])

  phoneNumber  String    // normalizovaný E.164 tak jak přišel
  rawNumber    String    // jak skutečně přišel z URL (pro audit)
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id])

  message      String
  isUrgent     Boolean   @default(false)
  wasVip       Boolean   @default(false) // snapshot v době přijetí

  // VIP-only: požadovaný termín splnění, propíše se do Todoist jako due_date.
  // Volitelný — VIP může nechat prázdné a Gideon si termín nastaví sám.
  requestedDueAt DateTime?

  ip           String?
  userAgent    String?

  todoistTaskId    String? // ID v Todoist pokud se podařilo vytvořit
  todoistProjectId String?
  todoistError     String? // pokud push selhal

  mailSentAt   DateTime? // kdy byl odeslán email Gideonovi
  mailError    String?

  seenAt       DateTime? // Gideon označil jako vyřízené

  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, seenAt])
}

model UserIntegration {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  provider   String   // "todoist" | budoucí "superlist" | "plaud" atd.

  // Encrypted credentials (AES-256-GCM, klíč odvozen ze SESSION_SECRET)
  tokenEnc   String   // ciphertext v base64
  tokenIv    String   // IV v base64
  tokenTag   String   // auth tag v base64

  // Per-provider konfigurace (pro Todoist: { vyruseni: projectId, vip: projectId })
  config     Json?

  lastUsedAt DateTime?
  lastError  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, provider])
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  name        String
  tokenHash   String    @unique
  prefix      String

  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

enum RecordingSource {
  SHORTCUT
  WEB
  MANUAL
}

enum EntryType {
  TASK
  JOURNAL
  THOUGHT
  CONTEXT
  KNOWLEDGE
}

enum TaskWhen {
  TODAY
  THIS_WEEK
  SOMEDAY
}

enum EntryStatus {
  PENDING
  CONFIRMED
  DISCARDED
}

model LoginAttempt {
  id        String   @id @default(cuid())
  username  String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([username, createdAt])
  @@index([ip, createdAt])
}

// ---- Dopisy: odesílatelé, adresáti, dopisy s PDF ----

model LetterSender {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  name          String   // "Petr Perina (osobní)", "ART76", "ABC s.r.o."
  legalName     String?  // formální název pro hlavičku, pokud se liší
  ico           String?
  dic           String?

  // Adresa odesílatele (volitelné, multiline)
  addressLines  String[] @default([])

  email         String?
  phone         String?
  web           String?
  bankAccount   String?

  // Cesty k souborům (relativní k UPLOADS_DIR)
  logoPath      String?
  signaturePath String?

  // AI prompt pro tlačítko "Učesat" — per odesílatel.
  // Per dopis se k tomuto promptu může připojit krátký override
  // (např. "vypíchni tučně klíčové body").
  redactPrompt  String  @default("Učeš text dopisu do formálního, zdvořilého a srozumitelného tónu. Zachovej oslovení i závěr napsané uživatelem. Neměň fakta. Vrať jen výsledný text bez vysvětlivek a bez markdown formátování.")

  // PDF design preset (zatím jen "classic"; do budoucna 'minimal', 'bold', ...)
  pdfTheme      String  @default("classic")

  letters       Letter[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model LetterRecipient {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  name         String   // "Pan Karel Novák" / "ČSOB, a.s."
  addressLines String[] @default([])

  letters      Letter[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Letter {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  senderId      String
  sender        LetterSender @relation(fields: [senderId], references: [id])

  recipientId   String?
  recipient     LetterRecipient? @relation(fields: [recipientId], references: [id])

  // Snapshot adresáta v momentě generování — i kdyby uživatel kontakt
  // později smazal nebo upravil, dopis si pamatuje, jak vypadal.
  recipientNameSnapshot         String?
  recipientAddressLinesSnapshot String[] @default([])
  showRecipientAddress          Boolean  @default(true)

  // Datum dopisu (default = dnes, lze přepsat)
  letterDate    DateTime @default(now())
  // Místo (např. "V Praze") — volitelné, zobrazí se jen pokud vyplněno
  place         String?

  // Vstupní text (co uživatel napsal) + finální text (po případném "učesání")
  // Pokud nepoužije Učesat, bodyFinal == bodyRaw.
  bodyRaw       String
  bodyFinal     String

  // Per-dopis prompt addendum (přidá se k senderRedactPrompt)
  promptOverride String?

  // Verzování — pokud je toto regenerace, parent ukáže původní dopis.
  parentLetterId String?
  parent         Letter?  @relation("LetterVersions", fields: [parentLetterId], references: [id])
  versions       Letter[] @relation("LetterVersions")
  version        Int      @default(1)

  // Cache PDF na disku (relativně k UPLOADS_DIR)
  pdfPath        String?
  pdfGeneratedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([senderId])
}

// ---- Studna: sdílené projektové boxíky s hlasovými záznamy ----

model ProjectBox {
  id                String   @id @default(cuid())
  userId            String   // owner (single-user systém = Petr)
  user              User     @relation(fields: [userId], references: [id])

  name              String   // "ART76 brainstorm"
  homeTitle         String?  // pod ikonou na ploše iPhone, max ~9 znaků
  description       String?  // kontext pro AI prompt + onboarding PDF

  // AI prompt overrides (pokud null, použije se default v lib/audio-transcribe.ts)
  extractionPrompt  String?

  // Per-projekt custom Studna/Prskavka prompty pro Stage 2 analýzu.
  // Priorita: tento override > DB global override (/settings/ai-prompts) > default v kódu.
  // Vyplňuje se v UI detailu projektu. Když null, použije se globální.
  studnaStandardPrompt  String?  @db.Text
  studnaBriefPrompt     String?  @db.Text

  // Notifikace v 18:00 cron — pokud false, projekt se v digestu vynechá
  includeInDigest   Boolean  @default(true)

  // Prskavka modul = osobní projekty (knížky, nápady, soukromé tvoření).
  // false = klasická Studánka (sdílená s klienty), true = Prskavka (jen Petr).
  // Liší se jen filtrem a kde se zobrazí, jinak je chování identické.
  isPrivate         Boolean  @default(false)

  invitations       ProjectInvitation[]
  recordings        ProjectRecording[]
  summaries         ProjectSummary[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  archivedAt        DateTime?

  @@index([userId])
}

model GuestUser {
  id          String   @id @default(cuid())
  ownerUserId String   // kdo ho vlastní (Petr)
  owner       User     @relation(fields: [ownerUserId], references: [id])

  email       String
  name        String
  phone       String?

  // Stabilní token v URL /me/<guestToken>. Lze regenerovat — invaliduje
  // všechny dříve sdílené odkazy.
  guestToken  String   @unique

  invitations ProjectInvitation[]
  recordings  ProjectRecording[]

  createdAt   DateTime @default(now())
  lastSeenAt  DateTime?

  // Jeden Karel per Petr (matching podle emailu).
  @@unique([ownerUserId, email])
  @@index([ownerUserId])
}

model ProjectInvitation {
  id              String   @id @default(cuid())
  projectId       String
  project         ProjectBox @relation(fields: [projectId], references: [id], onDelete: Cascade)
  guestUserId     String
  guestUser       GuestUser  @relation(fields: [guestUserId], references: [id], onDelete: Cascade)

  // Per-projekt permission — některý host má brief permission jinde, jinde ne.
  canRecordBrief  Boolean  @default(false)

  invitedAt       DateTime @default(now())

  @@unique([projectId, guestUserId])
  @@index([guestUserId])
}

model ProjectRecording {
  id              String   @id @default(cuid())
  projectId       String
  project         ProjectBox @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Autor. Buď GuestUser, nebo owner (pak guestUserId == null + isOwner == true).
  guestUserId     String?
  guestUser       GuestUser? @relation(fields: [guestUserId], references: [id])
  isOwner         Boolean  @default(false)
  authorName      String   // snapshot — i kdyby host byl smazán, dopis ví autora

  type            RecordingType @default(STANDARD)

  // Audio storage (relativní k UPLOADS_PATH; null = soubor smazán cleanup cronem)
  audioPath       String?
  audioMime       String?
  audioBytes      Int?
  audioDurationSec Int?

  // Transkript se zachová vždy
  transcript      String

  // Strukturovaný rozbor z Gemini (volné JSON pro flexibilitu)
  // {
  //   summary: string,
  //   key_themes: string[],
  //   thoughts: [{ text, importance, rationale, category }],
  //   open_questions: string[],
  //   sentiment: string,
  //   intensity_signals: string,
  //   ... (brief navíc: glossary, actors, decision_history)
  // }
  analysis        Json?

  // User-driven: zachovat audio i po 14 dnech (jen pro STANDARD; brief se nemaže nikdy)
  isPinned        Boolean  @default(false)

  // Status zpracování (asynchronní transcribe může selhat)
  status          String   @default("processing") // processing | processed | error
  processingError String?

  ip              String?
  userAgent       String?

  createdAt       DateTime @default(now())
  archivedAt      DateTime?

  @@index([projectId, createdAt])
  @@index([guestUserId])
  @@index([type, createdAt])
}

enum RecordingType {
  STANDARD       // < 10 min, Flash, audio mizí za 14 dní (pokud nepinned)
  BRIEF          // klíčový brief, Pro s deep analýzou, audio se nikdy nemaže
}

model ProjectSummary {
  id          String   @id @default(cuid())
  projectId   String
  project     ProjectBox @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Markdown výstup z Gemini Pro nad všemi recordings (briefy s vyšší vahou)
  text        String
  model       String   // "gemini-2.5-pro"
  recordingsIncluded Int
  briefsIncluded     Int

  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
}

// ============================================================================
// Kalendář & Bookingy
// ============================================================================

enum CalendarSource {
  GOOGLE_PRIMARY      // Petrův pracovní/osobní Google
  ICLOUD_SON          // synův program (read-only)
  ICLOUD_PARTNER      // partnerčiny služby (read-only)
  RASELINISTE         // vytvořeno přímo v Rašeliništi (rezerva, zatím nepoužíváno)
}

enum EventType {
  MEETING_PRAGUE      // prezenční v Praze
  MEETING_HOME        // prezenční u Petra doma
  MEETING_ELSEWHERE   // prezenční jinde (Plzeň, Brno...)
  MEETING_ONLINE      // online (Meet, Zoom...)
  PERSONAL            // soukromé, nepatří do bookingů
  HOCKEY_SON          // hokejové tréninky (auto z ICLOUD_SON)
  PARTNER_SHIFT       // partnerčina směna (auto z ICLOUD_PARTNER)
  PARTNER_VACATION    // partnerčina dovolená (kontext, neblok)
  OOO_FULL            // dovolená, vše blokované
  OOO_TRAVEL_WORKING  // nomád, jen prezenční blokované
  OTHER
}

model Location {
  id              String          @id @default(cuid())
  name            String          @unique          // "Praha", "Jílové u Prahy", "Plzeň"
  aliases         String[]        @default([])     // ["Prague", "Vinohrady", ...]
  commuteMinPeak  Int                              // ve špičce (min)
  commuteMinOff   Int                              // mimo špičku (min)
  isLocal         Boolean         @default(false)  // domov / žádný commute
  createdAt       DateTime        @default(now())

  events          CalendarEvent[]
}

model CalendarEvent {
  id              String          @id @default(cuid())
  source          CalendarSource
  externalId      String          // Google event ID nebo iCloud UID
  sourceUrl       String?         // odkaz zpět (např. Google Calendar URL)

  type            EventType
  title           String
  description     String?         // Markdown z popisu události
  locationText    String?         // volný text z eventu
  locationId      String?
  location        Location?       @relation(fields: [locationId], references: [id])

  startsAt        DateTime
  endsAt          DateTime
  allDay          Boolean         @default(false)
  timezone        String          @default("Europe/Prague")

  // Per-event metadata jen v Rašeliništi (ne v Google)
  prepNote        String?
  itemsToBring    Json?           // [{name: "knížky", forPerson: "Franta"}, ...]
  manualOverride  Boolean         @default(false)  // commit přes /quickadd 'přesto zapsat'

  // Booking metadata
  bookingInviteId String?
  bookingInvite   BookingInvite?  @relation(fields: [bookingInviteId], references: [id])

  // Sync metadata
  lastSyncedAt    DateTime
  etag            String?
  deletedRemotely Boolean         @default(false)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([source, externalId])
  @@index([startsAt, endsAt])
  @@index([type, startsAt])
  @@index([source, lastSyncedAt])
}

enum BookingMeetingType {
  CHOICE_PRAGUE
  CHOICE_ONLINE
  CHOICE_HOME
  CHOICE_ANY
}

enum BookingStatus {
  PENDING       // odeslán link, ještě nekliknul
  VIEWED        // klient otevřel
  RESERVED      // vybral slot, čekáme magic-link confirm
  CONFIRMED     // potvrzeno, event vytvořen
  CANCELED
  EXPIRED
}

model BookingInvite {
  id              String              @id @default(cuid())
  token           String              @unique     // 32 znaků
  mode            BookingMode
  meetingType     BookingMeetingType

  contactId       String?
  contact         Contact?            @relation(fields: [contactId], references: [id])

  // Pro cold leady (z /schuzka, žádný Contact)
  inviteeName     String?
  inviteeEmail    String?
  inviteePhone    String?
  inviteeSubject  String?

  internalNote    String?

  // Délka slotu v minutách — Petr volí při tvorbě (30/45/60/90/120)
  slotDurationMin Int                 @default(60)

  status          BookingStatus       @default(PENDING)
  validUntil      DateTime
  reservedSlot    Json?               // {startsAt, endsAt, type}
  confirmedAt     DateTime?

  events          CalendarEvent[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([token])
  @@index([status, validUntil])
}

model DayNote {
  id          String    @id @default(cuid())
  forDate     DateTime  @db.Date
  text        String
  area        String?                  // "Praha 5", "Smíchov", null
  done        Boolean   @default(false)
  doneAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([forDate, done])
}

enum RuleViolationSeverity {
  INFO
  WARNING
  ERROR
}

model RuleViolation {
  id            String                @id @default(cuid())
  forDate       DateTime              @db.Date
  eventId       String?
  ruleName      String
  severity      RuleViolationSeverity
  message       String
  acknowledged  Boolean               @default(false)
  createdAt     DateTime              @default(now())

  @@index([forDate, acknowledged])
}

model BriefingDigest {
  id              String    @id @default(cuid())
  forDate         DateTime  @db.Date  @unique
  generatedAt     DateTime  @default(now())

  // Strukturovaný obsah pro re-render v UI
  content         Json

  todoistTaskId   String?
  pushedAt        DateTime?
}

// ============================================================================
// ÚKOLY (samostatný Task model — nezávislý na Entry/Capture)
// ============================================================================

enum TaskStatus {
  open
  done
  cancelled
}

enum TaskPriority {
  low
  normal
  high
}

enum TaskSource {
  manual
  audio
  quickadd
  capture
  todoist_pull
  vip_call_log
  things_import
}

enum TaskBatchStatus {
  processing
  review
  committed
  discarded
  error
}

model Task {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id])

  title             String
  notes             String?      @db.Text
  dueAt             DateTime?
  dueIsTime         Boolean      @default(false)   // true = včetně času
  tags              String[]     @default([])
  status            TaskStatus   @default(open)
  priority          TaskPriority @default(normal)

  // Delegace — komu je úkol přidělen (z Contacts).
  // null = vlastní úkol Petra.
  assignedToContactId String?
  assignedToContact   Contact?  @relation("TaskAssignee", fields: [assignedToContactId], references: [id])

  // Origin tracking
  source            TaskSource   @default(manual)
  sourceBatchId     String?      // pro audio batch
  sourceBatch       TaskAudioBatch? @relation(fields: [sourceBatchId], references: [id])
  rawSnippet        String?      @db.Text

  // Hierarchie — 1 úroveň (rodič + děti). Stage 2 audio extrakce může
  // seskupit dílčí kroky pod jeden rodičovský úkol ("výlet s Matějem":
  // rezervovat hotel, koupit lístky, vzít kameru, ...).
  parentId          String?
  parent            Task?        @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks          Task[]       @relation("TaskSubtasks")

  // Todoist push (one-way out)
  todoistTaskId     String?
  todoistProjectId  String?
  pushedAt          DateTime?
  pushError         String?      @db.Text

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  completedAt       DateTime?

  @@index([userId, status, dueAt])
  @@index([sourceBatchId])
  @@index([assignedToContactId])
  @@index([parentId])
  @@index([userId, todoistTaskId])
  // Unique chrání proti race conditions při dvojitém push (dva paralelní
  // požadavky před idempotence checkem) — DB sama zabrání duplicitě.
  @@unique([userId, todoistTaskId], map: "Task_userId_todoistTaskId_unique")
}

model TaskAudioBatch {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])

  audioPath       String?
  audioMime       String?
  audioBytes      Int?
  audioDurationSec Int?

  rawTranscript   String?          @db.Text
  proposalsJson   Json?            // [{ title, dueAt, dueIsTime, tags, priority, notes, rawSnippet, assignedToContactId? }]
  status          TaskBatchStatus  @default(processing)
  processingError String?          @db.Text

  createdAt       DateTime         @default(now())
  reviewedAt      DateTime?

  tasks           Task[]

  @@index([userId, status])
}

// ============================================================================
// AI USAGE TRACKING — log každého Gemini volání pro kostový přehled
// ============================================================================

model AiUsageLog {
  id             String   @id @default(cuid())
  at             DateTime @default(now())

  userId         String?  // null pro cron běhy bez user kontextu
  module         String   // "briefing" | "task-extract" | "audio-stage1" | ...
  model          String   // "gemini-2.5-flash" | "gemini-2.5-pro"
  mode           String   // "vertex" | "api"

  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  costUsd        Float    @default(0)
  costCzk        Float    @default(0)
  durationMs     Int      @default(0)

  success        Boolean  @default(true)
  errorMsg       String?

  @@index([at])
  @@index([module, at])
}

// ============================================================================
// DENÍK (samostatný JournalEntry model — diktafonový + textový vstup)
// ============================================================================

enum JournalMood {
  ELATED
  CONTENT
  NEUTRAL
  TIRED
  STRESSED
  DOWN
  ANGRY
  MIXED
}

enum JournalStatus {
  draft
  processing
  ready
  error
}

model JournalEntry {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])

  date              DateTime      @db.Date
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  title             String?
  bodyMarkdown      String        @db.Text
  rawTranscript     String?       @db.Text
  mood              JournalMood?
  tags              String[]      @default([])
  people            String[]      @default([])  // z hlavičky LIDÉ — vyhledávání
  highlights        String[]      @default([])

  audioPath         String?
  audioMime         String?
  audioBytes        Int?
  audioDurationSec  Int?
  audioRetainForever Boolean      @default(false)
  audioDeletedAt    DateTime?

  status            JournalStatus @default(draft)
  processingError   String?       @db.Text

  @@index([userId, date])
  @@index([status])
}

// ============================================================================
// EDITOVATELNÉ AI PROMPTY (override defaultů z kódu)
// ============================================================================

model AiPrompt {
  id        String   @id @default(cuid())
  module    String   @unique  // "ozvena-stage2-journal", "ozvena-stage2-task", ...
  content   String   @db.Text
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([module])
}

// ============================================================================
// RAG — modul „Zeptat se" (full-text vyhledávání nad deníky / úkoly / Studnou)
// ============================================================================

/// Chunk = blok textu ze zdrojové entity (deník / úkol / Studna nahrávka)
/// pre-spočítaný embedding (768 dim, Gemini text-embedding-004).
/// Při dotazu spočítáme embedding dotazu a najdeme nejbližší chunky cosine sim.
model RagChunk {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Reference do zdrojové entity (volně, bez FK aby šlo soft-mazat zdroj
  // bez kaskády — chunk se promaže reindexem nebo cleanup cronem).
  sourceType  String   // "journal" | "task" | "studna"
  sourceId    String
  chunkIdx    Int      // 0..N-1 pořadí chunku v rámci zdroje
  text        String   @db.Text

  // Vektor pgvector. Unsupported = Prisma nezná typ, ale generuje sloupec.
  // Vyhledávání + insert zajišťuje raw SQL (viz src/lib/rag.ts).
  embedding   Unsupported("vector(768)")?

  // Snapshot kdy byl chunk vytvořen — pro audit a budoucí cleanup
  createdAt   DateTime @default(now())

  @@unique([sourceType, sourceId, chunkIdx])
  @@index([userId, sourceType])
}

// ============================================================================
// VÝROČÍ — paměť na osobní data (svatby, výročí, zesnulí, první rande, ...)
// ============================================================================

/// Anniversary = jedna položka v Petrově osobním kalendáři vzpomínek.
/// Není to klasický CalendarEvent — žádný iCloud sync, jen evidence v DB
/// + reminder cron 7:00 ráno.
model Anniversary {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String   // "Výročí svatby", "Babička †", "První rande s Marií"
  month       Int      // 1-12
  day         Int      // 1-31
  // Volitelný rok = pro počítání kolikáté výročí.
  // Např. svatba 2010 → letos 2026 = "16. Výročí svatby (3.5.)".
  year        Int?
  note        String?  @db.Text

  // null = žádný reminder, 0 = jen na samý den, 7 = týden předem, atd.
  reminderDaysBefore Int?
  reminderChannels   String[] @default([]) // "email" | "whatsapp"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, month, day])
}

// ============================================================================
// ŽIJEŠ? — Check-in formulář pro pravidelnou sebereflexi (2× denně 13:00/18:00)
// Interocepční nástroj. PDF specifikace: docs ze 2026-05-01.
// Žádná penalizace, žádné streaks, žádná gamifikace.
// ============================================================================

model CheckIn {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String   // "lunch" (polední 13:00) | "evening" (večerní 18:00)

  // Blok 1 — Tělo
  // "HH:MM" string (jednodušší než TIME, povoluje null = "nepamatuju si")
  lastMealAt   String?
  lastWaterAt  String?
  bodyFeeling  String?  @db.Text   // krátký text nebo "nevím"

  // Blok 2 — Mysl
  mood         Int?                // 1-10
  whatWorked   String?  @db.Text   // krátký text nebo "nic"

  // Blok 3 — Vztahy a vzorce
  contacts     String?  @db.Text   // jména nebo "ne"
  oldPattern   String?  @db.Text   // krátký text nebo "ne"

  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

// ============================================================================
// Web Push subscription (push notifikace na mobil bez WhatsApp / email)
// ============================================================================

/// Jeden device subscription (browser/PWA na konkrétním zařízení).
/// Petr může mít víc — iPhone, iPad, desktop Chrome — každý je separátní subscription.
model WebPushSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint    String   @unique  // URL push servisu (Apple/Google/Mozilla)
  p256dh      String              // Base64 public key z prohlížeče
  auth        String              // Base64 auth secret z prohlížeče

  // Pro UI „Smazat tohle zařízení"
  label       String?  // "iPhone Safari", "Mac Chrome", ručně Petr edituje
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  lastError   String?  // pokud Apple/Google vrátí 410 (gone) nebo jiný error

  @@index([userId])
}

// ============================================================================
// B&W Myš — rozhodovací systém (longitudinální sběr vstupů → AI vyhodnocení)
// Spec: Návody / Check-in_Formular_Zadani.pdf  (přesný popis sekcí A-H, toků 1-7)
// ============================================================================

model Decision {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  nazev               String   // pracovní název pro orientaci v archivu
  kontext             String   // "pracovni" | "osobni" | "smiseny"
  otazka              String   @db.Text  // formulovaná jako otázka
  varianty            Json     // String[] — minimum 3
  predpoklady         Json     // String[] — minimum 1

  deadlineRozhodnuti  DateTime
  delkaSberuDny       Int      @default(14)
  status              String   @default("aktivni")  // aktivni|uzavrene_jdu|uzavrene_nejdu|odlozene|archivovane

  datumVytvoreni      DateTime @default(now())
  datumUzavreni       DateTime?
  datumRevize         DateTime?
  // Pokud status=odlozene, kdy se má vrátit do aktivni (cron porovnává)
  odlozenoDo          DateTime?

  verdiktText         String?  @db.Text
  coByZmeniloVerdikt  String?  @db.Text

  // Doplněk 2 — autorství rozhodnutí (krok 2.5 ve formuláři)
  // pro_me | pro_jineho | spolecne | nejsem_si_jisty
  autorstvi           String   @default("pro_me")
  autorstviKdo        String?  // text, pro koho dalšího (u pro_jineho/spolecne)

  // Doplněk 2 — Tok 5: pokud uživatel chce uzavřít a poslední zápis byl
  // v aktivovaném/staženém stavu, můžeme nabídnout odložení o 48 h.
  odlozeneUzavreniDo  DateTime?
  uzavrenoPresUpozorneni Boolean @default(false)

  entries             DecisionEntry[]
  evaluations         DecisionEvaluation[]
  reopenings          DecisionReopening[]

  updatedAt           DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, datumVytvoreni])
  @@index([odlozenoDo])
}

model DecisionEntry {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  datum       DateTime @default(now())
  nalada      Int      // 1-5
  typVstupu   String   // "novy_fakt_zvenci" | "nova_uvaha" | "napadlo_me" | "reakce_na_udalost"
  uhelPohledu String   @default("nevybrano")  // fakta|emoce|kritika|prinosy|alternativy|meta|nevybrano
  obsah       String   @db.Text

  // Doplněk 2 — stav nervového systému (povinné u nových zápisů)
  // aktivovany | stazeny | klidny | nevim
  // Default "nevim" pro existující entries při migraci.
  stavSystemu String   @default("nevim")

  // Klasifikace doplněná AI při finálním vyhodnocení (pokud uhelPohledu="nevybrano")
  uhelPohleduAi String?

  // Audio source tracking — pokud Entry vznikl z audio záznamu
  audioPath   String?
  audioMime   String?
  audioBytes  Int?

  @@index([decisionId, datum])
}

// Things bulk import — uživatel ručně srovná Things JSON v jiné konverzaci,
// nahraje sem strukturovaný JSON s rozhodnutími (migrate/wishlist/discard).
// Rašeliniště to JEN zpracuje — žádná AI klasifikace.
model ThingsImport {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  filename        String
  rawJson         Json
  totalCount      Int
  migrateCount    Int
  wishlistCount   Int
  discardCount    Int
  status          String    // "uploaded" | "executing" | "completed" | "failed"
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  errorLog        Json?     // pole errorů per-item pokud něco selhalo

  items           ThingsImportItem[]

  @@index([userId, createdAt])
}

model ThingsImportItem {
  id              String    @id @default(cuid())
  importId        String
  import          ThingsImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  thingsUuid      String
  title           String
  decision        String    // "migrate" | "wishlist" | "discard"
  pushResult      String?   // "ok" | "skipped" | "error: ..."
  pushedTaskId    String?   // Todoist task ID nebo Entry ID
  pushedAt        DateTime?

  @@unique([importId, thingsUuid])
  @@index([importId])
}

// Mirror Todoist labelů — read-only kopie pro UI mapping a idempotenci
// při tvorbě nových přes /api/todoist/labels.
model TodoistLabelMirror {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoistId       String
  name            String
  color           String?
  syncedAt        DateTime  @default(now())

  @@unique([userId, todoistId])
  @@index([userId])
  @@index([userId, name])
}

// Mirror Todoist projektů — pull z Sync API, abychom v UI mohli zobrazit jméno
// projektu místo cryptického ID (Task.todoistProjectId odkazuje sem).
model TodoistProjectMirror {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoistId       String
  name            String
  color           String?
  isInbox         Boolean   @default(false)
  parentId        String?
  syncedAt        DateTime  @default(now())

  @@unique([userId, todoistId])
  @@index([userId])
}

// Tracking spuštění interního cron scheduleru (1 DSM entry → dispatcher → 16 jobs).
// Idempotence: před spuštěním job se kontroluje, zda lastSuccessAt je mimo
// aktuální "okno" (denní = dnes, every:Nmin = před více než N min).
model CronRun {
  id              String    @id @default(cuid())
  jobName         String    @unique
  lastTriggeredAt DateTime
  lastSuccessAt   DateTime?
  lastError       String?   @db.Text
  lastDurationMs  Int?
  lastStatus      Int?      // HTTP status z dispatched endpointu
  runCount        Int       @default(0)
  successCount    Int       @default(0)
  errorCount      Int       @default(0)

  @@index([jobName])
}

model DecisionEvaluation {
  id                          String   @id @default(cuid())
  decisionId                  String
  decision                    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  datum                       DateTime @default(now())
  typ                         String   // "prubezne" | "finalni"
  obsahStrukturovany          Json     // celý strukturovaný výstup AI (sekce A-H pro finální)
  argumentsJson               Json?    // mřížka argumentů (jen pro finální), generována zvlášť
  pocetVstupuVDobeGenerovani  Int

  // AI usage tracking
  modelName                   String?
  promptTokens                Int?
  outputTokens                Int?

  @@index([decisionId, datum])
}

model DecisionReopening {
  id                String   @id @default(cuid())
  decisionId        String
  decision          Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  datum             DateTime @default(now())
  popisNovehoFaktu  String   @db.Text
  schvaleno         Boolean  // uživatel sám potvrzuje že to je opravdu nový fakt

  @@index([decisionId, datum])
}
