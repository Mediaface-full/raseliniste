// ============================================================================
// RAG — modul „Zeptat se" (full-text vyhledávání nad deníky / úkoly / Studnou)
// ============================================================================

/// Chunk = blok textu ze zdrojové entity (deník / úkol / Studna nahrávka)
/// pre-spočítaný embedding (768 dim, Gemini text-embedding-004).
/// Při dotazu spočítáme embedding dotazu a najdeme nejbližší chunky cosine sim.
model RagChunk {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Reference do zdrojové entity (volně, bez FK aby šlo soft-mazat zdroj
  // bez kaskády — chunk se promaže reindexem nebo cleanup cronem).
  sourceType  String   // "journal" | "task" | "studna" | "email" (NOVE faze 4)
  sourceId    String
  chunkIdx    Int      // 0..N-1 pořadí chunku v rámci zdroje
  text        String   @db.Text

  // Faze 4 (2026-05-12) — metadata pro Posta hybrid chunking + debugging:
  // - chunkCount: celkovy pocet chunku pro tento sourceId (denormalized
  //   pro snadny lookup "kolik celkem mailo X chunku")
  // - tokenCount: priblizny pocet tokenu (znaky/4 heuristic, ne presny)
  // - sourceKind: pro email "body" | "thread_message" (per Petrovo zadani
  //   thread = kazda zprava samostatne); pro journal/task/studna null
  chunkCount  Int?
  tokenCount  Int?
  sourceKind  String?

  // Vektor pgvector. Unsupported = Prisma nezná typ, ale generuje sloupec.
  // Vyhledávání + insert zajišťuje raw SQL (viz src/lib/rag.ts).
  embedding   Unsupported("vector(768)")?

  // Snapshot kdy byl chunk vytvořen — pro audit a budoucí cleanup
  createdAt   DateTime @default(now())

  @@unique([sourceType, sourceId, chunkIdx])
  @@index([userId, sourceType])
}

// ============================================================================
// PostaEmbedFailure — dead letter queue pro selhaly embed pokus (faze 4).
// Po N retries (default 3) zustavaji zde pro manualni inspekci/reklasifikaci.
// ============================================================================

model PostaEmbedFailure {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailId         String   // EmailMessage.id — soft reference (no FK kvuli
                           // moznosti, ze mail bude smazan retention cronem)
  chunkIndex      Int      // 0-based; -1 pro chyby na urovni celeho mailu
                           // (napr. chunking selhal pred dosazenim per-chunk)
  error           String   @db.Text
  retryCount      Int      @default(0)
  lastAttemptedAt DateTime

  createdAt       DateTime @default(now())

  @@unique([emailId, chunkIndex])
  @@index([userId, lastAttemptedAt])
}

// ============================================================================
// PostaDeletionLog — audit log full-delete operaci (faze 5).
//
// Plne smazani mailu (DELETE /api/posta/emails/:id?full=true) je destructive
// operace — pro GDPR-style "right to be forgotten" requesty nebo mistake
// recovery. Audit log zustava NAVZDY (i kdyz mail samotny + chunks zmizely).
// ============================================================================

// ============================================================================
// EncryptionKey — versioning pro AES-256-GCM klíče (faze 5).
//
// Petrovo zadani: záznam pro ENV-loaded klíč obsahuje placeholder hash,
// NE plain key. Skutečný klíč je v EMAIL_BODY_ENCRYPTION_KEY env var.
// keyId v této tabulce = stabilní identifikátor pro foreign key z
// EmailMessage.bodyEncryptionKeyId.
//
// Rotace: nový klíč → nový row s nove keyId. Stará data zůstávají
// dešifrovatelná pokud Petr stary klíč drží (např. v separate
// EMAIL_BODY_ENCRYPTION_KEY_v1, ..._v2). Migrace re-šifruje na novou verzi
// postupně (future work, ne fáze 5).
// ============================================================================

model EncryptionKey {
  id          Int      @id @default(autoincrement())
  keyId       String   @unique  // "env:current" nebo explicit "env:v1" atd.
  createdAt   DateTime @default(now())
  retiredAt   DateTime?           // null = aktivni, non-null = jen pro decrypt
                                  // starych dat
  // Placeholder hash (SHA-256 z env klíče) pro detekci nesprávně načteného
  // ENV nebo přepsání mezi rotacemi. Plain key NIKDY v DB.
  keyHashSha256 String
  note        String?  @db.Text   // např. "rotated 2026-05-12 — kompromitace klíče v1"
}

// ============================================================================
// DetectedCommitment — vysumele zavazky z odeslanych mailu (faze 6).
//
// Primarka v nasi DB, Todoist je sekundarni mirror (1-way DB→Todoist sync).
// Vyhneme se konflikt resolution peklu dvousmerne synchronizace.
//
// Detector worker: LLM scan over outbound emails (from = User.gmailEmailAddress)
// → kandidati s confidence 0-1 → routing:
//   >=0.85: status=active, auto_created=true, auto-sync do Todoist
//   0.55-0.84: status=active, auto_created=false, jen v UI (needs confirm)
//   <0.55: skip (jen debug log, NE vytvořit záznam)
//
// Lifecycle: active → confirmed | rejected | resolved | merged | stale
// ============================================================================

model DetectedCommitment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Zdroj — mail ze kterého byl závazek detekován
  sourceEmailId   String
  sourceEmail     EmailMessage @relation("CommitmentSource", fields: [sourceEmailId], references: [id], onDelete: Cascade)

  detectedAt      DateTime @default(now())

  // Závazek samotný
  quotedText      String   @db.Text  // přesný citát z mailu
  recipient       String?              // komu byl závazek dán (jméno, nullable)
  recipientEmail  String?              // email recipientu (parsed z To/Cc)
  proposedTitle   String   @db.Text   // LLM návrh názvu úkolu
  deadlineHint    String?              // LLM odhad "do pátku" / "this week"
  parsedDeadline  DateTime?            // pokud se podařilo parsnout na konkrétní datum

  // Dedup — cosine similarity > 0.85 + same recipient + within 7d
  // → soft-link, NE auto-skip. UI nabídne "sloučit" / "jsou to jiné".
  // related_to[] = pole id existujicich active commitmentu se similar quoted_text
  relatedTo       String[] @default([])
  // Po slouceni: druhotny commitment dostane mergedInto = primary.id + status=merged
  mergedInto      String?

  // AI metadata
  confidence      Float                // 0-1 LLM self-report
  promptVersion   String              // "classify_commitment_v1" — version verzování

  // Routing výstup
  // active        — pending decision (auto pokud confidence>=0.85, jinak needs-confirm)
  // confirmed     — Petr explicitne akceptoval (i auto_created Petr můze "ujasnit")
  // rejected      — "tohle není závazek" (auditní data pro budouci prompt revizi)
  // resolved      — splneno, Todoist task closed
  // merged        — soft-merged do jineho commitmentu (viz mergedInto)
  // stale         — 30+ dni bez last_action_at update → auto-archive
  status          String   @default("active")
  autoCreated     Boolean  @default(false) // confidence >= 0.85 = true

  // Timestampy lifecycle
  confirmedAt     DateTime?
  rejectedAt      DateTime?
  resolvedAt      DateTime?
  staleAt         DateTime?
  rejectionReason String?  @db.Text

  // Klíčové pole pro stale detection
  // Aktualizuje se při: (a) vzniku, (b) update statusu, (c) související
  // mail dorazí v threadu source mailu (related_email_ids append)
  lastActionAt    DateTime @default(now())

  // Todoist sync (jednosměrný DB → Todoist, status closed/labeled)
  todoistTaskId   String?

  // Všechny maily co se vážou k tomuto commitmentu (thread + keyword match)
  // Append při příchodu nového mailu — drží commitment "alive" (lastActionAt update)
  relatedEmailIds String[] @default([])

  @@index([userId, status])
  @@index([userId, lastActionAt])
  @@index([sourceEmailId])
  @@index([userId, detectedAt])
  @@index([todoistTaskId])
}

model PostaDeletionLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot pole z EmailMessage v okamziku smazani (po DELETE jiz nedostupne)
  emailId       String   // puvodni EmailMessage.id
  gmailMessageId String  // Gmail ID — pripadny re-import by vytvoril novou row
  threadId      String
  subject       String?  @db.Text
  fromAddress   String
  receivedAt    DateTime

  // Operace metadata
  deletedAt     DateTime @default(now())
  requestedBy   String   // userId kdo smazani vyvolal (typicky stejny jako userId,
                         // ale schema dovoluje admin-iniciovany delete v multi-user
                         // setupu)
  reason        String?  @db.Text  // pro audit: "GDPR request", "mistake", "spam batch"
  chunksDeleted Int      @default(0) // pocet smazanych RagChunk recordu

  @@index([userId, deletedAt])
  @@index([gmailMessageId])
}

// ============================================================================
// VÝROČÍ — paměť na osobní data (svatby, výročí, zesnulí, první rande, ...)
// ============================================================================

/// Anniversary = jedna položka v Petrově osobním kalendáři vzpomínek.
/// Není to klasický CalendarEvent — žádný iCloud sync, jen evidence v DB
/// + reminder cron 7:00 ráno.
model Anniversary {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String   // "Výročí svatby", "Babička †", "První rande s Marií"
  month       Int      // 1-12
  day         Int      // 1-31
  // Volitelný rok = pro počítání kolikáté výročí.
  // Např. svatba 2010 → letos 2026 = "16. Výročí svatby (3.5.)".
  year        Int?
  note        String?  @db.Text

  // null = žádný reminder, 0 = jen na samý den, 7 = týden předem, atd.
  reminderDaysBefore Int?
  reminderChannels   String[] @default([]) // "email" | "whatsapp"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, month, day])
