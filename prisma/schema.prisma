generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
  moduleFormat = "cjs"
  // pgvector — pro RAG (modul „Zeptat se")
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  passwordHash      String
  createdAt         DateTime @default(now())
  lastLoginAt       DateTime?

  // Preferences (konfigurovatelné z /settings)
  notificationEmail String?  // kam posílat health reporty; fallback na env NOTIFICATION_EMAIL
  // WhatsApp target — kam posílat upozornění (Petrovo vlastní číslo v E.164 formátu).
  // Twilio credentials jsou v UserIntegration(provider="twilio").
  whatsappNumber    String?

  // Vlastní popisky rituálů — co Petr v daném rituálu dělá, krok po kroku.
  // JSON ve tvaru { morning_day: "...", friday_reflection: "...", weekly_review: "..." }
  // Null = použijí se default texty z lib/week-rituals.ts. Editovatelné v /settings/ritualy.
  ritualTemplates   Json?

  sessions     Session[]
  passkeys     WebauthnCredential[]
  recordings   Recording[]
  apiTokens    ApiToken[]
  healthMetrics HealthMetric[]
  healthEcgs    HealthEcg[]
  healthAnalyses HealthAnalysis[]
  healthLabReports HealthLabReport[]
  healthLabResults HealthLabResult[]
  contacts      Contact[]
  callLogs      CallLog[]
  integrations  UserIntegration[]
  letterSenders LetterSender[]
  letterRecipients LetterRecipient[]
  letters       Letter[]
  projectBoxes  ProjectBox[]
  guestUsers    GuestUser[]
  tasks            Task[]
  planningDayTemplates PlanningDayTemplate[]
  planningSettings     PlanningSettings?
  taskAudioBatches TaskAudioBatch[]
  journalEntries   JournalEntry[]
  ragChunks        RagChunk[]
  anniversaries    Anniversary[]
  checkIns         CheckIn[]
  sharedFiles      SharedFile[]
  sharedTimelines  SharedTimeline[]
  pushSubscriptions WebPushSubscription[]
  pageLinks         PageLink[]
  postaIgnoreRules  PostaIgnoreRule[]

  // Petr 2026-05-27: tracking timestamp pro push-notifications cron.
  // Items s createdAt > pushLastCheckedAt → pošle push, update timestamp.
  pushLastCheckedAt DateTime?

  // Petr 2026-05-27: per-source push filters. Default true (každý dostane
  // vše dokud si v /settings/push nevypne).
  pushVip              Boolean @default(true)
  pushUrgentEmail      Boolean @default(true)
  pushStudankaGuest    Boolean @default(true)
  pushBookingConfirmed Boolean @default(true)
  decisions        Decision[]
  todoistProjects  TodoistProjectMirror[]
  todoistLabels    TodoistLabelMirror[]
  thingsImports    ThingsImport[]
  customRituals    CustomRitual[]
  smsMessages      SmsMessage[]
  smsReplies       SmsReply[]
  emailMessages    EmailMessage[]
  emailDigests     EmailDigest[]
  postaEmbedFailures PostaEmbedFailure[]
  postaDeletionLogs  PostaDeletionLog[]
  // EncryptionKey nemá user FK — klíče jsou global (jeden klíč šifruje
  // všechny usery v single-user instance + key versioning pro rotace).

  // Todoist incremental sync (Sync API)
  todoistSyncToken  String?  @db.Text
  todoistSyncedAt   DateTime?
  todoistSyncError  String?  @db.Text

  // Pošta — Gmail incremental sync (fáze 1: 2026-05-12)
  // gmailHistoryId — kurzor pro Gmail history.list API, neslouží k full sync
  //   (ten používá messages.list s after: query). Null = ještě neproběhl
  //   první sync (full pull).
  gmailHistoryId    String?
  gmailSyncedAt     DateTime?
  gmailSyncError    String?  @db.Text

  // Faze 5 (2026-05-12) — Gmail push notifications pres Cloud Pub/Sub.
  // gmailWatchExpiresAt — Gmail watch lifetime max 7 dnu (Google limit);
  //   cron `posta-watch-renew` kazdych 5 dnu prodluzi watch (bezpecna rezerva).
  // gmailWatchTopicName — kontrola ze watch ukazuje na nas Pub/Sub topic;
  //   napr. "projects/raseliniste-prod/topics/gmail-watch-petr"
  // gmailLastPushAt — timestamp posledniho prijateho push (sledovani
  //   "30 min od posledniho push → spustit fallback polling")
  gmailWatchExpiresAt DateTime?
  gmailWatchTopicName String?
  gmailLastPushAt     DateTime?

  // Faze 6 (2026-05-12) — Petrova email adresa z Gmail profilu.
  // Detector commitmentu potrebuje vedet "from = ja", aby skenoval JEN odeslane
  // maily (outbound). Populated v posta-sync.ts pres gmail.users.getProfile().
  // Single-user typicky 1 hodnota, ale schema toleruje update (alias addresses).
  gmailEmailAddress    String?

  // 2026-05-15 (kontakty_brief.md 5.4) — Sleduje které kontakty UID už user
  // viděl. Banner "Nově přidané z mobilu" porovná aktuální Contact.icloudUid
  // proti baseline a ukáže diff. "Označit prohlédnuté" = update baseline.
  contactsSeenBaselineAt DateTime?

  // 2026-05-16 — Real-time progress sync pro UI banner. Sync funkce updatuje
  // tenhle JSON v jednotlivých krocích, frontend polluje à 2s.
  // Tvar: { provider: "icloud"|"google", stage: "...", current: N, total: N, mergedClusters: N, startedAt: "ISO", message: "..." }
  contactsSyncProgress Json?

  // 2026-05-13 — Backfill state pro multi-tick zpetny import historie (6 let).
  // Beh: Petr klikne "Stahnout historii X let" → set gmailBackfillStartedAt +
  // gmailBackfillYears. Cron `posta-backfill` 15min volá backfillMetadata():
  // pull jednu page (500 IDs), per-mail messages.get?format=metadata (zadny
  // bodyText), save next pageToken. Po dokonceni set gmailBackfillCompletedAt.
  // Kdyz null, cron neni active.
  gmailBackfillStartedAt   DateTime?
  gmailBackfillCompletedAt DateTime?
  gmailBackfillYears       Int?     // 1, 2, 4, 6, nebo null=all
  gmailBackfillPageToken   String?  // Gmail messages.list pageToken cursor
  gmailBackfillTotalFetched Int     @default(0)
  gmailBackfillError       String?  @db.Text

  detectedCommitments DetectedCommitment[]
  schedulingConfig    SchedulingConfig?
  contactGroups       ContactGroup[]
  contactBackups      ContactBackup[]
}

/// Záloha kontaktu před úpravou / smazáním (kontakty_brief.md 5.8 F).
/// Vytváří se automaticky před každým PUT do iCloudu / před DELETE.
/// UI „Obnova ze zálohy" listuje posledních 80 záznamů a může každou
/// obnovit jako nový kontakt nebo přepsat stávající (přes UID match).
model ContactBackup {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot kontaktu jako vCard 3.0 string (kompatibilní napříč zdroji)
  vcardSnapshot   String   @db.Text
  contactId       String?  // FK na původní Contact (nullable — Contact mohl být smazán)
  displayName     String   // pro UI listování bez parsing vCardy
  // Důvod zálohy:
  //   "before_put"    — před PUT do iCloudu (změna)
  //   "before_delete" — před DELETE z iCloudu (smazání)
  //   "before_merge"  — sekundární kontakt před sloučením v duplicit merge
  action          String

  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([contactId])
}

/// Booking scheduling config — 1 řádek per user, editovatelné z /calendar/settings.
/// Single-user typicky 1 řádek. Default hodnoty pocházejí z bývalého hardcoded
/// configu v src/lib/rules-config.ts (před 2026-05-13).
///
/// Den-of-week: 0=Sunday, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat.
/// "HH:MM" 24h time strings.
model SchedulingConfig {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dostupnost per typ schůzky
  pragueDays       Int[]
  pragueHoursStart String   // "09:00"
  pragueHoursEnd   String   // "17:00"
  homeDays         Int[]
  homeHoursStart   String
  homeHoursEnd     String
  onlineDays       Int[]
  onlineHoursStart String
  onlineHoursEnd   String

  // Petr 2026-06-19: pracovní oběd v Praze (90 min default, 11:00-13:30 default)
  lunchDays         Int[]    @default([])
  lunchHoursStart   String   @default("11:00")
  lunchHoursEnd     String   @default("13:30")

  // Denní okolnosti
  lunchBreakStart  String   // "12:00"
  lunchBreakEnd    String   // "13:00"
  endOfDay         String   // "17:00"

  // Buffery
  bufferPragueMinutes        Int   // minimum před cestou do Prahy
  bufferOnlineBetweenMinutes Int   // mezi online schůzkami

  // Booking-only
  minLeadTimeClientHours Int
  minLeadTimeFriendHours Int
  maxBookingHorizonDays  Int

  // Day-load limity
  maxPragueWarning     Int     // > X → warning v Praze
  maxInPersonWarning   Int     // > X → warning prezenčních
  maxInPersonError     Int     // > X → error
  maxOnlineWarning     Int     // > X → warning online
  weightedLoadWarning  Float   // prezenční=1.0, online=0.6
  weightedLoadError    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebauthnCredential {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId    String    @unique // base64url
  publicKey       Bytes
  counter         BigInt    @default(0)
  transports      String[]  // ["internal", "hybrid", "usb", ...]
  deviceType      String    // "singleDevice" | "multiDevice"
  backedUp        Boolean
  nickname        String?
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ---- Capture: ingest → klasifikace → triage ----

model Recording {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  source          RecordingSource
  rawText         String

  processedAt     DateTime?
  processingError String?

  createdAt       DateTime @default(now())

  entries         Entry[]

  @@index([userId, createdAt])
}

model Entry {
  id               String      @id @default(cuid())
  recordingId      String
  recording        Recording   @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  type             EntryType
  text             String
  rawExcerpt       String?

  // Pouze pro TASK
  suggestedProject String?
  suggestedWhen    TaskWhen?
  rationale        String?

  // Pouze pro KNOWLEDGE
  knowledgeCategory String?
  knowledgeUrl      String?
  knowledgeTags     String[] @default([])

  // Obecné hashtagy (teď hlavně pro JOURNAL po AI redakci)
  hashtags          String[] @default([])

  // Volitelná lokace odkud byl záznam pořízen (GPS z iPhone Shortcutu).
  // JSON: { lat: number, lng: number, name?: string, accuracy?: number }
  location          Json?

  status           EntryStatus @default(PENDING)

  // Push TASK položek do Todoistu (z /tasks stránky). Non-null = už je v TD.
  todoistTaskId    String?
  todoistProjectId String?

  // Ručně označeno jako hotové v /tasks nebo /notes (nezávisle na Todoistu).
  completedAt      DateTime?

  createdAt        DateTime    @default(now())
  confirmedAt      DateTime?

  @@index([recordingId])
  @@index([status])
  @@index([type, status, completedAt])
}

// ---- Zdravotní data (Apple Health přes Health Auto Export) ----

model HealthMetric {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Typ metriky = přesný název z HAE (step_count, weight_body_mass,
  // blood_pressure, sleep_analysis, heart_rate_variability, ...)
  type        String
  recordedAt  DateTime
  source      String   // "Petr – Apple Watch|Pacer" apod.
  unit        String?  // "kg", "count", "count/min", "kJ", "mmHg", "hr", ...

  // 14 z 17 metrik = simple scalar (step_count, weight, HRV, kroky, ...)
  qty         Float?

  // blood_pressure special-case
  bpSystolic  Float?
  bpDiastolic Float?

  // sleep_analysis: core/deep/rem/awake/asleep/inBed a časové rozsahy
  // — heterogenní pole, ukládáme jako JSONB pro fulltext/analýzu později.
  sleepData   Json?

  // Raw HAE položka (pro pozdější recovery kdyby se měnila schema).
  raw         Json?

  createdAt   DateTime @default(now())

  // ==== Unique constraint proti duplicitám ====
  // Jeden zdravotní záznam je definovaný trojicí (typ, čas, zdroj).
  // HAE tenhle tuple drží napříč exporty, takže re-ingest je bezpečný.
  @@unique([userId, type, recordedAt, source])
  @@index([userId, type, recordedAt])
}

model HealthAnalysis {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  periodFrom      DateTime
  periodTo        DateTime
  focus           String?
  trigger         AnalysisTrigger @default(MANUAL)

  text            String   // markdown odpověď z Gemini
  model           String   // "gemini-2.5-pro"
  promptChars     Int?
  totalSamples    Int?
  metricsWithData Int?

  emailSentAt     DateTime?
  emailError      String?

  // AI processing status pro fire-and-forget (NOVÉ 2026-05-06)
  status          String   @default("ready")
  processingError String?  @db.Text

  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, periodFrom, periodTo])
}

enum AnalysisTrigger {
  MANUAL
  MONTHLY_AUTO
}

// Laboratorní výsledky z PDF (Petr 2026-07-16). Upload PDF → Gemini flash
// extrakce hodnot → historické řady per analyt. Originál PDF zůstává
// (AI extrakce ~99 %, ne 100 % — dohledatelnost je nutná).
model HealthLabReport {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  filename        String            // původní jméno souboru
  pdfPath         String            // relativní cesta v uploads (health-labs/…)
  pdfBytes        Int

  sampledAt       DateTime?         // datum odběru (z AI extrakce)
  labName         String?

  status          String   @default("processing") // processing | ready | error
  processingError String?  @db.Text
  model           String?           // použitý Gemini model

  createdAt       DateTime @default(now())

  results         HealthLabResult[]

  @@index([userId, sampledAt])
}

model HealthLabResult {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  reportId    String
  report      HealthLabReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  analyte     String            // zobrazovaný název ("Glukóza")
  analyteKey  String            // normalizovaný slug pro časové řady ("glukoza")
  value       Float?            // číselná hodnota (null u textových výsledků)
  valueText   String?           // "negativní", "nezjištěno" apod.
  unit        String?
  refLow      Float?
  refHigh     Float?
  refText     String?           // referenční rozmezí jak stálo v PDF
  flag        String?           // "H" (nad), "L" (pod), null = v normě

  sampledAt   DateTime          // denormalizace z reportu — řazení řad

  createdAt   DateTime @default(now())

  @@index([userId, analyteKey, sampledAt])
  @@index([reportId])
}

model HealthEcg {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  startedAt      DateTime
  source         String
  classification String?  // "sinusRhythm", "atrialFibrillation", ...
  averageHr      Float?

  // Voltage samples jsou velké pole (10k+ bodů) — JSONB se komprimuje líp
  // než samostatná tabulka, queries na EKG raw data dělat nebudeme.
  voltageData    Json
  symptoms       Json?

  raw            Json?
  createdAt      DateTime @default(now())

  @@unique([userId, startedAt, source])
  @@index([userId, startedAt])
}

// ---- Gideonův Firewall: kontakty + call-log + integrace ----

model Contact {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])

  planningDigests PlanningSettings[]

  displayName  String
  firstName    String?
  // 5. pád (vokativ) pro oslovení v emailech a na /call-log VIP variantě.
  // Volitelné — pokud chybí, použije se algoritmus s výjimkami; pokud algoritmus
  // selže (cizí jméno apod.), fallback na firstName v 1. pádu.
  firstNameVocative String?
  // VIP-only: úplné vlastní oslovení (např. „drahá dívko", „kamaráde", „šéfe").
  // Pokud je vyplněno, na /call-log VIP nahradí defaultní „Ahoj, <vokativ>"
  // celým tímhle stringem. Necháme styl Petrovi — žádné formátování server-side.
  greetingOverride  String?
  lastName     String?
  note         String?
  isVip        Boolean        @default(false)

  // Petr 2026-07-06: výchozí Meet link kontaktu. Když má hodnotu a potvrdí se
  // online booking schůzka s tímto kontaktem, použije se TENHLE link místo
  // generování nového Meet přes Google conferenceData. Use case: klienti
  // s trvalou Meet místností.
  defaultMeetLink   String?

  // Booking módy (kalendář): kontakt může mít víc tagů zároveň
  isClient            Boolean        @default(false)
  isFriend            Boolean        @default(false)
  isFamily            Boolean        @default(false)
  defaultBookingMode  BookingMode?

  // Tým member — pro Todoist smart routing #3 (tým = lidé s kterými Petr
  // dlouhodobě pracuje, např. Dominik, Agáta). NOVÉ 2026-05-10.
  // Routing: assignee s isTeam=true → projekt "Práce" / sekce <jméno>.
  isTeam              Boolean        @default(false)

  // Petr 2026-05-25: Todoist Workspace user ID. Když přiřadí úkol členovi
  // týmu a tohle je vyplněné, task-todoist-push.ts pošle responsible_uid
  // → Gáťa/Lucie/Matěj dostanou reálnou notifikaci v Todoistu.
  // Bez tohoto se úkol jen vytvoří v jejich sekci, ale je asignován Petrovi.
  todoistUserId       String?

  // Slug klienta — kontakt patří k tomuto klientovi (např. tk-stavby).
  // Jeden kontakt = jeden klient (kontaktní osoba). Routing #2: assignee
  // s clientTag → projekt "Práce" / sekce odpovídající slugu.
  // Také použito v AI extract promptu — Gemini získá distinct seznam slugů
  // a v audiu je rozpoznává jako tag `klient-<slug>`. NOVÉ 2026-05-10.
  clientTag           String?

  // Aliases pro AI extract (NOVÉ 2026-05-10, alias systém):
  // - aliases: jak jinak Petr v audiu kontakt nazývá (např. "TK", "Tékáčko",
  //   "Karel z TK") → AI fuzzy match a vyplní assignedToContactName
  //   kanonickým displayName/firstName.
  // - clientTagAliases: synonyma pro slug klienta (např. clientTag="tk-stavby"
  //   + aliases ["TK", "TK Stavby", "Tékáčko"]) → AI v audiu rozpozná
  //   a generuje kanonický klient-tk-stavby tag.
  // Routing s aliases nepracuje — pracuje s kanonickou hodnotou.
  aliases             String[]       @default([])
  clientTagAliases    String[]       @default([])

  // Narozeniny — stačí den a měsíc (rok obvykle neznámý)
  birthMonth   Int?
  birthDay     Int?
  // Reminder na narozeniny — null = žádné předem, 0 = jen na samý den (popřát),
  // 7 = týden předem (čas na dárek), atd.
  birthdayReminderDaysBefore Int?
  birthdayReminderChannels   String[]  @default([])

  // VIP token pro /call-log (privátní link na zadávání misí + výpis Giďoušových misí).
  // Generuje se automaticky když Contact.isVip = true. Stabilní (neměnný) dokud Petr
  // nezvolí regenerate (tlačítko v /contacts u VIP). 24 znaků base64url.
  callLogToken            String?    @unique
  callLogTokenCreatedAt   DateTime?

  importedFrom String?        // "vcard" | "manual" | "google"
  externalId   String?        // UID z vCard, pokud má

  // Google People API sync
  googleResourceName  String?        @unique
  googlePhotoUrl      String?
  lastGoogleSyncAt    DateTime?

  // iCloud CardDAV sync (2026-05-14, kontakty_brief.md fáze 1).
  // iCloud je primární zdroj pravdy pro core fields (jméno, telefony, emaily,
  // adresa, narozeniny, skupiny, firma). Rašeliniště drží jako overlay
  // navíc isVip/aliases/clientTag/callLogToken/isTeam/... — ty iCloud nevidí.
  icloudUid          String?        @unique  // UID z vCard (stabilní napříč syncy)
  icloudEtag         String?                  // ETag pro optimistic concurrency PUT
  icloudHref         String?                  // CardDAV path pro PUT/DELETE
  lastIcloudSyncAt   DateTime?

  // Core fields rozšířené pro plný kontakt model (vCard 3.0 kompatibilita)
  company            String?                  // ORG vCard field
  addressLines       String[]       @default([]) // ADR vCard (víceřádková adresa)
  birthYear          Int?                      // úplné datum (kromě birthMonth/birthDay)
  // Apple skupiny — denormalizace na kontaktu (názvy skupin čárkou oddělené
  // ve vCard přes X-ABLabel nebo CATEGORIES). Pro UI tabulky stačí pole jmen.
  // Authoritative source ale je ContactGroup s seznamem členů — kontaktní
  // pole se generuje při syncu.
  groups             String[]       @default([])
  // Provenience záznamu: "icloud" | "google" | "manual"
  syncSource         String?

  phones       Phone[]
  emails       ContactEmail[]
  callLogs     CallLog[]
  bookingInvites      BookingInvite[]
  assignedTasks       Task[]   @relation("TaskAssignee")

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([userId, isVip])
  @@index([userId, birthMonth, birthDay])
  @@index([userId, isClient])
  @@index([userId, isFriend])
  @@index([userId, icloudUid])
}

/// Apple iCloud skupiny — v CardDAV jsou skupiny samostatné vCardy s typem
/// `group` a seznamem členských UID. Aplikace to abstrahuje (uživatel vidí
/// čárkou oddělený seznam v Contact.groups), ale autoritativní zdroj je
/// tahle tabulka. Při uložení změny aplikace spočte diff a updatuje
/// příslušné skupinové vCardy na iCloud serveru.
///
/// Petr 2026-05-14 (kontakty_brief.md sekce 4, 7).
model ContactGroup {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String                            // canonical jméno (case-insensitive unique)
  memberUids  String[]      @default([])        // UIDs z Contact.icloudUid

  // iCloud CardDAV sync
  icloudUid   String?       @unique
  icloudEtag  String?
  icloudHref  String?
  lastIcloudSyncAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

enum BookingMode {
  CLIENT
  FRIEND
}

model Phone {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  number    String  // normalizovaný E.164 např. "+420777123456"
  label     String? // "mobile" | "work" | "home" | "other"

  @@unique([contactId, number])
  @@index([number]) // rychlé lookup při příchozím hovoru
}

model ContactEmail {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  email     String
  label     String?

  @@unique([contactId, email])
}

model CallLog {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])

  phoneNumber  String    // normalizovaný E.164 tak jak přišel
  rawNumber    String    // jak skutečně přišel z URL (pro audit)
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id])

  message      String
  isUrgent     Boolean   @default(false)
  wasVip       Boolean   @default(false) // snapshot v době přijetí

  // VIP-only: požadovaný termín splnění, propíše se do Todoist jako due_date.
  // Volitelný — VIP může nechat prázdné a Gideon si termín nastaví sám.
  requestedDueAt DateTime?

  ip           String?
  userAgent    String?

  todoistTaskId    String? // ID v Todoist pokud se podařilo vytvořit
  todoistProjectId String?
  todoistError     String? // pokud push selhal

  mailSentAt   DateTime? // kdy byl odeslán email Gideonovi
  mailError    String?

  seenAt       DateTime? // Gideon označil jako vyřízené

  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, seenAt])
}

model UserIntegration {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  provider   String   // "todoist" | budoucí "superlist" | "plaud" atd.

  // Encrypted credentials (AES-256-GCM, klíč odvozen ze SESSION_SECRET)
  tokenEnc   String   // ciphertext v base64
  tokenIv    String   // IV v base64
  tokenTag   String   // auth tag v base64

  // Per-provider konfigurace (pro Todoist: { vyruseni: projectId, vip: projectId })
  config     Json?

  lastUsedAt DateTime?
  lastError  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, provider])
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  name        String
  tokenHash   String    @unique
  prefix      String

  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

enum RecordingSource {
  SHORTCUT
  WEB
  MANUAL
}

enum EntryType {
  TASK
  JOURNAL
  THOUGHT
  CONTEXT
  KNOWLEDGE
}

enum TaskWhen {
  TODAY
  THIS_WEEK
  SOMEDAY
}

enum EntryStatus {
  PENDING
  CONFIRMED
  DISCARDED
}

model LoginAttempt {
  id        String   @id @default(cuid())
  username  String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([username, createdAt])
  @@index([ip, createdAt])
}

// ---- Dopisy: odesílatelé, adresáti, dopisy s PDF ----

model LetterSender {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  name          String   // "Petr Perina (osobní)", "ART76", "ABC s.r.o."
  legalName     String?  // formální název pro hlavičku, pokud se liší
  ico           String?
  dic           String?

  // Adresa odesílatele (volitelné, multiline)
  addressLines  String[] @default([])

  email         String?
  phone         String?
  web           String?
  bankAccount   String?

  // Cesty k souborům (relativní k UPLOADS_DIR)
  logoPath      String?
  signaturePath String?

  // AI prompt pro tlačítko "Učesat" — per odesílatel.
  // Per dopis se k tomuto promptu může připojit krátký override
  // (např. "vypíchni tučně klíčové body").
  redactPrompt  String  @default("Učeš text dopisu do formálního, zdvořilého a srozumitelného tónu. Zachovej oslovení i závěr napsané uživatelem. Neměň fakta. Vrať jen výsledný text bez vysvětlivek a bez markdown formátování.")

  // PDF design preset (zatím jen "classic"; do budoucna 'minimal', 'bold', ...)
  pdfTheme      String  @default("classic")

  letters       Letter[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model LetterRecipient {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  name         String   // "Pan Karel Novák" / "ČSOB, a.s."
  addressLines String[] @default([])

  letters      Letter[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Letter {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  senderId      String
  sender        LetterSender @relation(fields: [senderId], references: [id])

  recipientId   String?
  recipient     LetterRecipient? @relation(fields: [recipientId], references: [id])

  // Snapshot adresáta v momentě generování — i kdyby uživatel kontakt
  // později smazal nebo upravil, dopis si pamatuje, jak vypadal.
  recipientNameSnapshot         String?
  recipientAddressLinesSnapshot String[] @default([])
  showRecipientAddress          Boolean  @default(true)

  // Datum dopisu (default = dnes, lze přepsat)
  letterDate    DateTime @default(now())
  // Místo (např. "V Praze") — volitelné, zobrazí se jen pokud vyplněno
  place         String?

  // Vstupní text (co uživatel napsal) + finální text (po případném "učesání")
  // Pokud nepoužije Učesat, bodyFinal == bodyRaw.
  bodyRaw       String
  bodyFinal     String

  // Per-dopis prompt addendum (přidá se k senderRedactPrompt)
  promptOverride String?

  // Verzování — pokud je toto regenerace, parent ukáže původní dopis.
  parentLetterId String?
  parent         Letter?  @relation("LetterVersions", fields: [parentLetterId], references: [id])
  versions       Letter[] @relation("LetterVersions")
  version        Int      @default(1)

  // Cache PDF na disku (relativně k UPLOADS_DIR)
  pdfPath        String?
  pdfGeneratedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([senderId])
}

// ---- Studna: sdílené projektové boxíky s hlasovými záznamy ----

model ProjectBox {
  id                String   @id @default(cuid())
  userId            String   // owner (single-user systém = Petr)
  user              User     @relation(fields: [userId], references: [id])

  name              String   // "ART76 brainstorm"
  homeTitle         String?  // pod ikonou na ploše iPhone, max ~9 znaků
  description       String?  // kontext pro AI prompt + onboarding PDF

  // AI prompt overrides (pokud null, použije se default v lib/audio-transcribe.ts)
  extractionPrompt  String?

  // Per-projekt custom Studna/Prskavka prompty pro Stage 2 analýzu.
  // Priorita: tento override > DB global override (/settings/ai-prompts) > default v kódu.
  // Vyplňuje se v UI detailu projektu. Když null, použije se globální.
  studnaStandardPrompt  String?  @db.Text
  studnaBriefPrompt     String?  @db.Text

  // Per-projekt override Gemini modelu pro Stage 2 (analýza). Null = default
  // chování: BRIEF=Pro, STANDARD=Flash. Pokud vyplněno (např. "gemini-2.5-pro"),
  // použije se na všechny analýzy v projektu. Stage 1 (přepis) je vždy Flash.
  analysisModel     String?

  // Per-projekt vlastní prompt pro Souhrn projektu (tlačítko v detail UI volá
  // summarizeProject — agregát napříč všemi nahrávkami). Null = default prompt
  // v project-summary.ts. Vrací markdown, ne JSON — Petr může psát volně.
  projectSummaryPrompt String? @db.Text

  // Notifikace v 18:00 cron — pokud false, projekt se v digestu vynechá
  includeInDigest   Boolean  @default(true)

  // Petr 2026-07-06: integrace s externím systémem (SRO Manager).
  // webhookUrl: po dokončení přepisu POST JSON s přepisem na tuto URL.
  // webhookSecret: HMAC-SHA256 podpis payloadu v hlavičce X-Raseliniste-Signature.
  // externalClientRef: ID/slug klienta v externím systému — párování projekt↔klient.
  webhookUrl        String?
  webhookSecret     String?
  externalClientRef String?

  // Prskavka modul = osobní projekty (knížky, nápady, soukromé tvoření).
  // false = klasická Studánka (sdílená s klienty), true = Prskavka (jen Petr).
  // Liší se jen filtrem a kde se zobrazí, jinak je chování identické.
  isPrivate         Boolean  @default(false)

  invitations       ProjectInvitation[]
  recordings        ProjectRecording[]
  summaries         ProjectSummary[]
  files             ProjectFile[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  archivedAt        DateTime?

  @@index([userId])
}

// Admin (owner) přílohy ke projektu — PDF, XLS, DOC, obrázky atd.
// Žádná AI analýza, jen storage a download. Petr je u Studánky/Prskavky
// jediný uploader — hosté soubory nepřidávají.
// Sdílené soubory — Gideon nahraje, dostane share link, klient stáhne, po
// 14 dnech se soubor automaticky smaže. Veřejný download přes /g/<token>.
model SharedFile {
  id           String   @id @default(cuid())
  userId       String   // owner (Petr)
  user         User     @relation(fields: [userId], references: [id])

  token        String   @unique // 24 znaků base64url, public URL
  filename     String   // bezpečné jméno na disku
  originalName String
  mime         String
  bytes        Int
  storagePath  String

  uploadedAt   DateTime @default(now())
  expiresAt    DateTime // typicky uploadedAt + 14 dní; cron maže po expiraci
  downloadCount Int     @default(0)
  lastDownloadAt DateTime?

  @@index([userId, uploadedAt])
  @@index([expiresAt])
}

model ProjectFile {
  id           String   @id @default(cuid())
  projectId    String
  project      ProjectBox @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Petr 2026-06-19: kdo nahrál — null = Petr (admin), guestUserId = host přes Studánku.
  guestUserId  String?
  guestUser    GuestUser? @relation(fields: [guestUserId], references: [id], onDelete: SetNull)

  filename     String   // bezpečné jméno na disku (uuid + ext)
  originalName String   // původní jméno z uploadu (pro download "save as")
  mime         String
  bytes        Int
  storagePath  String   // relativní k UPLOADS_PATH

  // Volitelný popis — Petr si může napsat „faktura listopad 2026" apod.
  note         String?  @db.Text

  // Petr 2026-06-19: extrakce textu z dokumentu (PDF/DOCX/XLSX/TXT) + RAG index.
  // Status: null (audio nebo neznámý typ, neextrahujeme) | "pending" | "ok" | "error".
  // extractedText: plný text pro RAG search + audit. Max ~100k chars.
  extractedText    String? @db.Text
  extractionStatus String?
  extractionError  String?

  uploadedAt   DateTime @default(now())

  @@index([projectId, uploadedAt])
  @@index([guestUserId])
}

model GuestUser {
  id          String   @id @default(cuid())
  ownerUserId String   // kdo ho vlastní (Petr)
  owner       User     @relation(fields: [ownerUserId], references: [id])

  email       String
  name        String
  phone       String?

  // Stabilní token v URL /me/<guestToken>. Lze regenerovat — invaliduje
  // všechny dříve sdílené odkazy.
  guestToken  String   @unique

  invitations ProjectInvitation[]
  recordings  ProjectRecording[]
  files       ProjectFile[]

  createdAt   DateTime @default(now())
  lastSeenAt  DateTime?

  // Jeden Karel per Petr (matching podle emailu).
  @@unique([ownerUserId, email])
  @@index([ownerUserId])
}

model ProjectInvitation {
  id              String   @id @default(cuid())
  projectId       String
  project         ProjectBox @relation(fields: [projectId], references: [id], onDelete: Cascade)
  guestUserId     String
  guestUser       GuestUser  @relation(fields: [guestUserId], references: [id], onDelete: Cascade)

  // Per-projekt permission — některý host má brief permission jinde, jinde ne.
  canRecordBrief  Boolean  @default(false)

  // Per-projekt × per-host: zachovat audio nahrávky tohoto hosta natrvalo.
  // Default false → STANDARD audio se po 14 dnech maže (transkript zůstává).
  // Při true → cleanup-audio cron tento konkrétní pár (projekt × host) přeskočí.
  keepAudio       Boolean  @default(false)

  // Per-projekt × per-host: může nahrát audio SOUBOR (MP3/M4A/...) jako UPLOAD
  // recording. Žádná AI analýza, jen přepis. Bez tohoto flagu host neuvidí
  // Upload tlačítko ani UPLOAD recordingy ve výpisu.
  canUploadAudio  Boolean  @default(false)

  invitedAt       DateTime @default(now())

  @@unique([projectId, guestUserId])
  @@index([guestUserId])
}

model ProjectRecording {
  id              String   @id @default(cuid())
  projectId       String
  project         ProjectBox @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Autor. Buď GuestUser, nebo owner (pak guestUserId == null + isOwner == true).
  guestUserId     String?
  guestUser       GuestUser? @relation(fields: [guestUserId], references: [id])
  isOwner         Boolean  @default(false)
  authorName      String   // snapshot — i kdyby host byl smazán, dopis ví autora

  type            RecordingType @default(STANDARD)

  // Audio storage (relativní k UPLOADS_PATH; null = soubor smazán cleanup cronem)
  audioPath       String?
  audioMime       String?
  audioBytes      Int?
  audioDurationSec Int?

  // Transkript se zachová vždy
  transcript      String

  // Volný text který klient/host napsal vedle hlasové nahrávky (URL, jména,
  // čísla — věci co se hlasem zkomolí). Není to AI analyzováno, jen uloženo.
  // Nepovinné, max ~8000 znaků. Petr to vidí v detailu nahrávky.
  guestNote       String?  @db.Text

  // Pro type=UPLOAD: původní filename ze stroje uploadera. V UI se zobrazuje
  // jako název záznamu (host pozná podle filename z disku). Null pro audio
  // záznamy nahrávané přes mikrofon (STANDARD/BRIEF).
  uploadedFilename String?

  // Strukturovaný rozbor z Gemini (volné JSON pro flexibilitu)
  // {
  //   summary: string,
  //   key_themes: string[],
  //   thoughts: [{ text, importance, rationale, category }],
  //   open_questions: string[],
  //   sentiment: string,
  //   intensity_signals: string,
  //   ... (brief navíc: glossary, actors, decision_history)
  // }
  analysis        Json?

  // User-driven: zachovat audio i po 14 dnech (jen pro STANDARD; brief se nemaže nikdy)
  isPinned        Boolean  @default(false)

  // Status zpracování (asynchronní transcribe může selhat)
  status          String   @default("processing") // processing | processed | error
  processingError String?

  ip              String?
  userAgent       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  archivedAt      DateTime?

  @@index([projectId, createdAt])
  @@index([guestUserId])
  @@index([type, createdAt])
}

enum RecordingType {
  STANDARD       // < 10 min, Flash, audio mizí za 14 dní (pokud nepinned)
  BRIEF          // klíčový brief, Pro s deep analýzou, audio se nikdy nemaže
  UPLOAD         // host/admin nahrál audio soubor — JEN přepis, bez Stage 2 analýzy, audio se nemaže
}

model ProjectSummary {
  id          String   @id @default(cuid())
  projectId   String
  project     ProjectBox @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Markdown výstup z Gemini Pro nad všemi recordings (briefy s vyšší vahou)
  text        String
  model       String   // "gemini-2.5-pro"
  recordingsIncluded Int
  briefsIncluded     Int

  // AI processing status pro fire-and-forget (NOVÉ 2026-05-06)
  status      String   @default("ready")
  processingError String?  @db.Text

  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
}

// ============================================================================
// Kalendář & Bookingy
// ============================================================================

enum CalendarSource {
  GOOGLE_PRIMARY      // Petrův pracovní/osobní Google
  ICLOUD_SON          // synův program (read-only)
  ICLOUD_PARTNER      // partnerčiny služby (read-only)
  RASELINISTE         // vytvořeno přímo v Rašeliništi (rezerva, zatím nepoužíváno)
  LOCAL_ICS           // nahraný .ics soubor (display-only, neblokuje booking, žádný sync)
}

// Nahraný .ics kalendář (Petr 2026-07-15) — čistě informativní zobrazení
// v Rašeliništi. Nikam se nesynchronizuje, booking ho ignoruje.
model LocalCalendar {
  id          String          @id @default(cuid())
  name        String
  filename    String
  eventCount  Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  events      CalendarEvent[]
}

enum EventType {
  MEETING_PRAGUE      // prezenční v Praze
  MEETING_HOME        // prezenční u Petra doma
  MEETING_ELSEWHERE   // prezenční jinde (Plzeň, Brno...)
  MEETING_ONLINE      // online (Meet, Zoom...)
  MEETING_LUNCH_PRAGUE // pracovní oběd v Praze (90 min, 11:00-13:30)
  PERSONAL            // soukromé, nepatří do bookingů
  HOCKEY_SON          // hokejové tréninky (auto z ICLOUD_SON)
  PARTNER_SHIFT       // partnerčina směna (auto z ICLOUD_PARTNER)
  PARTNER_VACATION    // partnerčina dovolená (kontext, neblok)
  OOO_FULL            // dovolená, vše blokované
  OOO_TRAVEL_WORKING  // nomád, jen prezenční blokované
  OTHER
}

// Nastavení plánování (ADHD F4) — digest pro kolegyni.
model PlanningSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  digestEnabled   Boolean  @default(false)
  digestContactId String?  // Contact (isTeam) — příjemce denního digestu
  digestContact   Contact? @relation(fields: [digestContactId], references: [id])
}

// Šablona týdne — theme days (Petr 2026-07-22, ADHD F3).
// Po/Pá manager (schůzky, admin), Út/St maker (deep work klienti),
// Čt vlastní projekty. Řídí badge na /planovani, AI plánování a soft
// warning při schůzce v maker/own dni.
model PlanningDayTemplate {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekday Int     // 0 = pondělí … 6 = neděle
  mode    String  // "manager" | "maker" | "own" | "off"
  label   String? // volitelný popisek ("Klienti", "StoryMapa"…)

  @@unique([userId, weekday])
}

model Location {
  id              String          @id @default(cuid())
  name            String          @unique          // "Praha", "Jílové u Prahy", "Plzeň"
  aliases         String[]        @default([])     // ["Prague", "Vinohrady", ...]
  commuteMinPeak  Int                              // ve špičce (min)
  commuteMinOff   Int                              // mimo špičku (min)
  isLocal         Boolean         @default(false)  // domov / žádný commute
  createdAt       DateTime        @default(now())

  events          CalendarEvent[]
}

model CalendarEvent {
  id              String          @id @default(cuid())
  source          CalendarSource
  externalId      String          // Google event ID nebo iCloud UID
  sourceUrl       String?         // odkaz zpět (např. Google Calendar URL)

  type            EventType
  title           String
  description     String?         // Markdown z popisu události
  locationText    String?         // volný text z eventu
  locationId      String?
  location        Location?       @relation(fields: [locationId], references: [id])

  startsAt        DateTime
  endsAt          DateTime
  allDay          Boolean         @default(false)
  timezone        String          @default("Europe/Prague")

  // Per-event metadata jen v Rašeliništi (ne v Google)
  prepNote        String?
  itemsToBring    Json?           // [{name: "knížky", forPerson: "Franta"}, ...]
  manualOverride  Boolean         @default(false)  // commit přes /quickadd 'přesto zapsat'

  // Booking metadata
  bookingInviteId String?
  bookingInvite   BookingInvite?  @relation(fields: [bookingInviteId], references: [id])

  // Lokální .ics kalendář (jen pro source=LOCAL_ICS)
  localCalendarId String?
  localCalendar   LocalCalendar?  @relation(fields: [localCalendarId], references: [id], onDelete: Cascade)

  // Sync metadata
  lastSyncedAt    DateTime
  etag            String?
  deletedRemotely Boolean         @default(false)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([source, externalId])
  @@index([startsAt, endsAt])
  @@index([type, startsAt])
  @@index([source, lastSyncedAt])
  @@index([localCalendarId])
}

enum BookingMeetingType {
  CHOICE_PRAGUE
  CHOICE_ONLINE
  CHOICE_HOME
  CHOICE_ANY
  CHOICE_LUNCH_PRAGUE   // Petr 2026-06-19: pracovní oběd v Praze, 90 min
}

enum BookingStatus {
  PENDING       // odeslán link, ještě nekliknul
  VIEWED        // klient otevřel
  RESERVED      // vybral slot, čekáme magic-link confirm
  CONFIRMED     // potvrzeno, event vytvořen
  CANCELED
  EXPIRED
}

model BookingInvite {
  id              String              @id @default(cuid())
  token           String              @unique     // 32 znaků
  mode            BookingMode
  meetingType     BookingMeetingType

  contactId       String?
  contact         Contact?            @relation(fields: [contactId], references: [id])

  // Pro cold leady (z /schuzka, žádný Contact)
  inviteeName     String?
  inviteeEmail    String?
  inviteePhone    String?
  inviteeSubject  String?

  internalNote    String?
  // Petr 2026-05-25: veřejná poznámka — host ji uvidí v pickeru, v Google
  // eventu (description) a v .ics. Doplňuje internalNote (jen pro Petra).
  publicNote      String?

  // Délka slotu v minutách — Petr volí při tvorbě (30/45/60/90/120)
  slotDurationMin Int                 @default(60)

  status          BookingStatus       @default(PENDING)
  validUntil      DateTime
  reservedSlot    Json?               // {startsAt, endsAt, type}
  confirmedAt     DateTime?

  // Petr 2026-05-25: Meet link + Google event ID persistované, aby resend
  // mohl poslat skutečný odkaz a /diagnose endpoint zobrazil celý řetězec.
  meetLink        String?
  googleEventId   String?

  // Petr 2026-05-25: per-invite earliest slot — host neuvidí sloty před
  // tímhle datem. Null = jen globální lead time z SchedulingConfig.
  // Použije se MAX(now + leadTime, availableFrom).
  availableFrom   DateTime?

  events          CalendarEvent[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([token])
  @@index([status, validUntil])
}

