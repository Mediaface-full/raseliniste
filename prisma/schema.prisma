// ============================================================================
// ÚKOLY (samostatný Task model — nezávislý na Entry/Capture)
// ============================================================================

enum TaskStatus {
  open
  done
  cancelled
}

enum TaskPriority {
  low
  normal
  high
}

enum TaskSource {
  manual
  audio
  quickadd
  capture
  todoist_pull
  vip_call_log
  things_import
}

enum TaskBatchStatus {
  processing
  review
  committed
  discarded
  error
}

model Task {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id])

  title             String
  notes             String?      @db.Text
  dueAt             DateTime?
  dueIsTime         Boolean      @default(false)   // true = včetně času

  // Execution date ≠ deadline (Petr 2026-07-22, ADHD plánování F1):
  // KDY to budu dělat — plánovaný den výroby. Rašeliniště-only overlay,
  // do Todoistu se nesyncuje. Board: /planovani.
  plannedFor        DateTime?
  tags              String[]     @default([])
  status            TaskStatus   @default(open)
  priority          TaskPriority @default(normal)

  // Delegace — komu je úkol přidělen (z Contacts).
  // null = vlastní úkol Petra.
  assignedToContactId String?
  assignedToContact   Contact?  @relation("TaskAssignee", fields: [assignedToContactId], references: [id])

  // Origin tracking
  source            TaskSource   @default(manual)
  sourceBatchId     String?      // pro audio batch
  sourceBatch       TaskAudioBatch? @relation(fields: [sourceBatchId], references: [id])
  rawSnippet        String?      @db.Text

  // Hierarchie — 1 úroveň (rodič + děti). Stage 2 audio extrakce může
  // seskupit dílčí kroky pod jeden rodičovský úkol ("výlet s Matějem":
  // rezervovat hotel, koupit lístky, vzít kameru, ...).
  parentId          String?
  parent            Task?        @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks          Task[]       @relation("TaskSubtasks")

  // Todoist push (one-way out)
  todoistTaskId     String?
  todoistProjectId  String?
  pushedAt          DateTime?
  pushError         String?      @db.Text

  // Manuální override Smart routingu (Petr 2026-06-09). Pokud nastavené,
  // task-todoist-push.ts je preferuje před resolveRoute(). Petr klikl na
  // chip 📁 v Triage a vybral projekt sám.
  manualTodoistProjectId  String?
  manualTodoistSectionId  String?

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  completedAt       DateTime?

  @@index([userId, status, dueAt])
  @@index([userId, status, plannedFor])
  @@index([sourceBatchId])
  @@index([assignedToContactId])
  @@index([parentId])
  @@index([userId, todoistTaskId])
  // Unique chrání proti race conditions při dvojitém push (dva paralelní
  // požadavky před idempotence checkem) — DB sama zabrání duplicitě.
  @@unique([userId, todoistTaskId], map: "Task_userId_todoistTaskId_unique")
}

model TaskAudioBatch {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])

  audioPath       String?
  audioMime       String?
  audioBytes      Int?
  audioDurationSec Int?

  rawTranscript   String?          @db.Text
  proposalsJson   Json?            // [{ title, dueAt, dueIsTime, tags, priority, notes, rawSnippet, assignedToContactId? }]
  status          TaskBatchStatus  @default(processing)
  processingError String?          @db.Text

