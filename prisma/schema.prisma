// ============================================================================
// Web Push subscription (push notifikace na mobil bez WhatsApp / email)
// ============================================================================

/// Jeden device subscription (browser/PWA na konkrétním zařízení).
/// Petr může mít víc — iPhone, iPad, desktop Chrome — každý je separátní subscription.
// Petr 2026-05-27: user-defined web shortcuts. Sidebar sekce „Page Links"
// + /links stránka renderuje boxy jako /start, /settings/page-links CRUD.
model PageLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  url       String
  // Tint name z palety: peach/mint/lavender/sky/sage/butter/rose/pink
  tint      String   @default("sky")
  // Volitelná lucide icon name (např. "globe", "book"); default null = generic globe
  icon      String?
  order     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, order])
}

// Petr 2026-05-27: blacklist emailových odesílatelů/domén pro /notifikace
// a push cron. Per-user. Matchuje fromAddress / fromName podle matchType.
model PostaIgnoreRule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Pattern dle matchType:
  //  - contains: substring v fromAddress nebo fromName (case insensitive)
  //  - domain: fromAddress končí "@<pattern>" (pattern bez @, např. "newsletter.cz")
  //  - exact:  fromAddress přesně = pattern
  pattern   String
  matchType String   @default("contains")
  // Volitelný human-readable popis k čemu rule slouží
  label     String?
  enabled   Boolean  @default(true)

  createdAt DateTime @default(now())

  @@index([userId, enabled])
}

model WebPushSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint    String   @unique  // URL push servisu (Apple/Google/Mozilla)
  p256dh      String              // Base64 public key z prohlížeče
  auth        String              // Base64 auth secret z prohlížeče

  // Pro UI „Smazat tohle zařízení"
  label       String?  // "iPhone Safari", "Mac Chrome", ručně Petr edituje
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  lastError   String?  // pokud Apple/Google vrátí 410 (gone) nebo jiný error

  @@index([userId])
}

// ============================================================================
// B&W Myš — rozhodovací systém (longitudinální sběr vstupů → AI vyhodnocení)
// Spec: Návody / Check-in_Formular_Zadani.pdf  (přesný popis sekcí A-H, toků 1-7)
// ============================================================================

model Decision {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  nazev               String   // pracovní název pro orientaci v archivu
  kontext             String   // "pracovni" | "osobni" | "smiseny"
  otazka              String   @db.Text  // formulovaná jako otázka
  varianty            Json     // String[] — minimum 3
  predpoklady         Json     // String[] — minimum 1

  deadlineRozhodnuti  DateTime
  delkaSberuDny       Int      @default(14)
  status              String   @default("aktivni")  // aktivni|uzavrene_jdu|uzavrene_nejdu|odlozene|archivovane

  datumVytvoreni      DateTime @default(now())
  datumUzavreni       DateTime?
  datumRevize         DateTime?
  // Pokud status=odlozene, kdy se má vrátit do aktivni (cron porovnává)
  odlozenoDo          DateTime?

  verdiktText         String?  @db.Text
  coByZmeniloVerdikt  String?  @db.Text

  // Doplněk 2 — autorství rozhodnutí (krok 2.5 ve formuláři)
  // pro_me | pro_jineho | spolecne | nejsem_si_jisty
  autorstvi           String   @default("pro_me")
  autorstviKdo        String?  // text, pro koho dalšího (u pro_jineho/spolecne)

  // Doplněk 2 — Tok 5: pokud uživatel chce uzavřít a poslední zápis byl
  // v aktivovaném/staženém stavu, můžeme nabídnout odložení o 48 h.
  odlozeneUzavreniDo  DateTime?
  uzavrenoPresUpozorneni Boolean @default(false)

  entries             DecisionEntry[]
  evaluations         DecisionEvaluation[]
  reopenings          DecisionReopening[]

  updatedAt           DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, datumVytvoreni])
  @@index([odlozenoDo])
}

model DecisionEntry {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  datum       DateTime @default(now())
  nalada      Int      // 1-5
  typVstupu   String   // "novy_fakt_zvenci" | "nova_uvaha" | "napadlo_me" | "reakce_na_udalost"
  uhelPohledu String   @default("nevybrano")  // fakta|emoce|kritika|prinosy|alternativy|meta|nevybrano
  obsah       String   @db.Text

  // Doplněk 2 — stav nervového systému (povinné u nových zápisů)
  // aktivovany | stazeny | klidny | nevim
  // Default "nevim" pro existující entries při migraci.
  stavSystemu String   @default("nevim")

  // Klasifikace doplněná AI při finálním vyhodnocení (pokud uhelPohledu="nevybrano")
  uhelPohleduAi String?

  // Audio source tracking — pokud Entry vznikl z audio záznamu
  audioPath   String?
  audioMime   String?
  audioBytes  Int?

  // AI processing status — pro fire-and-forget audio entries (NOVÉ 2026-05-06)
  // "ready" = hotovo, "processing" = AI Stage 1+2 běží na pozadí, "error" = AI selhala
  status          String   @default("ready")
  processingError String?  @db.Text

  @@index([decisionId, datum])
}

// Things bulk import — uživatel ručně srovná Things JSON v jiné konverzaci,
// nahraje sem strukturovaný JSON s rozhodnutími (migrate/wishlist/discard).
// Rašeliniště to JEN zpracuje — žádná AI klasifikace.
model ThingsImport {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  filename        String
  rawJson         Json
  totalCount      Int
  migrateCount    Int
  wishlistCount   Int
  discardCount    Int
  status          String    // "uploaded" | "executing" | "completed" | "failed"
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  errorLog        Json?     // pole errorů per-item pokud něco selhalo

  items           ThingsImportItem[]

  @@index([userId, createdAt])
}

model ThingsImportItem {
  id              String    @id @default(cuid())
  importId        String
  import          ThingsImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  thingsUuid      String
  title           String
  decision        String    // "migrate" | "wishlist" | "discard"
  pushResult      String?   // "ok" | "skipped" | "error: ..."
  pushedTaskId    String?   // Todoist task ID nebo Entry ID
  pushedAt        DateTime?

  @@unique([importId, thingsUuid])
  @@index([importId])
}

// Mirror Todoist labelů — read-only kopie pro UI mapping a idempotenci
// při tvorbě nových přes /api/todoist/labels.
model TodoistLabelMirror {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoistId       String
  name            String
  color           String?
  syncedAt        DateTime  @default(now())

  @@unique([userId, todoistId])
  @@index([userId])
  @@index([userId, name])
}

// Mirror Todoist projektů — pull z Sync API, abychom v UI mohli zobrazit jméno
// projektu místo cryptického ID (Task.todoistProjectId odkazuje sem).
model TodoistProjectMirror {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoistId       String
  name            String
  color           String?
  isInbox         Boolean   @default(false)
  parentId        String?
  syncedAt        DateTime  @default(now())

  // Team Workspace support (Petr 2026-05-18 — Cesta B).
  // workspaceId = id Team Workspace (např. "645948" = Mefa) nebo null = Personal.
  // Sync API vrací `workspace_id` na Team projektech, na Personal je field absentní.
  // isTeamProject = derived (workspaceId != null), persisted pro index speed.
  // accessVisibility = "team" / "restricted" — sekundární diskriminátor.
  workspaceId       String?
  isTeamProject     Boolean   @default(false)
  accessVisibility  String?

  // Folder support (Petr 2026-05-20). Todoist Team Workspace nepodporuje
  // sub-projekty přes parent_id — místo toho má FOLDERS. Více projektů ve
  // stejné složce sdílí folder_id. Pro Timeline View modul potřebujeme
  // agregovat projekty ze stejné složky do jedné timeline.
  folderId          String?
  folderName        String?

  @@unique([userId, todoistId])
  @@index([userId])
  @@index([userId, workspaceId])
}

// Tracking spuštění interního cron scheduleru (1 DSM entry → dispatcher → 16 jobs).
// Idempotence: před spuštěním job se kontroluje, zda lastSuccessAt je mimo
// aktuální "okno" (denní = dnes, every:Nmin = před více než N min).
model CronRun {
  id              String    @id @default(cuid())
  jobName         String    @unique
  lastTriggeredAt DateTime
  lastSuccessAt   DateTime?
  lastError       String?   @db.Text
  lastDurationMs  Int?
  lastStatus      Int?      // HTTP status z dispatched endpointu
  runCount        Int       @default(0)
  successCount    Int       @default(0)
  errorCount      Int       @default(0)

  @@index([jobName])
}

// =============================================================================
// Project Timeline View — F4 share link (Petr 2026-05-19)
// JEDINÁ povolená migrace mimo F1 dle zadani-timeline-view.pdf § 8.
// Public read-only URL pro klienty bez loginu.
// =============================================================================
model SharedTimeline {
  id              String    @id @default(cuid())
  userId          String                                              // owner (Petr)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId       String                                              // TodoistProjectMirror.todoistId snapshot
  projectName     String                                              // snapshot — kdyby projekt přejmenován
  token           String    @unique                                   // random URL token
  expiresAt       DateTime                                            // po vypršení 404
  createdAt       DateTime  @default(now())
  revokedAt       DateTime?                                           // soft delete (Petr může revoke)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// =============================================================================
// MailLog — historie všech odeslaných mailů z aplikace (Petr 2026-05-20)
// Pro retrospektivní ověření zda email odešel (booking confirmace, sdílení,
// notifikace). Bez tohoto byly maily black box — Resend dashboard mimo Rašeliniště.
// =============================================================================
model MailLog {
  id          String   @id @default(cuid())
  to          String                                    // recipient email
  subject     String
  provider    String                                    // "smtp" | "resend" | "log"
  ok          Boolean
  providerId  String?                                   // Resend message ID nebo SMTP messageId
  error       String?  @db.Text
  context     String?                                   // "booking-confirm" / "share-link" / ...
  createdAt   DateTime @default(now())

  @@index([to])
  @@index([createdAt(sort: Desc)])
  @@index([context, createdAt(sort: Desc)])
}

// Historie backupů — záznam po každém /api/cron/backup runu. Admin UI
// /settings/backup-log čte tuto tabulku. Vzor hlidactk (denní záloha
// modul). Petr 2026-05-17.
model BackupRun {
  id              String    @id @default(cuid())
  startedAt       DateTime
  finishedAt      DateTime
  durationMs      Int
  ok              Boolean
  triggeredBy     String    // "cron" | "manual-session" | "manual-key"

  pgDumpOk        Boolean
  pgDumpBytes     Int?      // nullable: fail = no bytes
  pgDumpError     String?   @db.Text

  uploadsTarOk    Boolean
  uploadsTarBytes Int?
  uploadsTarError String?   @db.Text

  rsyncOk         Boolean
  rsyncSkipped    Boolean   @default(false)
  rsyncError      String?   @db.Text

  retentionOk     Boolean
  retentionDeleted Int?
  retentionError  String?   @db.Text

  createdAt       DateTime  @default(now())

  @@index([startedAt(sort: Desc)])
  @@index([ok])
}

// Audit log pro Todoist routing — kde úkol skončil + proč.
// Viditelný v /settings/crons (sekce "Routing audit log").
// Smaže se po 30 dnech (cron cleanup-audit-log nebo manuálně).
// NOVÉ 2026-05-10 — kvůli auto-create projektu/sekce ať Petr vidí
// kdy a proč Rašeliniště vytvořilo nový Todoist resource.
model RoutingAuditLog {
  id              String    @id @default(cuid())
  userId          String
  taskId          String?   // Task.id v Rašeliništi (může být null pro VIP route)
  taskTitle       String    // snapshot — task se může smazat
  rule            String    // "vip" | "klient-tag" | "klient-contact" | "team" | "people" | "personal-tag" | "fallback"
  matchedValue    String?   // konkrétní hodnota co matchla (např. "tk-stavby", "Dominik", "dum")
  todoistProjectName String?
  todoistSectionName String?
  todoistProjectId   String?
  todoistSectionId   String?
  autoCreatedProject Boolean @default(false) // true pokud projekt vznikl při push
  autoCreatedSection Boolean @default(false) // true pokud sekce vznikla při push
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, autoCreatedProject])
  @@index([userId, autoCreatedSection])
}

model DecisionEvaluation {
  id                          String   @id @default(cuid())
  decisionId                  String
  decision                    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  datum                       DateTime @default(now())
  typ                         String   // "prubezne" | "finalni"
  obsahStrukturovany          Json     // celý strukturovaný výstup AI (sekce A-H pro finální)
  argumentsJson               Json?    // mřížka argumentů (jen pro finální), generována zvlášť
  pocetVstupuVDobeGenerovani  Int

  // AI usage tracking
  modelName                   String?
  promptTokens                Int?
  outputTokens                Int?

  // AI processing status pro fire-and-forget (NOVÉ 2026-05-06)
  // "ready" = hotovo, "processing" = AI běží na pozadí, "error" = AI selhala
  status                      String   @default("ready")
  processingError             String?  @db.Text

  @@index([decisionId, datum])
}

model DecisionReopening {
  id                String   @id @default(cuid())
  decisionId        String
  decision          Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  datum             DateTime @default(now())
  popisNovehoFaktu  String   @db.Text
  schvaleno         Boolean  // uživatel sám potvrzuje že to je opravdu nový fakt

  @@index([decisionId, datum])
}

// ============================================================================
// SMS — GoSMS integrace (univerzální modul, použitelný napříč Rašeliništěm)
// Doc: https://doc.gosms.eu/?lang=cs
// Credentials per-user v UserIntegration(provider="gosms").
// ============================================================================

enum SmsStatus {
  pending      // čekající na odeslání (scheduled v budoucnosti)
  sent         // odesláno do GoSMS, bez potvrzení doručení
  delivered    // doručenka přišla (alespoň 1 příjemce)
  undelivered  // explicitně neuspělo (operátor vrátil neúspěch)
  failed       // chyba při odesílání nebo invalidní příjemci
  cancelled    // zrušeno před odesláním přes DELETE
}

model SmsMessage {
  id                String     @id @default(cuid())
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ID zprávy v GoSMS (z `link: api/v1/messages/{id}`). Null jen v okamžiku
  // mezi vytvořením DB rowy a úspěšným POSTem do GoSMS — pak se update.
  gosmsMessageId    String?    @unique

  // Příjemci jako pole E.164 čísel — snapshot v okamžiku odeslání.
  recipients        String[]   @default([])
  // Příjemci nevalidní podle GoSMS (čísla která API odmítlo)
  invalidRecipients String[]   @default([])

  body              String     @db.Text
  channelId         Int        // GoSMS channel ID použitý pro tuto zprávu

  status            SmsStatus  @default(pending)

  // Volitelné odložené odeslání (předáno jako expectedSendStart do API)
  scheduledFor      DateTime?

  // Odkaz na entitu která SMS vyvolala — JSON `{type: "task", id: "..."}`.
  // Možné typy zatím: "task" | "contact" | "recording" | "ad-hoc"
  // (rozšiřitelné bez migrace; sirotčí odkazy jsou OK — log je audit trail).
  linkedEntity      Json?

  // Cena za odeslání (CZK/EUR podle organizace) — vyplněno když známe z API.
  cost              Float?
  currency          String?

  // Pinned = neuklizovat 90denním cleanup cronem (pro důležité zprávy).
  isPinned          Boolean    @default(false)

  sentAt            DateTime?  // kdy server odeslal POST do GoSMS
  deliveredAt       DateTime?  // čas první doručenky
  failedAt          DateTime?
  errorMessage      String?    @db.Text

  // Doručenky per recipient — JSON `{ "+420...": "2026-05-10T17:32:45Z", ... }`
  // Aktualizováno z webhooku nebo polling cronu.
  deliveryDetails   Json?

  replies           SmsReply[]

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([gosmsMessageId])
}

// ============================================================================
// POŠTA — Email Intelligence (fáze 1: 2026-05-12)
// Gmail integrace přes Google OAuth. Tato fáze: čistý import + storage.
// Klasifikace, embeddingy, UI, klasifikace -- fáze 2+.
// ============================================================================

model EmailMessage {
  id                String     @id @default(cuid())
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Gmail identifikátory — message ID v Gmailu je 16-znakový hex string,
  // unique napříč všemi schránkami. Idempotence: druhý import stejné zprávy
  // = no-op (upsert by gmailMessageId).
  gmailMessageId    String     @unique
  threadId          String     // gmail thread ID (sjednocení konverzace)

  // Hlavičky — parsované z raw_headers pro rychlé filtrování bez JSON pathu.
  fromAddress       String     // RFC5322 email (bez display name)
  fromName          String?    // display name z From headeru
  toAddresses       String[]   @default([])  // pole emailů
  ccAddresses       String[]   @default([])
  bccAddresses      String[]   @default([])
  subject           String?    @db.Text
  snippet           String?    @db.Text      // Gmail-generated preview (~150 znaků)

  // Tělo — fáze 5 (2026-05-12): AES-256-GCM šifrování at-rest.
  // POKUD bodyTextCiphertext IS NOT NULL → encrypted, použij EmailBodyCrypto.decrypt()
  // POKUD bodyText IS NOT NULL → legacy plain text (back-compat pro pre-fáze-5 data)
  // Migration script encryption-migrate-existing.ts šifruje legacy řádky postupně.
  bodyText          String?    @db.Text     // legacy plain (deprecated, retain pro back-compat)
  bodyHtml          String?    @db.Text     // legacy plain (deprecated)

  // Faze 5 encrypted blobs — format: AES-256-GCM s 12B nonce + 16B tag.
  // bodyTextCiphertext = base64(nonce(12B) || ciphertext(N) || tag(16B))
  // bodyEncryptionKeyId = FK na EncryptionKey.keyId (versioning pro rotace)
  bodyTextCiphertext String?   @db.Text
  bodyHtmlCiphertext String?   @db.Text
  bodyEncryptionKeyId String?  // EncryptionKey.keyId; null = nešifrované (legacy)

  // Gmail labely (např. ["INBOX", "IMPORTANT", "CATEGORY_PERSONAL"]).
  labels            String[]   @default([])

  hasAttachments    Boolean    @default(false)
  // attachment metadata jen — payload v Gmailu na demand, neukládáme
  attachments       Json?      // [{filename, mimeType, sizeBytes, attachmentId}]

  // Raw headers jako JSONB — pro budoucí analýzu (DKIM, SPF, X-* headers).
  rawHeaders        Json

  receivedAt        DateTime   // z Gmail internalDate (epoch ms)
  importedAt        DateTime   @default(now())
  bodyDeletedAt     DateTime?  // 96denní retention cron nuluje bodyText/HTML, metadata zůstává

  // Faze 6 hint — placeholder pro budouci detekci vychozich zavazku.
  // Schema je tu pripraveno, populace prijde s implementaci DetectedCommitment.
  // Default false; po klasifikaci faze 6 nastavi na true u odeslanych mailu
  // se signalama jako "ozvu se", "poslu do patku", atd. Diky tomu nemusime
  // pri rescanu prochazet vsechny maily, jen ty s candidates.
  hasOutboundCommitmentCandidates Boolean @default(false)

  // Faze 3 (2026-05-12) — Petr "oznacit jako vyrizene" v /posta UI.
  // null = aktivni (zobrazi se v listu). Non-null = archivovany.
  // Sidebar badge counter pocita jen WHERE resolvedAt IS NULL.
  resolvedAt        DateTime?
  resolvedReason    String?    // "manual" | "auto-archive-newsletter" (faze 5+) | atd.

  // Faze 4 (2026-05-12) — RAG embeddings. null = jeste neembededovano.
  // Worker cron `posta-embed` (every 5 min) hleda WHERE classification IS NOT NULL
  // AND embeddedAt IS NULL LIMIT 50, generuje chunks + embeddings do RagChunk.
  embeddedAt        DateTime?

  classification    EmailClassification?
  sourceCommitments DetectedCommitment[] @relation("CommitmentSource")

  @@index([userId, receivedAt])
  @@index([userId, threadId])
  @@index([threadId])
  @@index([userId, importedAt])
  @@index([userId, hasOutboundCommitmentCandidates])
  @@index([userId, resolvedAt])
  @@index([userId, embeddedAt])
}

// ============================================================================
// Klasifikace mailu — faze 2 (2026-05-12)
// Ortogonalni schema dle INSTRUKCE/POSTA-DESIGN-DECISIONS.md
//   action_type   x   content_type   x   urgency   x   escalation
// + suggestedAction, projectHint, reason
//
// Jeden zaznam per EmailMessage (1:1). Reklasifikace = update existujiciho
// zaznamu (NE novy radek — historii klasifikaci pro fazi 2 nepotrebujeme).
// ============================================================================

model EmailClassification {
  id              String       @id @default(cuid())

  messageId       String       @unique
  message         EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // CO S TIM DELAT (akce)
  // action_required   — ceka na moji akci (odpoved, rozhodnuti, akce)
  // waiting_external  — poslal jsem neco, ceka se na druhou stranu
  // informational     — k precteni/povedomi, zadna akce
  // noise             — archivovat (marketing, automaty, spam)
  actionType      String

  // CO TO JE (obsah)
  // klient | osobni | admin | newsletter | reklama
  // | systemovy | bezpecnostni | spam
  contentType     String

  // low | medium | high
  urgency         String

  // true pokud LLM detekoval eskalacni markery V TEXTU, NEBO
  // post-processing DB check naslo >=2 nedavne maily od stejneho
  // odesilatele bez moji odpovedi v poslednich 7 dnech.
  escalation      Boolean      @default(false)

  // Kratky akcni navrh — "odpovedet dnes do 18h", "schválit fakturu",
  // "delegovat na Karla", "archivovat".
  suggestedAction String?

  // Volny odhad projektu/tematu — pro pozdejsi clusterovani v UI/digestu.
  projectHint     String?

  // 1 veta proc takhle — pro debug + zobrazeni v digestu.
  reason          String       @db.Text

  // Audit metadata
  model           String       // "gemini-2.5-flash"
  confidence      Float?       // 0-1, self-report z LLM (nullable kvuli pripadu kdy LLM nedonese)
  classifiedAt    DateTime     @default(now())
  // Pokud LLM vraci escalation=false ale post-processing override na true,
  // ulozime tu flag pro debug.
  escalationDbOverride Boolean @default(false)

  @@index([actionType])
  @@index([contentType])
  @@index([urgency])
  @@index([escalation])
}

// ============================================================================
// EmailDigest — denni snapshot stavu Posty (faze 3, 2026-05-12)
//
// Cron `posta-digest` denne 7:00 generuje 1 zaznam per den per user.
// Strukturovany JSON `content` obsahuje:
//   - top action_required (priorita dle urgency + escalation + receivedAt)
//   - eskalace (escalation=true OR urgency=high)
//   - waiting_external prehled (kratky outbound stav)
//   - counts dle actionType + contentType
//   - LLM-generated reflective summary (vyhled do dne)
//
// Schema content JSONu je intentionalne loose — finalni mockup je v
// INSTRUKCE/POSTA-PHASE-3.md (a SPEC.md az ho Petr posle), schema povoluje
// rust bez migrace.
// ============================================================================

model EmailDigest {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  forDate         DateTime @db.Date  // den ke kteremu se digest vztahuje (Praha TZ)
  generatedAt     DateTime @default(now())

  // Strukturovany obsah pro UI render. Tvar zatim:
  // {
  //   topActions: [{ emailId, subject, fromName, urgency, suggestedAction, reason }],
  //   escalations: [{ emailId, subject, fromName, urgency, reason }],
  //   waitingExternal: [{ emailId, subject, toAddresses, since }],
  //   counts: { actionType: { action_required: N, ... }, contentType: { klient: N, ... } },
  //   summary: "1-2 vety LLM reflexe (Co me dnes ceka)",
  //   model: "gemini-2.5-flash",
  //   totalActiveEmails: N
  // }
  content         Json

  viewedAt        DateTime?  // kdy Petr otevrel /posta (pro stats)

  @@unique([userId, forDate])
  @@index([userId, forDate])
}

model SmsReply {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Spárování na původní zprávu (pokud webhook poslal `links.message`).
  // Null = nespárovaná odpověď (přišla bez kontextu).
  smsMessageId      String?
  smsMessage        SmsMessage? @relation(fields: [smsMessageId], references: [id], onDelete: SetNull)

  // ID odpovědi v GoSMS (deduplikace).
  gosmsReplyId      String      @unique

  fromNumber        String      // E.164 normalized
  toSourceNumber    String?     // číslo/sender ID na které přišla
  body              String      @db.Text
  receivedAt        DateTime

  // Pro multipart SMS (více částí) — uchováme metadata pro pozdější rekonstrukci.
  partNumber        Int?
  partsCount        Int?
  messageReferenceNumber Int?

  // Petr v UI označí jako přečtené.
  seenAt            DateTime?

  createdAt         DateTime    @default(now())

  @@index([userId, receivedAt])
  @@index([smsMessageId])
}
