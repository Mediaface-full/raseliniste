---
import Shell from "../../../layouts/Shell.astro";
import GoogleIntegration from "../../../components/GoogleIntegration";
import PostaIntegration from "../../../components/PostaIntegration";
import { prisma } from "../../../lib/db";
import { readSession } from "../../../lib/session";
import { isConnected, POSTA_REQUIRED_SCOPE } from "../../../lib/google-oauth";
import { env } from "../../../lib/env";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: {
    username: true,
    gmailHistoryId: true, gmailSyncedAt: true, gmailSyncError: true,
    gmailBackfillStartedAt: true, gmailBackfillCompletedAt: true,
    gmailBackfillYears: true, gmailBackfillTotalFetched: true, gmailBackfillError: true,
  },
});
if (!user) return Astro.redirect("/login");

const status = await isConnected(session.uid);
// Detekce zda OAuth ma vsechny Posta scopy. Pokud Petr autorizoval Google driv
// (kalendar + kontakty), config.scopes neobsahuje gmail.modify/send a Posta
// nemuze fungovat. Treba reauth.
const grantedScopes = (status.config?.scopes as string[] | undefined) ?? [];
const hasGmailScope = grantedScopes.includes(POSTA_REQUIRED_SCOPE);
const eventsCount = await prisma.calendarEvent.count({
  where: { source: "GOOGLE_PRIMARY", deletedRemotely: false },
});
const contactsCount = await prisma.contact.count({
  where: { userId: session.uid, googleResourceName: { not: null } },
});
const emailsCount = await prisma.emailMessage.count({
  where: { userId: session.uid },
});
const classifiedCount = await prisma.emailClassification.count({
  where: { message: { userId: session.uid } },
});

const justConnected = Astro.url.searchParams.get("just_connected") === "1";
const oauthMisconfigured = !env.GOOGLE_CLIENT_ID || !env.GOOGLE_CLIENT_SECRET;
---

<Shell
  title="Google · Rašeliniště"
  username={user.username}
  breadcrumb={[{ label: "Nastavení" }, { label: "Integrace" }, { label: "Google" }]}
>
  <div class="max-w-2xl space-y-4">
    <GoogleIntegration
      client:load
      initial={{
        connected: status.connected,
        lastUsedAt: status.lastUsedAt?.toISOString() ?? null,
        lastError: status.lastError,
        eventsCount,
        contactsCount,
        justConnected,
        oauthMisconfigured,
        hasGmailScope,
      }}
    />

    {status.connected && (
      <PostaIntegration
        client:load
        initial={{
          emailsCount,
          classifiedCount,
          gmailSyncedAt: user.gmailSyncedAt?.toISOString() ?? null,
          gmailSyncError: user.gmailSyncError,
          hasHistoryId: Boolean(user.gmailHistoryId),
          backfill: {
            started: !!user.gmailBackfillStartedAt,
            completed: !!user.gmailBackfillCompletedAt,
            inProgress: !!user.gmailBackfillStartedAt && !user.gmailBackfillCompletedAt,
            years: user.gmailBackfillYears,
            totalFetched: user.gmailBackfillTotalFetched,
            error: user.gmailBackfillError,
          },
        }}
      />
    )}
  </div>
</Shell>
