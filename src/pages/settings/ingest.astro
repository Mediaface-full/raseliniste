---
import Shell from "../../layouts/Shell.astro";
import IngestSetupGuide from "../../components/IngestSetupGuide";
import HealthFileUpload from "../../components/HealthFileUpload";
import { Icon } from "astro-icon/components";
import { prisma } from "../../lib/db";
import { readSession } from "../../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

const appUrl = Astro.url.origin;
---

<Shell
  title="Napojení Health · Rašeliniště"
  username={user.username}
  breadcrumb={[{ label: "Nastavení" }, { label: "Napojení Health" }]}
>
  <div class="max-w-3xl space-y-5">
    {/* Rychlý import — nahrání jednorázového JSON souboru bez API tokenu */}
    <section class="glass rounded-xl p-5" style="--c: var(--tint-mint);">
      <div class="flex items-center gap-3 mb-3">
        <div class="size-9 rounded-md grid place-items-center shrink-0" style="background: color-mix(in oklch, var(--c) 16%, transparent); color: var(--c);">
          <Icon name="lucide:file-up" class="size-4" />
        </div>
        <div>
          <div class="text-[10px] uppercase tracking-[0.15em] text-muted-foreground font-mono">Rychlý import</div>
          <h3 class="font-serif text-lg leading-tight">Nahrát JSON soubor</h3>
        </div>
      </div>
      <div class="text-sm space-y-3 pl-12">
        <p class="text-muted-foreground">
          Pro jednorázový upload (např. roční historie z HAE „Export to Files"). Bez API tokenu — autentikuje tě tvoje session. Limit <strong>50 MB</strong>. Duplicity se přeskakují.
        </p>
        <HealthFileUpload client:load />
      </div>
    </section>

    <IngestSetupGuide appUrl={appUrl} client:load />
  </div>
</Shell>
