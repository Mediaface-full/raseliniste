---
import Shell from "../../layouts/Shell.astro";
import { Icon } from "astro-icon/components";
import { prisma } from "../../lib/db";
import { readSession } from "../../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

type Tile = {
  href: string;
  title: string;
  description: string;
  icon: string;
  tint: "peach" | "mint" | "lavender" | "sky" | "sage" | "butter" | "rose" | "pink";
};

const groups: { label: string; tiles: Tile[] }[] = [
  {
    label: "Integrace",
    tiles: [
      {
        href: "/settings/page-links",
        title: "Page Links",
        description: "Odkazy v sidebaru — název, barva, URL (otevře v novém okně)",
        icon: "lucide:link",
        tint: "sky",
      },
      {
        href: "/settings/integrations/google",
        title: "Google",
        description: "Kalendář + kontakty (OAuth, sync à 5 min / denně)",
        icon: "lucide:calendar-clock",
        tint: "sky",
      },
      {
        href: "/settings/integrations/icloud",
        title: "iCloud",
        description: "Synův a partnerčin kalendář (CalDAV, read-only)",
        icon: "lucide:cloud",
        tint: "lavender",
      },
      {
        href: "/settings/local-calendars",
        title: "Nahrané kalendáře",
        description: "Upload .ics souborů — jen zobrazení v Rašeliništi, žádný sync",
        icon: "lucide:calendar-plus",
        tint: "sage",
      },
      {
        href: "/settings/integrations",
        title: "Todoist",
        description: "Push úkolů, briefing 22:00, Lidé/sekce routing",
        icon: "lucide:plug",
        tint: "mint",
      },
      {
        href: "/settings/reports",
        title: "E-mail (SMTP)",
        description: "Seznam / Gmail / vlastní SMTP, příjemce reportů",
        icon: "lucide:mail",
        tint: "butter",
      },
      {
        href: "/settings/whatsapp",
        title: "WhatsApp (Twilio)",
        description: "Připomínky výročí a narozenin přímo do WhatsApp",
        icon: "lucide:message-circle",
        tint: "mint",
      },
      {
        href: "/settings/push",
        title: "Push notifikace",
        description: "Přímá push na iPhone/Android (nezávisle na WhatsApp). Vyžaduje PWA na ploše.",
        icon: "lucide:bell",
        tint: "rose",
      },
    ],
  },
  {
    label: "Mobilní zařízení",
    tiles: [
      {
        href: "/settings/shortcuts",
        title: "iPhone Shortcuty",
        description: "Capture + Deník diktát z mobilu (Bearer tokeny)",
        icon: "lucide:smartphone",
        tint: "peach",
      },
      {
        href: "/settings/ingest",
        title: "Health Auto Export",
        description: "Apple Health → Rašeliniště (REST API z iPhone)",
        icon: "lucide:cable",
        tint: "rose",
      },
      {
        href: "/settings/tokens",
        title: "API tokeny",
        description: "Bearer tokeny pro Capture / Journal / Health (revokovatelné)",
        icon: "lucide:key",
        tint: "lavender",
      },
    ],
  },
  {
    label: "Kalendář a rituály",
    tiles: [
      {
        href: "/settings/ritualy",
        title: "Rituály",
        description: "Editovat text 3 default rituálů + přidávat vlastní (každý den / pracovní dny / víkend / vybrané)",
        icon: "lucide:sparkles",
        tint: "peach",
      },
    ],
  },
  {
    label: "Obsah a šablony",
    tiles: [
      {
        href: "/settings/letter-senders",
        title: "Odesílatelé dopisů",
        description: "Hlavičky + podpisy + per-sender AI prompt",
        icon: "lucide:user-square",
        tint: "butter",
      },
    ],
  },
  {
    label: "AI",
    tiles: [
      {
        href: "/settings/ai-prompts",
        title: "AI prompty",
        description: "Edituj instrukce pro Ozvěnu, Studnu, briefing, deníkové review",
        icon: "lucide:sparkles",
        tint: "rose",
      },
      {
        href: "/settings/ai-usage",
        title: "AI náklady",
        description: "Sledování útraty Gemini volání (per modul, model, den)",
        icon: "lucide:coins",
        tint: "sage",
      },
    ],
  },
  {
    label: "Systém",
    tiles: [
      {
        href: "/settings/crons",
        title: "Crony",
        description: "Stav 16 automatických úloh — poslední úspěch, chyby, rozvrhy",
        icon: "lucide:clock",
        tint: "lavender",
      },
      {
        href: "/settings/backup-log",
        title: "Backup log",
        description: "Historie zálohy aplikace (denní pg_dump + uploads) — ok/fail, velikost, trvání",
        icon: "lucide:database-backup",
        tint: "sage",
      },
      {
        href: "/things-import",
        title: "Things import",
        description: "Bulk import úkolů z Things přes srovnaný JSON (migrate/wishlist/discard)",
        icon: "lucide:file-input",
        tint: "sky",
      },
      {
        href: "/settings/diagnose",
        title: "Diagnostika AI",
        description: "Stav AI procesů — Myší, Studánka, Health, Souhrny. Stuck joby, errory, migrace.",
        icon: "lucide:activity",
        tint: "rose",
      },
    ],
  },
];
---

<Shell
  title="Nastavení · Rašeliniště"
  username={user.username}
  heading="Nastavení"
  breadcrumb={[{ label: "Nastavení" }]}
>
  <div class="max-w-4xl space-y-8">
    {groups.map((group) => (
      <section>
        <h2 class="text-2xl font-semibold tracking-tight text-foreground mb-4 pb-2 border-b border-white/10">
          {group.label}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {group.tiles.map((tile) => (
            <a
              href={tile.href}
              class="glass rounded-xl p-4 hover:bg-white/5 transition-colors block group relative overflow-hidden"
              style={`--c: var(--tint-${tile.tint});`}
            >
              <div
                class="absolute -top-10 -right-10 size-24 rounded-full blur-2xl pointer-events-none"
                style="background: color-mix(in oklch, var(--c) 25%, transparent);"
              ></div>

              <div class="relative">
                <div
                  class="size-10 rounded-lg grid place-items-center mb-3"
                  style="background: color-mix(in oklch, var(--c) 18%, transparent); color: var(--c);"
                >
                  <Icon name={tile.icon} class="size-5" />
                </div>
                <div class="text-base font-semibold tracking-tight">{tile.title}</div>
                <div class="text-xs text-muted-foreground mt-1 leading-relaxed">
                  {tile.description}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</Shell>
