---
import Base from "../layouts/Base.astro";
import { Icon } from "astro-icon/components";
import { prisma } from "../lib/db";
import { readSession } from "../lib/session";
import { svatekDne } from "../lib/jmenny-kalendar";
import SchedulerStatus from "../components/SchedulerStatus.astro";
import bwMysSvg from "../assets/icons/bw-mys.svg?raw";
import miseRaketaSvg from "../assets/icons/mise-raketa.svg?raw";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

// User + kontakty s narozeninami + výročí paralelně (3× round-trip → 1)
const [user, contactsWithBirthday, anniversaries] = await Promise.all([
  prisma.user.findUnique({
    where: { id: session.uid },
    select: { username: true },
  }),
  prisma.contact.findMany({
    where: {
      userId: session.uid,
      birthMonth: { not: null },
      birthDay: { not: null },
    },
    select: { displayName: true, firstName: true, birthMonth: true, birthDay: true },
  }),
  prisma.anniversary.findMany({
    where: { userId: session.uid },
    select: { id: true, title: true, month: true, day: true, year: true },
  }),
]);
if (!user) return Astro.redirect("/login");

type Tile = {
  href: string;
  title: string;
  icon: string;
  tint: "peach" | "mint" | "lavender" | "sky" | "sage" | "butter" | "rose" | "pink";
  disabled?: boolean;
  badge?: string;
};

const tiles: Tile[] = [
  { href: "/dnes",                title: "Mise",      icon: "custom:mise-raketa",            tint: "sky" },
  { href: "/ozvena?mode=journal", title: "Deník",     icon: "lucide:book-open",              tint: "butter" },
  { href: "/ozvena?mode=task",    title: "Úkoly",     icon: "lucide:check-square",           tint: "peach" },
  { href: "/studna/nahravka",     title: "Studánka",  icon: "lucide:waves",                  tint: "mint" },
  { href: "/prskavka/nahravka",   title: "Prskavka",  icon: "lucide:sparkles",               tint: "rose" },
  { href: "/zeptat-se",           title: "Zeptat se", icon: "lucide:message-circle-question", tint: "lavender" },
  { href: "/zijes/novy",          title: "ŽIJEŠ?",    icon: "lucide:heart-pulse",            tint: "pink" },
  { href: "/bwmys",               title: "Myši",      icon: "custom:bw-mys",                 tint: "sage" },
];

const today = new Date();
const todayStr = today.toLocaleDateString("cs-CZ", { weekday: "long", day: "numeric", month: "long" });
const svatek = svatekDne(today);

// Spočti "kolik dní do narozenin" pro každého kontaktu (data už načtená výše paralelně)
function daysUntil(month: number, day: number): number {
  const t = new Date(today.getFullYear(), today.getMonth(), today.getDate());
  let target = new Date(today.getFullYear(), month - 1, day);
  if (target < t) target = new Date(today.getFullYear() + 1, month - 1, day);
  return Math.round((target.getTime() - t.getTime()) / 86_400_000);
}

const birthdaysSoon = contactsWithBirthday
  .map((c) => ({
    name: c.firstName?.trim() || c.displayName,
    month: c.birthMonth!,
    day: c.birthDay!,
    days: daysUntil(c.birthMonth!, c.birthDay!),
  }))
  .filter((b) => b.days <= 7)
  .sort((a, b) => a.days - b.days);

const birthdayToday = birthdaysSoon.filter((b) => b.days === 0);
const birthdayUpcoming = birthdaysSoon.filter((b) => b.days > 0 && b.days <= 7);

// Výročí — formát "N. Výročí svatby (3.5.)" pokud rok zadaný, jinak "Výročí svatby (3.5.)"
const currentYear = today.getFullYear();
const anniversariesSoon = anniversaries
  .map((a) => {
    const days = daysUntil(a.month, a.day);
    const yearsCount = a.year ? currentYear - a.year : null;
    const label = yearsCount && yearsCount > 0 ? `${yearsCount}. ${a.title}` : a.title;
    return { id: a.id, label, month: a.month, day: a.day, days };
  })
  .filter((a) => a.days <= 14)
  .sort((a, b) => a.days - b.days);

const anniversariesToday = anniversariesSoon.filter((a) => a.days === 0);
const anniversariesUpcoming = anniversariesSoon.filter((a) => a.days > 0 && a.days <= 14);
---

<Base
  title="Rašeliniště"
  appleTitle="Rašeliniště"
  appleCapable={true}
  manifestPath="/manifest-start.json"
  appleIconPath="/tree-touch-icon.png"
>
  <main class="min-h-screen flex flex-col">
    <!-- Topbar -->
    <div class="border-b border-white/5 px-4 py-3 flex items-center gap-3">
      <a href="/" class="text-xs font-mono text-muted-foreground hover:text-foreground">← Dashboard</a>
      <span class="text-xs font-mono text-muted-foreground">{user.username}</span>
      <a href="/settings" class="ml-auto text-xs font-mono text-muted-foreground hover:text-foreground" aria-label="Nastavení">
        <Icon name="lucide:settings" class="size-4" />
      </a>
    </div>

    <!-- Content — zarovnáno nahoru, ne na střed (nemusí se scrollovat) -->
    <div class="flex-1 px-4 sm:px-6 pt-6 pb-8">
      <div class="w-full max-w-lg mx-auto space-y-5">

        {/* VÝRAZNÝ banner — dnešní výročí (Petr explicitně chtěl výrazné, ne jemné) */}
        {anniversariesToday.length > 0 && (
          <div class="rounded-2xl p-4 border-2 border-[var(--tint-rose)]/50 bg-[var(--tint-rose)]/15 text-center space-y-1">
            <div class="text-[10px] uppercase tracking-[0.22em] font-mono text-[var(--tint-rose)]">
              Dnes
            </div>
            {anniversariesToday.map((a) => (
              <div class="text-lg font-serif">
                🕯 {a.label}
              </div>
            ))}
          </div>
        )}

        <header class="text-center space-y-2">
          {/* Svátek + narozeniny — info pruh nad datem */}
          <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-xs">
            {svatek && (
              <span class="text-muted-foreground">
                Svátek má <strong class="text-foreground">{svatek}</strong>
              </span>
            )}
            {birthdayToday.length > 0 && (
              <span class="text-[var(--tint-rose)]">
                🎂 <strong>{birthdayToday.map((b) => b.name).join(", ")}</strong>
                {" má dnes narozeniny"}
              </span>
            )}
          </div>

          <div class="text-xs uppercase tracking-widest font-mono text-muted-foreground">
            {todayStr}
          </div>
          <h1 class="text-3xl tracking-tight">Co teď?</h1>

          {(birthdayUpcoming.length > 0 || anniversariesUpcoming.length > 0) && (
            <div class="text-xs text-foreground/80 space-y-0.5 pt-1">
              {anniversariesUpcoming.length > 0 && (
                <div>
                  <span class="text-[var(--tint-rose)]">🕯 Nadchází:</span>{" "}
                  {anniversariesUpcoming.map((a) => `${a.label} (${a.day}.${a.month}., za ${a.days} ${a.days === 1 ? "den" : a.days < 5 ? "dny" : "dní"})`).join(" · ")}
                </div>
              )}
              {birthdayUpcoming.length > 0 && (
                <div>
                  <span class="text-muted-foreground">🎂 Tento týden:</span>{" "}
                  {birthdayUpcoming.map((b) => `${b.name} (${b.day}.${b.month}.)`).join(" · ")}
                </div>
              )}
            </div>
          )}
        </header>

        <div class="grid grid-cols-2 gap-3">
          {tiles.map((tile) => {
            const Tag = tile.disabled ? "div" : "a";
            return (
              <Tag
                href={tile.disabled ? undefined : tile.href}
                class={`glass rounded-2xl p-4 relative overflow-hidden flex flex-col items-start gap-2 min-h-[96px] transition ${
                  tile.disabled
                    ? "opacity-50 cursor-not-allowed"
                    : "hover:bg-white/5 active:scale-[0.98]"
                }`}
                style={`--c: var(--tint-${tile.tint});`}
              >
                <div
                  class="absolute -top-12 -right-12 size-32 rounded-full blur-2xl pointer-events-none"
                  style="background: color-mix(in oklch, var(--c) 28%, transparent);"
                ></div>

                <div
                  class="size-10 rounded-xl grid place-items-center [&>svg]:size-5"
                  style="background: color-mix(in oklch, var(--c) 22%, transparent); color: var(--c);"
                >
                  {tile.icon === "custom:bw-mys" ? (
                    <Fragment set:html={bwMysSvg} />
                  ) : tile.icon === "custom:mise-raketa" ? (
                    <Fragment set:html={miseRaketaSvg} />
                  ) : (
                    <Icon name={tile.icon} class="size-5" />
                  )}
                </div>

                <div class="relative mt-auto text-base font-semibold tracking-tight flex items-center gap-2">
                  {tile.title}
                  {tile.badge && (
                    <span class="text-[10px] uppercase font-mono px-1.5 py-0.5 rounded bg-white/10 text-muted-foreground">
                      {tile.badge}
                    </span>
                  )}
                </div>
              </Tag>
            );
          })}
        </div>

        <!-- Plnošířkové tlačítko Dashboard — proklik do hlavního systému -->
        <a
          href="/"
          class="glass rounded-2xl px-5 py-4 flex items-center justify-center gap-3 hover:bg-white/5 active:scale-[0.99] transition"
        >
          <Icon name="lucide:layout-dashboard" class="size-5 text-[var(--tint-sky)]" />
          <span class="text-base font-semibold tracking-tight">Dashboard</span>
          <Icon name="lucide:arrow-right" class="size-4 text-muted-foreground" />
        </a>

        <SchedulerStatus variant="compact" />

        <div class="text-center text-xs font-mono text-muted-foreground/60">
          Tip: <strong>Sdílet → Přidat na plochu</strong> = ikona Rašeliniště
        </div>
      </div>
    </div>
  </main>
</Base>
