---
// Vždy redirectne na /day/<dnešní datum> v Europe/Prague.
// Důvod: když si Petr přidá tuhle stránku na plochu mobilu jako PWA,
// chceme aby se po otevření vždy zobrazil aktuální den, ne datum,
// kdy se ikona vytvořila.
const today = new Date().toLocaleDateString("sv-SE", { timeZone: "Europe/Prague" });
// Zachovej ?naplno=1 (pokud je v URL) — fullscreen ritual mode
const qs = Astro.url.searchParams.get("naplno") === "1" ? "?naplno=1" : "";
return Astro.redirect(`/day/${today}${qs}`, 302);
---
