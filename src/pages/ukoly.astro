---
import Shell from "../layouts/Shell.astro";
import UkolyList from "../components/UkolyList";
import { Icon } from "astro-icon/components";
import { prisma } from "../lib/db";
import { readSession } from "../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

const todoistConfigured = Boolean(
  await prisma.userIntegration.findUnique({
    where: { userId_provider: { userId: session.uid, provider: "todoist" } },
    select: { id: true },
  }),
);

// Audio batche čekající na review nebo zpracovávané AI (last 48h).
// Petr nahraje na mobilu → AI běží na pozadí → tady to najde a otevře Triage.
const pendingBatches = await prisma.taskAudioBatch.findMany({
  where: {
    userId: session.uid,
    status: { in: ["processing", "review", "error"] },
    createdAt: { gte: new Date(Date.now() - 48 * 60 * 60 * 1000) },
  },
  orderBy: { createdAt: "desc" },
  select: {
    id: true,
    status: true,
    audioDurationSec: true,
    createdAt: true,
    processingError: true,
    proposalsJson: true,
  },
  take: 10,
});

function fmtTime(d: Date) {
  return new Intl.DateTimeFormat("cs-CZ", { dateStyle: "short", timeStyle: "short" }).format(d);
}
function fmtDuration(sec: number | null) {
  if (!sec) return null;
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return m > 0 ? `${m} min ${s} s` : `${s} s`;
}
---

<Shell
  title="Úkoly · Rašeliniště"
  username={user.username}
  heading="Úkoly"
  breadcrumb={[{ label: "Organizace" }, { label: "Úkoly" }]}
>
  <!-- Petr 2026-05-25: max-w-3xl → max-w-6xl. Sidebar lze sbalit šipkou
       v levém panelu (Shell má desktop collapse přes data-sidebar-collapsed). -->
  <div class="max-w-6xl space-y-4">
    {pendingBatches.length > 0 && (
      <details class="rounded-xl border border-border bg-card group" open={pendingBatches.length <= 2}>
        <summary class="flex items-center gap-2 p-4 cursor-pointer list-none">
          <Icon name="lucide:inbox" class="size-4 text-muted-foreground" />
          <h2 class="text-base font-bold tracking-[-0.02em]">Audio salvy čekají na review</h2>
          <span class="text-[10px] uppercase tracking-widest font-mono text-muted-foreground">
            {pendingBatches.length}
          </span>
          <Icon name="lucide:chevron-down" class="size-4 ml-auto text-muted-foreground group-open:rotate-180 transition-transform" />
        </summary>
        <ul class="space-y-1.5 px-4 pb-4">
          {pendingBatches.map((b) => {
            const proposals = Array.isArray(b.proposalsJson) ? b.proposalsJson.length : 0;
            const isReady = b.status === "review";
            const isProcessing = b.status === "processing";
            const isError = b.status === "error";
            return (
              <li class="flex items-center gap-1">
                <a
                  href={`/ukoly/audio/${b.id}/review`}
                  class="flex-1 flex items-center gap-3 px-3 py-2 rounded-md hover:bg-accent/40 transition-colors border border-border"
                >
                  <span class={`size-8 rounded-md grid place-items-center shrink-0 border ${
                    isError ? "border-destructive/30 bg-destructive/10" : "border-border bg-accent/30"
                  }`}>
                    {isReady && <Icon name="lucide:check-circle-2" class="size-4 text-muted-foreground" />}
                    {isProcessing && <Icon name="lucide:loader-2" class="size-4 animate-spin text-muted-foreground" />}
                    {isError && <Icon name="lucide:alert-triangle" class="size-4 text-destructive" />}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm">
                      {isReady && `${proposals} úkolů k potvrzení`}
                      {isProcessing && "AI zpracovává…"}
                      {isError && "Chyba zpracování"}
                    </div>
                    <div class="text-[11px] text-muted-foreground font-mono">
                      {fmtTime(b.createdAt)}
                      {b.audioDurationSec ? ` · ${fmtDuration(b.audioDurationSec)}` : ""}
                    </div>
                    {isError && b.processingError && (
                      <div class="text-[11px] text-destructive/80 mt-0.5 line-clamp-2">{b.processingError}</div>
                    )}
                  </div>
                  <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground shrink-0" />
                </a>
                <button
                  data-batch-discard
                  data-batch-id={b.id}
                  type="button"
                  class="p-2 rounded-md hover:bg-destructive/15 text-muted-foreground hover:text-destructive transition shrink-0"
                  title="Skrýt tuto audio salvu (úkoly už jsem zařadil / nepotřebuji)"
                  aria-label="Skrýt batch"
                >
                  <Icon name="lucide:x" class="size-4" />
                </button>
              </li>
            );
          })}
        </ul>
      </details>
    )}

    <UkolyList client:load todoistConfigured={todoistConfigured} />
  </div>
</Shell>

<script>
  // Petr 2026-06-19: skrýt zaseknuté Audio salvy ve stavu review/error
  // pokud Gideon úkoly z nich už zařadil ručně. Klik na ✕ → POST discard
  // (status = discarded) → query filtru `status in [processing, review,
  // error]` je vyřadí.
  document.querySelectorAll<HTMLButtonElement>('button[data-batch-discard]').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = btn.dataset.batchId;
      if (!id) return;
      if (!confirm('Skrýt tuhle audio salvu?\n\nÚkoly co jsou v Todoist/Rašeliništi zůstanou. Přepis a hlavička batch zmizí ze seznamu.')) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/api/ukoly/audio/${id}/discard`, { method: 'POST' });
        if (res.ok) {
          btn.closest('li')?.remove();
        } else {
          alert('Skrytí selhalo. Zkus refresh + znovu.');
          btn.disabled = false;
        }
      } catch (err) {
        alert('Síťová chyba: ' + (err instanceof Error ? err.message : String(err)));
        btn.disabled = false;
      }
    });
  });
</script>
