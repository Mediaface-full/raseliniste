---
import Shell from "../layouts/Shell.astro";
import { Icon } from "astro-icon/components";
import { prisma } from "../lib/db";
import { readSession } from "../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

// Petr 2026-06-19 (verze 4): minimální možný fetch + render. Defenzivní
// try/catch zachytí jakoukoli chybu z Prisma a ukáže ji přímo na stránce.
// Pokud Astro SSR padá někde mezi `<Shell>` a daty, výpis tady to ukáže.
type LinkRow = {
  id: string;
  name: string;
  url: string;
  tint: string;
  icon: string | null;
  order: number;
};

let links: LinkRow[] = [];
let fetchError: string | null = null;
try {
  const rows = await prisma.pageLink.findMany({
    where: { userId: session.uid },
    orderBy: [{ order: "asc" }, { createdAt: "asc" }],
    select: { id: true, name: true, url: true, tint: true, icon: true, order: true },
  });
  links = rows.map((r) => ({
    id: r.id,
    name: r.name ?? "(bez názvu)",
    url: r.url ?? "#",
    tint: r.tint ?? "sky",
    icon: r.icon,
    order: r.order,
  }));
} catch (e) {
  fetchError = e instanceof Error ? e.message : String(e);
}

function prettyDomain(url: string): string {
  try {
    const u = new URL(url);
    return u.hostname.replace(/^www\./, "");
  } catch {
    return url.slice(0, 40);
  }
}

const VALID_LUCIDE = /^[a-z][a-z0-9-]*$/;
function safeIcon(icon: string | null): string {
  if (!icon || !icon.trim()) return "lucide:globe";
  const t = icon.trim();
  return VALID_LUCIDE.test(t) ? `lucide:${t}` : "lucide:globe";
}
---

<Shell
  title="Page Links · Rašeliniště"
  username={user.username}
  heading="Page Links · v4 build"
  breadcrumb={[{ label: "Přehled" }, { label: "Page Links" }]}
>
  <div class="max-w-5xl space-y-4">
    <!-- Petr 2026-06-19: marker že tento konkrétní commit je deploynutý.
         Pokud Gideon NEVIDÍ box níže, kód neběží na produkci → problem
         je deploy (GH Actions selhal, DSM nedělal Recreate, Chrome cachuje). -->
    <div class="rounded-lg border-2 border-foreground bg-card p-3 text-xs font-mono">
      ✅ <strong>links.astro v4</strong> — debug build z 2026-06-19, defensive rewrite (commit 28e06d0+).
      Pokud tohle vidíš ALE žádné dlaždice/error/empty state, problém je v Astro SSR mezi tímto markerem a renderem dat dole.
      <br />
      <span class="text-muted-foreground">DB fetch returned <strong>{links.length}</strong> links · fetchError = <strong>{fetchError ? "YES" : "no"}</strong></span>
    </div>

    {fetchError && (
      <div class="rounded-xl border-2 border-destructive p-4 bg-destructive/10 text-destructive font-mono text-sm">
        <strong>Chyba načtení odkazů z DB:</strong>
        <pre class="mt-2 text-xs whitespace-pre-wrap">{fetchError}</pre>
      </div>
    )}

    {!fetchError && links.length === 0 && (
      <div class="rounded-2xl border border-border bg-card p-8 text-center space-y-3">
        <Icon name="lucide:link" class="size-12 mx-auto text-muted-foreground" />
        <h2 class="text-lg font-bold tracking-[-0.02em]">Zatím žádné odkazy</h2>
        <p class="text-sm text-muted-foreground">
          Přidejte si odkazy na často navštěvované weby, otevřou se v novém okně.
        </p>
        <a
          href="/settings/page-links"
          class="inline-flex items-center gap-1.5 mt-2 px-4 py-2 rounded-md bg-foreground text-background text-sm font-medium hover:opacity-90"
        >
          + Přidat první odkaz
        </a>
      </div>
    )}

    {!fetchError && links.length > 0 && (
      <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 list-none p-0 m-0">
        {links.map((link) => (
          <li class="m-0 p-0">
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer external"
              data-external-link
              class="block rounded-2xl p-4 border border-border bg-card hover:border-foreground/40 hover:bg-accent/40 transition min-h-[96px] no-underline"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="size-9 rounded-lg grid place-items-center border border-border text-muted-foreground shrink-0">
                  <Icon name={safeIcon(link.icon)} class="size-5" />
                </span>
              </div>
              <div class="text-base font-semibold tracking-tight text-foreground">{link.name}</div>
              <div class="text-[10px] font-mono text-muted-foreground/70 truncate">
                {prettyDomain(link.url)}
              </div>
            </a>
          </li>
        ))}
        <li class="m-0 p-0">
          <a
            href="/settings/page-links"
            class="block rounded-2xl p-4 border border-dashed border-border hover:border-foreground/40 hover:bg-accent/40 transition min-h-[96px] no-underline"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="size-9 rounded-lg grid place-items-center border border-border text-muted-foreground shrink-0">
                <Icon name="lucide:settings" class="size-5" />
              </span>
            </div>
            <div class="text-base font-semibold tracking-tight text-foreground">Upravit odkazy</div>
            <div class="text-[10px] font-mono text-muted-foreground/70">přidat · přejmenovat · smazat</div>
          </a>
        </li>
      </ul>
    )}
  </div>
</Shell>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[data-external-link]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      window.open(a.href, '_blank', 'noopener,noreferrer');
    });
  });
</script>
