---
import Shell from "../layouts/Shell.astro";
import { Icon } from "astro-icon/components";
import { prisma } from "../lib/db";
import { readSession } from "../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

const links = await prisma.pageLink.findMany({
  where: { userId: session.uid },
  orderBy: [{ order: "asc" }, { createdAt: "asc" }],
});

// Petr 2026-05-27: pretty domain pro malý subtitle pod názvem
function prettyDomain(url: string): string {
  try {
    const u = new URL(url);
    return u.hostname.replace(/^www\./, "");
  } catch {
    return url.slice(0, 40);
  }
}

// Petr 2026-05-27: validace lucide icon name. Pokud Petr zadal něco co
// není v lucide-icons (např. „Immich", „PhotoPrism" = brand names), fallback
// na generic „globe". Bez tohoto guardu Astro při buildu/SSR padl protože
// `lucide:Immich` neexistuje → stránka prázdná.
//
// Heuristika: lucide names jsou kebab-case lowercase. Pokud icon obsahuje
// velké písmeno (capital), je to brand jméno → fallback. Jinak věřit.
function safeIconName(icon: string | null): string {
  if (!icon || !icon.trim()) return "lucide:globe";
  const trimmed = icon.trim();
  // Brand jména (Immich/Video/PhotoPrism) mají capital nebo nejsou kebab-case
  if (/[A-Z]/.test(trimmed) || !/^[a-z][a-z0-9-]*$/.test(trimmed)) {
    return "lucide:globe";
  }
  return `lucide:${trimmed}`;
}
---

<Shell
  title="Page Links · Rašeliniště"
  username={user.username}
  heading="Page Links"
  breadcrumb={[{ label: "Přehled" }, { label: "Page Links" }]}
>
  <div class="max-w-5xl space-y-4">
    {links.length === 0 ? (
      <div class="glass rounded-2xl p-8 text-center space-y-3">
        <Icon name="lucide:link" class="size-12 mx-auto text-muted-foreground" />
        <h2 class="text-lg font-bold tracking-[-0.02em]">Zatím žádné odkazy</h2>
        <p class="text-sm text-muted-foreground">
          Přidej si odkazy na často navštěvované weby, otevřou se v novém okně.
        </p>
        <a
          href="/settings/page-links"
          class="inline-flex items-center gap-1.5 mt-2 px-4 py-2 rounded-md bg-foreground text-background text-sm font-medium hover:opacity-90 transition"
        >
          <Icon name="lucide:plus" class="size-4" /> Přidat první odkaz
        </a>
      </div>
    ) : (
      <>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          {links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer external"
              data-external-link
              class="glass rounded-2xl p-4 relative overflow-hidden flex flex-col items-start gap-2 min-h-[96px] transition hover:bg-white/5 active:scale-[0.98]"
              style={`--c: var(--tint-${link.tint});`}
            >
              <div
                class="absolute -top-12 -right-12 size-32 rounded-full blur-2xl pointer-events-none"
                style="background: color-mix(in oklch, var(--c) 28%, transparent);"
              ></div>
              <div
                class="size-10 rounded-xl grid place-items-center"
                style="background: color-mix(in oklch, var(--c) 22%, transparent); color: var(--c);"
              >
                <Icon name={safeIconName(link.icon)} class="size-5" />
              </div>
              <div class="relative mt-auto">
                <div class="text-base font-semibold tracking-tight">{link.name}</div>
                <div class="text-[10px] font-mono text-muted-foreground/70 truncate">
                  {prettyDomain(link.url)}
                </div>
              </div>
            </a>
          ))}

          <a
            href="/settings/page-links"
            class="rounded-2xl p-4 flex flex-col items-start gap-2 min-h-[96px] border border-dashed border-border hover:border-foreground/40 hover:bg-accent/40 transition"
          >
            <div class="size-10 rounded-xl grid place-items-center border border-border text-muted-foreground">
              <Icon name="lucide:settings" class="size-5" />
            </div>
            <div class="mt-auto">
              <div class="text-base font-semibold tracking-tight">Upravit odkazy</div>
              <div class="text-[10px] font-mono text-muted-foreground/70">
                přidat · přejmenovat · smazat
              </div>
            </div>
          </a>
        </div>
      </>
    )}
  </div>
</Shell>

<script>
  // Force external links to open in browser window (not PWA scope).
  // Chrome PWA / iOS PWA default behavior pro target="_blank" je otevřít
  // link v in-app browser uvnitř PWA okna. window.open() s noopener
  // přesměruje na hlavní browser okno (Chrome tab / Safari).
  document.querySelectorAll<HTMLAnchorElement>('a[data-external-link]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      window.open(a.href, '_blank', 'noopener,noreferrer');
    });
  });
</script>
