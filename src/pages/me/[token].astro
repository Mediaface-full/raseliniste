---
import Base from "../../layouts/Base.astro";
import GuestRecorder from "../../components/GuestRecorder";
import GuestGuide from "../../components/GuestGuide";
import GuestRecordings from "../../components/GuestRecordings";
import GideonWordmark from "../../components/GideonWordmark";
import SwUpdateBanner from "../../components/SwUpdateBanner";
import { prisma } from "../../lib/db";

const token = Astro.params.token;
let guest: { name: string; email: string } | null = null;
let projects: Array<{
  id: string;
  name: string;
  homeTitle: string | null;
  description: string | null;
  canRecordBrief: boolean;
  canUploadAudio: boolean;
}> = [];
let recentRecordings: Array<{
  id: string;
  projectName: string;
  type: "STANDARD" | "BRIEF" | "UPLOAD";
  status: string;
  durationSec: number | null;
  transcript: string;
  createdAt: string;
  uploadedFilename: string | null;
}> = [];
let recentDocs: Array<{
  id: string;
  projectName: string;
  originalName: string;
  mime: string;
  bytes: number;
  extractionStatus: string | null;
  uploadedAt: string;
}> = [];
let canUploadAudioAny = false;

if (token) {
  const g = await prisma.guestUser.findUnique({
    where: { guestToken: token },
    include: {
      invitations: {
        where: { project: { archivedAt: null } },
        include: {
          project: { select: { id: true, name: true, homeTitle: true, description: true } },
        },
      },
    },
  });
  if (g) {
    guest = { name: g.name, email: g.email };
    projects = g.invitations.map((inv) => ({
      id: inv.project.id,
      name: inv.project.name,
      homeTitle: inv.project.homeTitle,
      description: inv.project.description,
      canRecordBrief: inv.canRecordBrief,
      canUploadAudio: inv.canUploadAudio,
    }));
    canUploadAudioAny = projects.some((p) => p.canUploadAudio);

    // Posledních 5 vlastních nahrávek hosta napříč všemi jeho projekty.
    // Petr chce ať host vidí kde skončil — tedy plný transkript, ne AI analýzu.
    // Pokud host nemá v žádném projektu canUploadAudio, UPLOAD typy filtrujeme.
    const projectsWithUpload = new Set(projects.filter((p) => p.canUploadAudio).map((p) => p.id));
    const recs = await prisma.projectRecording.findMany({
      where: { guestUserId: g.id },
      orderBy: { createdAt: "desc" },
      take: 20,
      select: {
        id: true,
        type: true,
        status: true,
        audioDurationSec: true,
        transcript: true,
        createdAt: true,
        uploadedFilename: true,
        projectId: true,
        project: { select: { name: true } },
      },
    });
    const filtered = recs.filter((r) =>
      r.type !== "UPLOAD" || projectsWithUpload.has(r.projectId),
    ).slice(0, 5);
    recentRecordings = filtered.map((r) => ({
      id: r.id,
      projectName: r.project.name,
      type: r.type,
      status: r.status,
      durationSec: r.audioDurationSec,
      transcript: r.transcript,
      createdAt: r.createdAt.toISOString(),
      uploadedFilename: r.uploadedFilename,
    }));

    // Petr 2026-06-19: dokumenty co host nahrál — kontext pro něj samého
    // (transparentnost: ví že soubor byl přijat + status extrakce).
    const docs = await prisma.projectFile.findMany({
      where: { guestUserId: g.id },
      orderBy: { uploadedAt: "desc" },
      take: 5,
      select: {
        id: true, originalName: true, mime: true, bytes: true,
        extractionStatus: true, uploadedAt: true,
        project: { select: { name: true } },
      },
    });
    recentDocs = docs.map((d) => ({
      id: d.id,
      projectName: d.project.name,
      originalName: d.originalName,
      mime: d.mime,
      bytes: d.bytes,
      extractionStatus: d.extractionStatus,
      uploadedAt: d.uploadedAt.toISOString(),
    }));

    // Touch lastSeenAt asynchronně (fire-and-forget)
    prisma.guestUser.update({
      where: { id: g.id },
      data: { lastSeenAt: new Date() },
    }).catch(() => null);
  }
}

// Apple home title — pokud má 1 projekt, použij jeho homeTitle/name (max 12 char celkem),
// jinak generický "Studánka".
let appleTitle = "Studánka";
if (projects.length === 1) {
  const p = projects[0];
  appleTitle = p.homeTitle ? `G: ${p.homeTitle}` : `G: ${p.name.slice(0, 9)}`;
}

// Guide variant — pokud guest má aspoň jednu invitation s canRecordBrief,
// dostane brief variantu (zahrnuje i standard info). Jinak standard.
const guideVariant: "standard" | "brief" =
  projects.some((p) => p.canRecordBrief) ? "brief" : "standard";
---

<Base
  title={guest ? `Studánka · ${guest.name}` : "Studánka"}
  appleTitle={appleTitle}
  appleCapable={true}
>
  <div class="min-h-screen px-4 pt-8 sm:pt-14 pb-10 relative z-10">
    <div class="w-full max-w-md mx-auto">
      {!guest ? (
        <div class="glass-strong rounded-xl p-8 text-center">
          <div class="mb-4 flex justify-center">
            <GideonWordmark size="sm" />
          </div>
          <h1 class="text-2xl font-bold tracking-[-0.03em] leading-tight mb-3">Odkaz nefunguje</h1>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Tenhle odkaz neexistuje nebo byl zrušen. Zkontaktuj prosím Gideona,
            aby ti poslal nový.
          </p>
        </div>
      ) : (
        <>
          <div class="mb-6 text-center relative">
            <div class="absolute right-0 top-0">
              <GuestGuide client:load variant={guideVariant} guestName={guest.name} />
            </div>
            <div class="mb-3 flex justify-center">
              <GideonWordmark size="sm" />
            </div>
            <h1 class="text-4xl font-bold tracking-[-0.04em] leading-tight">Studánka</h1>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
              Nahrávárna pro projekty, do kterých tě Gideon pozval.
            </p>
            <div class="text-[11px] uppercase tracking-[0.22em] text-muted-foreground font-mono mt-3">
              Připojen jako {guest.name}
            </div>
          </div>

          <GuestRecorder
            client:load
            token={token!}
            initialProjects={projects}
            guestName={guest.name}
          />

          {recentRecordings.length > 0 && (
            <GuestRecordings client:load recordings={recentRecordings} hideErrors={true} />
          )}

          {recentDocs.length > 0 && (
            <div class="mt-6 space-y-2">
              <div class="text-[11px] uppercase tracking-[0.22em] text-muted-foreground font-mono">
                ↳ Tvé poslední dokumenty
              </div>
              <div class="space-y-1.5">
                {recentDocs.map((d) => (
                  <div class="glass rounded-lg p-3 flex items-center gap-3">
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-medium truncate">{d.originalName}</div>
                      <div class="text-[11px] text-muted-foreground font-mono">
                        {d.projectName} · {(d.bytes / 1024).toFixed(0)} kB ·{" "}
                        {new Date(d.uploadedAt).toLocaleString("cs-CZ", {
                          day: "numeric", month: "numeric",
                          hour: "2-digit", minute: "2-digit",
                        })}
                      </div>
                    </div>
                    {d.extractionStatus === "pending" && (
                      <span class="text-[10px] font-mono uppercase tracking-wider text-muted-foreground">
                        Zpracovávám…
                      </span>
                    )}
                    {d.extractionStatus === "ok" && (
                      <span class="text-[10px] font-mono uppercase tracking-wider text-[color:var(--c-signal)]">
                        ✓ Přijato
                      </span>
                    )}
                    {d.extractionStatus === "error" && (
                      <span class="text-[10px] font-mono uppercase tracking-wider text-destructive">
                        Selhalo
                      </span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          <p class="mt-6 text-center text-[11px] text-muted-foreground font-mono tracking-wider">
            Tip: přidej tuhle stránku na plochu (Sdílet → Přidat na plochu).
          </p>
        </>
      )}
    </div>
  </div>
  <SwUpdateBanner client:load />
</Base>
