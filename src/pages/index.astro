---
import Shell from "../layouts/Shell.astro";
import { prisma } from "../lib/db";
import { readSession } from "../lib/session";
import { Icon } from "astro-icon/components";
import SchedulerStatus from "../components/SchedulerStatus.astro";
import QuickRecordButton from "../components/QuickRecordButton";
import { loadNotifications } from "../lib/notifications";
import { getForecast3Days } from "../lib/weather";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true, lastLoginAt: true, createdAt: true, passkeys: { select: { id: true } } },
});
if (!user) return Astro.redirect("/login");

const fmt = (d: Date | null | undefined) =>
  d ? new Date(d).toLocaleString("cs-CZ") : "—";

type Tint = "peach" | "mint" | "lavender" | "sky" | "sage" | "butter" | "rose" | "pink";

const unseenFirewall = await prisma.callLog.count({
  where: { userId: session.uid, seenAt: null },
});

// Petr 2026-05-19: KPI Otevřené úkoly byla od začátku projektu hardcoded "—".
// 1502 open tasks v DB — pojďme to konečně ukázat. Plus due-today counter
// jako delta (kolik z toho má dnešní termín).
const todayStart = new Date(); todayStart.setHours(0, 0, 0, 0);
const todayEnd = new Date(todayStart); todayEnd.setDate(todayEnd.getDate() + 1);
const [openTasksCount, dueTodayCount] = await Promise.all([
  prisma.task.count({ where: { userId: session.uid, status: "open" } }),
  prisma.task.count({
    where: { userId: session.uid, status: "open", dueAt: { gte: todayStart, lt: todayEnd } },
  }),
]);

// Plán — eventy které se konají TEĎ nebo v nejbližších 2 dnech.
// Klíč: `endsAt > teď` (ne `>= dayStart`), aby se nezobrazily eventy
// co dnes brzo ráno už skončily.
const now = new Date();
const dayStart = new Date();
dayStart.setHours(0, 0, 0, 0);
const dayPlus2End = new Date(dayStart);
dayPlus2End.setDate(dayPlus2End.getDate() + 2);
dayPlus2End.setHours(23, 59, 59, 999);

const upcomingEventsRaw = await prisma.calendarEvent.findMany({
  where: {
    deletedRemotely: false,
    AND: [
      { endsAt: { gte: now } },           // ještě neskončily
      { startsAt: { lte: dayPlus2End } }, // už začaly nebo začnou v okně
    ],
  },
  select: {
    id: true, title: true, type: true, source: true,
    startsAt: true, endsAt: true, locationText: true, allDay: true,
  },
  orderBy: { startsAt: "asc" },
  take: 24, // víc načteme, po dedup může zůstat méně — chceme 12 unikátních
});

// Petr 2026-05-27: dedup duplicit (stejný název + čas + source) — viz
// day/[date].astro pattern. Google občas posílá recurring instance + master,
// nebo Petr má event v Google i iCloud. Hack ve view; root cause = sync logika.
const seenKeys = new Set<string>();
const upcomingEvents = upcomingEventsRaw.filter((e) => {
  const key = `${e.title}|${e.startsAt.getTime()}|${e.endsAt.getTime()}`;
  if (seenKeys.has(key)) return false;
  seenKeys.add(key);
  return true;
}).slice(0, 12);

// Aktivní porušení pravidel pro nejbližší dny (neacknowledged)
const todayDate = new Date();
todayDate.setHours(0, 0, 0, 0);
const horizon = new Date(todayDate);
horizon.setDate(horizon.getDate() + 7);

const activeViolations = await prisma.ruleViolation.findMany({
  where: { acknowledged: false, forDate: { gte: todayDate, lte: horizon } },
  orderBy: [{ severity: "desc" }, { forDate: "asc" }],
  take: 10,
});

// Petr 2026-05-27: Notifikace na dashboardu místo Pravidla widgetu.
// Stejné jako na mobilu (/notifikace) — VIP, urgent mail, Studánka host, booking.
const notifications = await loadNotifications(session.uid);

// Výročí — propsání na desktop dashboard (paralelní query)
const anniversaries = await prisma.anniversary.findMany({
  where: { userId: session.uid },
  select: { id: true, title: true, month: true, day: true, year: true },
});
const _today = new Date();
const _todayY = _today.getFullYear();
function _daysUntil(month: number, day: number): number {
  const t = new Date(_todayY, _today.getMonth(), _today.getDate());
  let target = new Date(_todayY, month - 1, day);
  if (target < t) target = new Date(_todayY + 1, month - 1, day);
  return Math.round((target.getTime() - t.getTime()) / 86_400_000);
}
const annivItems = anniversaries
  .map((a) => {
    const days = _daysUntil(a.month, a.day);
    const yearsCount = a.year ? _todayY - a.year : null;
    const label = yearsCount && yearsCount > 0 ? `${yearsCount}. ${a.title}` : a.title;
    return { id: a.id, label, month: a.month, day: a.day, days };
  })
  .filter((a) => a.days <= 14)
  .sort((a, b) => a.days - b.days);
const annivToday = annivItems.filter((a) => a.days === 0);
const annivUpcoming = annivItems.filter((a) => a.days > 0 && a.days <= 14);

const fmtDay = (d: Date) =>
  d.toLocaleDateString("cs-CZ", { weekday: "short", day: "numeric", month: "numeric" });
const fmtTime = (d: Date) =>
  d.toLocaleTimeString("cs-CZ", { hour: "2-digit", minute: "2-digit", hour12: false });

const sourceLabel = (src: string) =>
  src === "ICLOUD_SON" ? "syn" : src === "ICLOUD_PARTNER" ? "partnerka" : src === "LOCAL_ICS" ? "ics" : "G";
const sourceTint = (src: string): Tint =>
  src === "ICLOUD_SON" ? "mint" : src === "ICLOUD_PARTNER" ? "lavender" : src === "LOCAL_ICS" ? "sage" : "sky";

const kpis: { label: string; value: string; delta?: string; deltaDir?: "up" | "down" | "flat"; href?: string; icon: string; tint: Tint }[] = [
  { label: "Otevřené úkoly",  value: openTasksCount.toString(), delta: dueTodayCount > 0 ? `${dueTodayCount} dnes` : "nic dnes",   deltaDir: dueTodayCount > 0 ? "up" : "flat", href: "/ukoly", icon: "lucide:check-square",  tint: "peach" },
  { label: "Poznámky týden",  value: "—", delta: "—",   deltaDir: "flat", icon: "lucide:notebook-pen",  tint: "mint" },
  { label: "Firewall",        value: unseenFirewall.toString(), delta: unseenFirewall === 0 ? "žádné" : "nevyřízené", deltaDir: unseenFirewall > 0 ? "up" : "flat", href: "/firewall", icon: "lucide:shield", tint: "peach" },
  { label: "Passkey",         value: user.passkeys.length.toString(), delta: "aktivní", deltaDir: "up", icon: "lucide:fingerprint", tint: "lavender" },
];

const activity = [
  { icon: "lucide:shield-check", label: "Přihlášení úspěšné",      at: fmt(user.lastLoginAt), tint: "sage" as Tint },
  { icon: "lucide:user-plus",    label: "Účet vytvořen",           at: fmt(user.createdAt),   tint: "lavender" as Tint },
];

// Petr 2026-07-15: moduly co už existují jsou klikatelné zkratky ("aktivní"),
// zbytek zůstává "v plánu" bez odkazu
const modules: { icon: string; label: string; tint: Tint; href?: string }[] = [
  { icon: "lucide:check-square", label: "Úkoly",     tint: "peach",    href: "/ukoly" },
  { icon: "lucide:notebook-pen", label: "Poznámky",  tint: "mint",     href: "/notes" },
  { icon: "lucide:book-open",    label: "Deník",     tint: "butter",   href: "/denik" },
  { icon: "lucide:calendar",     label: "Kalendář",  tint: "sky",      href: "/calendar" },
  { icon: "lucide:users",        label: "Kontakty",  tint: "lavender", href: "/contacts" },
  { icon: "lucide:wallet",       label: "Finance",   tint: "sage" },
  { icon: "lucide:sparkles",     label: "AI chat",   tint: "rose",     href: "/zeptat-se" },
  { icon: "lucide:list-todo",    label: "Superlist", tint: "pink" },
];
const activeModulesCount = modules.filter((m) => m.href).length;

// "Dnes" tabulka — reálná data místo scaffold placeholderu (Petr 2026-07-15):
// úkoly s termínem dnes + dnešní události + stav zápisu dne
const todayKey = new Date().toLocaleDateString("sv-SE", { timeZone: "Europe/Prague" });
const [dueTodayTasks, todayEventsRaw, todayJournalEntry] = await Promise.all([
  prisma.task.findMany({
    where: { userId: session.uid, status: "open", dueAt: { gte: todayStart, lt: todayEnd } },
    select: { id: true, title: true, dueAt: true, dueIsTime: true },
    orderBy: [{ dueAt: "asc" }],
    take: 6,
  }),
  prisma.calendarEvent.findMany({
    where: {
      deletedRemotely: false,
      // gt (ne gte): all-day event končící přesně o dnešní půlnoci patří včerejšku
      AND: [{ endsAt: { gt: todayStart } }, { startsAt: { lt: todayEnd } }],
    },
    select: { id: true, title: true, startsAt: true, endsAt: true, allDay: true },
    orderBy: { startsAt: "asc" },
    take: 12,
  }),
  prisma.journalEntry.findFirst({
    where: {
      userId: session.uid,
      date: { gte: new Date(`${todayKey}T00:00:00`), lte: new Date(`${todayKey}T23:59:59`) },
    },
    select: { id: true, title: true },
  }),
]);

// Dedup událostí (Google duplicity) — stejný pattern jako Plán výše
const todaySeen = new Set<string>();
const todayEvents = todayEventsRaw
  .filter((e) => {
    const key = `${e.title}|${e.startsAt.getTime()}|${e.endsAt.getTime()}`;
    if (todaySeen.has(key)) return false;
    todaySeen.add(key);
    return true;
  })
  .slice(0, 6);

type DnesRow = { type: string; label: string; cat: string; time: string; state: string; tint: Tint; href: string };
const fmtHm = (d: Date) =>
  d.toLocaleTimeString("cs-CZ", { hour: "2-digit", minute: "2-digit", hour12: false });
const dnesRows: DnesRow[] = [
  ...dueTodayTasks.map((t) => ({
    type: "Úkol", label: t.title, cat: "Úkoly",
    time: t.dueIsTime && t.dueAt ? fmtHm(t.dueAt) : "—",
    state: "otevřený", tint: "peach" as Tint, href: "/ukoly",
  })),
  ...todayEvents.map((e) => ({
    type: "Událost", label: e.title, cat: "Kalendář",
    time: e.allDay ? "celý den" : `${fmtHm(e.startsAt)}–${fmtHm(e.endsAt)}`,
    state: e.endsAt < now ? "proběhlo" : e.startsAt <= now ? "běží" : "čeká",
    tint: "sky" as Tint, href: `/day/${todayKey}`,
  })),
  {
    type: "Deník", label: todayJournalEntry ? (todayJournalEntry.title || "Dnešní zápis") : "Zápis dne zatím chybí",
    cat: "Deník", time: "—", state: todayJournalEntry ? "zapsáno" : "chybí",
    tint: "butter" as Tint,
    href: todayJournalEntry ? `/denik#${todayJournalEntry.id}` : "/denik",
  },
];

const today = new Date().toLocaleDateString("cs-CZ", { weekday: "long", day: "numeric", month: "long" });

// Počasí dnes + 2 dny (Petr 2026-07-15) — chipy v hlavičce Plánu.
// null při výpadku API = chipy se nevykreslí, dashboard jede dál.
const weather = await getForecast3Days();
const weatherDayLabel = (dateStr: string, i: number) =>
  i === 0 ? "dnes" : new Date(`${dateStr}T12:00:00`).toLocaleDateString("cs-CZ", { weekday: "short" });
---

<Shell title="Dashboard · Rašeliniště" username={user.username}>
  <div class="space-y-4">

    {/* VÝRAZNÝ banner — dnešní výročí (Petr explicitně chce výrazné, ne jemné) */}
    {annivToday.length > 0 && (
      <div class="rounded-2xl p-4 border-2 border-[var(--tint-rose)]/50 bg-[var(--tint-rose)]/15 flex items-center gap-3 flex-wrap">
        <div class="size-10 rounded-md grid place-items-center bg-[var(--tint-rose)]/30 text-[var(--tint-rose)] shrink-0">
          <Icon name="lucide:calendar-heart" class="size-5" />
        </div>
        <div class="flex-1">
          <div class="text-[10px] uppercase tracking-[0.22em] font-mono text-[var(--tint-rose)] mb-0.5">
            Dnes
          </div>
          {annivToday.map((a) => (
            <div class="text-lg font-serif">🕯 {a.label}</div>
          ))}
        </div>
        <a href="/vyroci" class="text-xs font-mono text-[var(--tint-rose)] hover:underline">
          spravovat →
        </a>
      </div>
    )}

    {/* Headline */}
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div>
        <div class="text-xs uppercase tracking-widest text-muted-foreground font-mono mb-1.5">
          {today}
        </div>
        <h1 class="font-serif text-[2.5rem] leading-tight">
          Vítej, {user.username}.
        </h1>
        {annivUpcoming.length > 0 && (
          <div class="mt-2 text-sm text-foreground/80">
            <span class="text-[var(--tint-rose)]">🕯 Nadchází:</span>{" "}
            {annivUpcoming.map((a) => `${a.label} (${a.day}.${a.month}., za ${a.days} ${a.days === 1 ? "den" : a.days < 5 ? "dny" : "dní"})`).join(" · ")}
          </div>
        )}
      </div>
      <div class="text-sm font-mono text-muted-foreground tabular">
        Poslední přihlášení: <span class="text-foreground">{fmt(user.lastLoginAt)}</span>
      </div>
    </div>

    {/* Rychlý záznam — Petr 2026-06-19: klik = start, klik znovu = stop.
        Funguje přímo z dashboardu, žádný redirect na /ozvena potřeba. */}
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <QuickRecordButton client:load mode="task" />
      <QuickRecordButton client:load mode="journal" />
    </section>

    {/* Plán — nejbližší eventy + Notifikace (místo Pravidla, viz Petr 2026-05-27) */}
    {(upcomingEvents.length > 0 || notifications.length > 0) && (
      <section class="grid grid-cols-1 lg:grid-cols-3 gap-3">
        <div class="glass rounded-xl p-4 lg:col-span-2" style="--c: var(--tint-sky);">
          <div class="flex items-center gap-2 mb-3">
            <Icon name="lucide:calendar-days" class="size-4" style="color: var(--c);" />
            <h2 class="font-serif text-lg">Plán (dnes + 2 dny)</h2>
            {weather && (
              <div class="flex items-center gap-2 ml-2 flex-wrap" title="Předpověď — Jílové u Prahy (Open-Meteo)">
                {weather.map((w, i) => (
                  <span class="inline-flex items-center gap-1 rounded-md px-1.5 py-0.5 text-[11px] font-mono bg-white/[0.04] text-muted-foreground" title={`${w.label}, ${w.tMin}–${w.tMax} °C`}>
                    <span class="lowercase">{weatherDayLabel(w.date, i)}</span>
                    <Icon name={w.icon} class="size-3.5" style="color: var(--tint-sky);" />
                    <span class="tabular text-foreground">{w.tMax}°</span>
                  </span>
                ))}
              </div>
            )}
            <div class="ml-auto flex items-center gap-3 flex-wrap">
              <a href="/calendar/tyden" class="text-xs font-mono text-[var(--tint-sky)] hover:underline">
                Týden →
              </a>
              <a href="/calendar/mesic" class="text-xs font-mono text-[var(--tint-sky)] hover:underline">
                Měsíc →
              </a>
              <a href="/quickadd" class="text-xs font-mono text-[var(--tint-sky)] hover:underline">
                + Rychlé zadání
              </a>
            </div>
          </div>
          {upcomingEvents.length === 0 ? (
            <div class="text-sm text-muted-foreground italic">Žádné události — užij si volno.</div>
          ) : (
            <div class="space-y-1.5">
              {upcomingEvents.map((e) => {
                const start = new Date(e.startsAt);
                const end = new Date(e.endsAt);
                // Multi-day event začatý v minulosti — zobraz "Probíhá" + do kdy,
                // nikoli původní datum začátku (mátlo).
                const ongoing = start < dayStart;
                // Petr 2026-07-12: narozeniny zapadaly mezi ostatní řádky —
                // zvýraznit (Signal Coral left border + tint bg + ikona dortu).
                // Match přes title — narozeniny přicházejí z Google kalendáře
                // s „… – narozeniny" v názvu (žádný vlastní event type nemají).
                const isBirthday = /narozenin|výročí|svátek/i.test(e.title);
                return (
                  <div class={`flex items-center gap-3 text-sm rounded-md px-2 py-1.5 ${
                    isBirthday
                      ? "border-l-[3px] border-[color:var(--c-signal)] bg-[color:var(--c-signal)]/10"
                      : "bg-black/10"
                  }`}>
                    <span class={`font-mono text-xs tabular w-20 shrink-0 ${ongoing ? "text-[var(--tint-mint)]" : "text-muted-foreground"}`}>
                      {ongoing ? "Probíhá" : fmtDay(start)}
                    </span>
                    <span class="font-mono text-xs tabular w-24 shrink-0 text-muted-foreground">
                      {ongoing
                        ? `do ${fmtDay(end)}`
                        : e.allDay
                          ? "celý den"
                          : `${fmtTime(start)}–${fmtTime(end)}`}
                    </span>
                    {isBirthday && (
                      <Icon name="lucide:cake" class="size-4 shrink-0 text-[color:var(--c-signal)]" />
                    )}
                    <span class={`flex-1 truncate ${isBirthday ? "font-semibold" : ""}`}>{e.title}</span>
                    {e.locationText && (
                      <span class="text-xs text-muted-foreground truncate max-w-[8rem]">
                        {e.locationText}
                      </span>
                    )}
                    <span class={`text-xs font-mono text-[var(--tint-${sourceTint(e.source)})]`}>
                      {sourceLabel(e.source)}
                    </span>
                  </div>
                );
              })}
            </div>
          )}
        </div>

        {/* Petr 2026-05-27: Notifikace místo Pravidla — stejný zdroj jako
            mobilní /notifikace. Compact verze, max 5 položek + link na detail.
            Pravidla zůstávají dostupná přes /settings nebo /dnes detail view. */}
        {notifications.length > 0 ? (
          <a href="/notifikace" class="glass rounded-xl p-4 block hover:bg-white/[0.03] transition" style="--c: var(--tint-butter);">
            <div class="flex items-center gap-2 mb-3">
              <Icon name="lucide:bell" class="size-4" style="color: var(--c);" />
              <h2 class="font-serif text-lg">Notifikace</h2>
              <span class="ml-auto text-xs font-mono text-muted-foreground">
                {notifications.length}
              </span>
            </div>
            <div class="space-y-2">
              {notifications.slice(0, 5).map((n) => {
                const tint = n.type === "studanka" ? "mint" : n.type === "posta" ? "sky" : "rose";
                const label = n.type === "studanka" ? "🌊 Studánka" : n.type === "posta" ? "Pošta" : "VIP";
                return (
                  <div class={`text-sm rounded-md p-2 border border-[var(--tint-${tint})]/30 bg-[var(--tint-${tint})]/10`}>
                    <div class="text-[10px] uppercase tracking-wider font-mono mb-0.5" style={`color: var(--tint-${tint});`}>
                      {label}
                    </div>
                    <div class="line-clamp-2">{n.title}</div>
                  </div>
                );
              })}
              {notifications.length > 5 && (
                <div class="text-xs text-muted-foreground text-center pt-1">
                  + {notifications.length - 5} dalších v /notifikace
                </div>
              )}
            </div>
          </a>
        ) : (
          <a href="/notifikace" class="glass rounded-xl p-4 block hover:bg-white/[0.03] transition" style="--c: var(--tint-sage);">
            <div class="flex items-center gap-2 mb-2">
              <Icon name="lucide:check-circle-2" class="size-4" style="color: var(--c);" />
              <h2 class="font-serif text-lg">Notifikace</h2>
            </div>
            <div class="text-sm text-muted-foreground">Nic nového. Klid. </div>
          </a>
        )}
      </section>
    )}

    {/* KPI grid — glass cards, každý v pastelovém tintu */}
    <section class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {kpis.map((k) => (
        <article
          class="glass rounded-xl p-4 relative overflow-hidden"
          style={`--c: var(--tint-${k.tint});`}
        >
          <div class="absolute -top-10 -right-10 size-24 rounded-full blur-2xl pointer-events-none" style="background: color-mix(in oklch, var(--c) 25%, transparent);"></div>

          <div class="relative flex items-center justify-between">
            <span class="text-[10px] uppercase tracking-[0.18em] font-mono text-muted-foreground">
              {k.label}
            </span>
            <div class="size-7 rounded-md grid place-items-center" style="background: color-mix(in oklch, var(--c) 15%, transparent); color: var(--c);">
              <Icon name={k.icon} class="size-3.5" />
            </div>
          </div>

          <div class="font-serif text-[2.25rem] leading-none mt-2 tabular text-foreground">
            {k.value}
          </div>

          {k.delta && (
            <div class="mt-2 flex items-center gap-1 text-xs text-muted-foreground">
              {k.deltaDir === "up" && <Icon name="lucide:trending-up" class="size-3.5" style="color: var(--tint-sage);" />}
              {k.deltaDir === "down" && <Icon name="lucide:trending-down" class="size-3.5" style="color: var(--tint-rose);" />}
              {k.deltaDir === "flat" && <Icon name="lucide:minus" class="size-3.5" />}
              <span class="font-mono tabular">{k.delta}</span>
            </div>
          )}
        </article>
      ))}
    </section>

    {/* Dva sloupce: Dnes (tabulka) + Aktivita (feed) */}
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-3">

      {/* "Dnes" — tabulka úkolů / událostí */}
      <div class="lg:col-span-2 glass rounded-xl">
        <div class="flex items-center justify-between px-5 py-4 border-b border-white/5">
          <div>
            <h2 class="font-serif text-xl">Dnes</h2>
            <p class="text-xs text-muted-foreground mt-0.5">
              Všechno, co je na dnešní den.
            </p>
          </div>
          <span class="text-[10px] uppercase tracking-widest text-muted-foreground font-mono">
            {today}
          </span>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-[10px] uppercase tracking-widest text-muted-foreground font-mono">
                <th class="text-left font-normal px-5 py-2">Typ</th>
                <th class="text-left font-normal px-5 py-2">Název</th>
                <th class="text-left font-normal px-5 py-2">Kategorie</th>
                <th class="text-right font-normal px-5 py-2">Čas</th>
                <th class="text-right font-normal px-5 py-2 pr-5">Stav</th>
              </tr>
            </thead>
            <tbody>
              {dnesRows.map((row) => (
                <tr class="border-t border-white/5 hover:bg-white/[0.03] transition-colors">
                  <td class="px-5 py-3">
                    <span class="inline-flex items-center gap-1.5 rounded-md px-2 py-0.5 text-[11px]" style={`background: color-mix(in oklch, var(--tint-${row.tint}) 14%, transparent); color: var(--tint-${row.tint});`}>
                      <span class="size-1.5 rounded-full" style={`background: var(--tint-${row.tint});`}></span>
                      {row.type}
                    </span>
                  </td>
                  <td class="px-5 py-3 text-foreground">
                    <a href={row.href} class="hover:underline">{row.label}</a>
                  </td>
                  <td class="px-5 py-3 text-muted-foreground">{row.cat}</td>
                  <td class="px-5 py-3 text-right font-mono tabular text-muted-foreground whitespace-nowrap">{row.time}</td>
                  <td class="px-5 py-3 text-right pr-5 font-mono text-muted-foreground">{row.state}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* Aktivita — feed */}
      <div class="glass rounded-xl">
        <div class="flex items-center justify-between px-5 py-4 border-b border-white/5">
          <h2 class="font-serif text-xl">Aktivita</h2>
          <Icon name="lucide:activity" class="size-4 text-muted-foreground" />
        </div>
        <ul class="divide-y divide-white/5">
          {activity.map((a) => (
            <li class="flex items-start gap-3 px-5 py-3.5 text-sm">
              <div class="size-8 rounded-md grid place-items-center shrink-0" style={`background: color-mix(in oklch, var(--tint-${a.tint}) 14%, transparent); color: var(--tint-${a.tint});`}>
                <Icon name={a.icon} class="size-4" />
              </div>
              <div class="min-w-0 flex-1">
                <div>{a.label}</div>
                <div class="text-xs text-muted-foreground font-mono tabular mt-0.5">{a.at}</div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* Moduly v plánu — glass grid */}
    <section class="glass rounded-xl">
      <div class="flex items-center justify-between px-5 py-4 border-b border-white/5">
        <div>
          <h2 class="font-serif text-xl">Moduly</h2>
          <p class="text-xs text-muted-foreground mt-0.5">
            Zkratky do hotových modulů, zbytek přijde postupně.
          </p>
        </div>
        <span class="text-[10px] uppercase tracking-widest text-muted-foreground font-mono">
          {activeModulesCount}/{modules.length} aktivních
        </span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-2 p-4 text-sm">
        {modules.map((m) => m.href ? (
          <a
            href={m.href}
            class="flex items-center justify-between gap-3 px-3 py-3 rounded-lg glass-subtle hover:bg-white/[0.06] transition-colors"
            style={`--c: var(--tint-${m.tint});`}
          >
            <div class="flex items-center gap-2.5 min-w-0">
              <div class="size-8 rounded-md grid place-items-center shrink-0" style="background: color-mix(in oklch, var(--c) 15%, transparent); color: var(--c);">
                <Icon name={m.icon} class="size-4" />
              </div>
              <span class="truncate">{m.label}</span>
            </div>
            <span class="text-[10px] uppercase tracking-widest font-mono" style="color: var(--c);">
              aktivní
            </span>
          </a>
        ) : (
          <div
            class="flex items-center justify-between gap-3 px-3 py-3 rounded-lg glass-subtle opacity-60"
            style={`--c: var(--tint-${m.tint});`}
          >
            <div class="flex items-center gap-2.5 min-w-0">
              <div class="size-8 rounded-md grid place-items-center shrink-0" style="background: color-mix(in oklch, var(--c) 15%, transparent); color: var(--c);">
                <Icon name={m.icon} class="size-4" />
              </div>
              <span class="truncate">{m.label}</span>
            </div>
            <span class="text-[10px] uppercase tracking-widest text-muted-foreground font-mono">
              v plánu
            </span>
          </div>
        ))}
      </div>
    </section>

    {/* Scheduler status — diskrétní info na konci stránky */}
    <SchedulerStatus variant="full" />
  </div>
</Shell>
