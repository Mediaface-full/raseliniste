---
import Shell from "../layouts/Shell.astro";
import CaptureForm from "../components/CaptureForm";
import { prisma } from "../lib/db";
import { readSession } from "../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");
---

<Shell
  title="Capture · Rašeliniště"
  username={user.username}
  breadcrumb={[{ label: "Capture" }, { label: "Ruční vstup" }]}
>
  <div class="space-y-5 max-w-3xl">
    <div>
      <h1 class="font-serif text-[2.25rem] leading-tight">Capture</h1>
      <p class="text-sm text-muted-foreground mt-1">
        Fallback pro ruční vstup nebo testování. Primární cesta jde přes iPhone Shortcut a Wispr Flow.
      </p>
    </div>

    <div class="glass rounded-xl p-5">
      <CaptureForm client:load />
    </div>
  </div>
</Shell>
