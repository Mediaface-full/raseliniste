---
import Shell from "../../layouts/Shell.astro";
import { Icon } from "astro-icon/components";
import { prisma } from "../../lib/db";
import { readSession } from "../../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

const items = await prisma.checkIn.findMany({
  where: { userId: session.uid },
  orderBy: { createdAt: "desc" },
  take: 60,
});

function fmtDate(d: Date): string {
  const today = new Date();
  const isToday = d.toDateString() === today.toDateString();
  const yest = new Date(Date.now() - 86_400_000);
  const isYest = d.toDateString() === yest.toDateString();
  if (isToday) return "Dnes";
  if (isYest) return "Včera";
  return d.toLocaleDateString("cs-CZ", { weekday: "short", day: "numeric", month: "numeric" });
}

function fmtTime(d: Date): string {
  return d.toLocaleTimeString("cs-CZ", { hour: "2-digit", minute: "2-digit" });
}

function moodBar(m: number | null): { width: string; color: string; label: string } {
  if (m === null) return { width: "0%", color: "var(--muted-foreground)", label: "—" };
  const pct = `${(m / 10) * 100}%`;
  // Barva: 1-3 rose (zlé), 4-6 butter (neutrál), 7-10 sage (dobré)
  const color = m <= 3 ? "var(--tint-rose)" : m <= 6 ? "var(--tint-butter)" : "var(--tint-sage)";
  return { width: pct, color, label: String(m) };
}
---

<Shell
  title="ŽIJEŠ? · Rašeliniště"
  username={user.username}
  heading="ŽIJEŠ?"
  breadcrumb={[{ label: "ŽIJEŠ?" }]}
>
  <div class="space-y-4">
    {/* Tlačítko + intro */}
    <div class="glass rounded-xl p-4 flex flex-wrap items-center gap-3">
      <div class="flex-1 min-w-0">
        <div class="text-sm text-foreground/85 leading-relaxed">
          Pravidelná sebereflexe — 2× denně, 90 sekund.
          Tady jsem, když chceš.
        </div>
      </div>
      <a
        href="/zijes/novy"
        class="px-4 py-2 rounded-md bg-[var(--tint-rose)]/20 border border-[var(--tint-rose)]/40 text-foreground font-medium text-sm hover:bg-[var(--tint-rose)]/30 transition flex items-center gap-2"
      >
        <Icon name="lucide:heart-pulse" class="size-4" /> Nový check-in
      </a>
    </div>

    {/* Archiv */}
    {items.length === 0 ? (
      <div class="glass rounded-xl p-8 text-center text-muted-foreground text-sm">
        Zatím žádný záznam. První check-in můžeš vyplnit kliknutím nahoře.
      </div>
    ) : (
      <div class="space-y-2">
        {items.map((it) => {
          const m = moodBar(it.mood);
          const typeLabel = it.type === "lunch" ? "Polední" : "Večerní";
          return (
            <a
              href={`/zijes/${it.id}`}
              class="glass rounded-xl p-4 flex flex-col gap-2 hover:bg-white/5 transition block"
            >
              <div class="flex items-baseline gap-2 flex-wrap">
                <span class="font-mono text-xs uppercase tracking-wider text-[var(--tint-rose)]">
                  {typeLabel}
                </span>
                <span class="text-sm font-medium">{fmtDate(it.createdAt)}</span>
                <span class="text-xs font-mono text-muted-foreground">{fmtTime(it.createdAt)}</span>
                <span class="ml-auto text-xs font-mono text-muted-foreground">
                  Nálada {m.label}
                </span>
              </div>

              {/* Mood bar */}
              {it.mood !== null && (
                <div class="h-1 bg-white/5 rounded-full overflow-hidden">
                  <div
                    class="h-full rounded-full transition-all"
                    style={`width: ${m.width}; background: ${m.color};`}
                  />
                </div>
              )}

              {/* Snippety pokud něco vyplněno */}
              {(it.bodyFeeling || it.whatWorked || it.oldPattern) && (
                <div class="text-xs text-muted-foreground/90 space-y-0.5 mt-1">
                  {it.bodyFeeling && <div>🫀 {it.bodyFeeling}</div>}
                  {it.whatWorked && <div>✓ {it.whatWorked}</div>}
                  {it.oldPattern && it.oldPattern.toLowerCase() !== "ne" && (
                    <div class="text-[var(--tint-butter)]">↻ {it.oldPattern}</div>
                  )}
                </div>
              )}
            </a>
          );
        })}
      </div>
    )}
  </div>
</Shell>
