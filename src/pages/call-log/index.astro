---
import Base from "../../layouts/Base.astro";
import GideonWordmark from "../../components/GideonWordmark";
import { prisma } from "../../lib/db";
import { normalizePhone } from "../../lib/phone";
import { vokativ } from "../../lib/vokativ";
import { resolveCallLogToken } from "../../lib/call-log-token";
import { checkPageRateLimit, getIp } from "../../lib/page-rate-limit";
import { loadVipMissions, type VipMission } from "../../lib/vip-missions";
import VipMissionsList from "../../components/VipMissionsList.astro";

// Rate-limit anti-DoS: 60 req/min/IP. Veřejná stránka, neautentizovaná.
const _ip = getIp(Astro.request, Astro.clientAddress);
if (!checkPageRateLimit(_ip, "call-log-index", 60)) {
  return new Response("Too many requests", { status: 429 });
}

// =============================================================================
// TEXTY — Petr edituje zde. VIP a ne-VIP jsou ZÁMĚRNĚ ODDĚLENÉ entity.
// =============================================================================

const NONVIP_TEXTS = {
  pageTitle: "Vzkaz Gideonovi",
  appleTitle: "Vzkaz Gideonovi",
  heading: "Gideon teď nezvedá",
  intro:
    "Gideon je teď ponořen do práce a není na příjmu. Klidně mu tu ale " +
    "nechte zprávu. Hned jakmile se vynoří a projde si vaše zadání, dá vám vědět.",
  messagePlaceholder: "S čím voláš?",
  urgentLabel: "Je to urgentní",
  urgentSub: "Gideonovi přijde notifikace ihned.",
  submit: "Odeslat vzkaz",
  footer: "tvoje IP a čas budou zaznamenány",
};

const VIP_TEXTS = {
  pageTitle: "Gíďo, máš misi",
  appleTitle: "Gíďo, máš misi",
  // Personalizované oslovení — "Ahoj, Karle"
  greetingPrefix: "Ahoj,",
  heading: "Zadej Gíďovi jeho misi.",
  intro: "Pošli mu to a trochu mu rozčeř svět.",
  messagePlaceholder: "Co mu hodíš na hřbet?",
  dueDateLabel: "Do kdy to potřebuješ (volitelné)",
  dueDateHint: "Termín nejdřív za 2 dny. Pokud to potřebuješ dřív, zaškrtni níže Urgent.",
  urgentLabel: "Je to urgentní",
  urgentSub: "Gideonovi přijde notifikace ihned.",
  submit: "Vypusť Gíďu",
  footer: "tvoje IP a čas budou zaznamenány",
};

// =============================================================================
// SERVER LOGIKA — detekce VIP podle telefonu, předvyplnění formuláře
// =============================================================================

const url = new URL(Astro.request.url);
const rawToken = url.searchParams.get("t")?.trim() ?? "";
let rawPhone =
  url.searchParams.get("phone") ??
  url.searchParams.get("tel") ??
  url.searchParams.get("from") ??
  "";

let matchedFirstName: string | null = null;
let matchedFirstNameVocative: string | null = null;
let matchedGreetingOverride: string | null = null;
let matchedIsVip = false;
let phoneKnown = false;
let tokenAuthed = false;
let tokenUserId: string | null = null;
let tokenContactId: string | null = null;
let tokenContactPhones: string[] = [];

// Token-based VIP cesta: pokud máme platný token, načti kontakt + telefon z DB.
if (rawToken) {
  const c = await resolveCallLogToken(rawToken);
  if (c) {
    matchedIsVip = true;
    tokenAuthed = true;
    phoneKnown = true;
    matchedFirstName = c.firstName?.trim() || c.displayName.split(" ")[0] || null;
    matchedFirstNameVocative = c.firstNameVocative?.trim() || null;
    matchedGreetingOverride = c.greetingOverride?.trim() || null;
    rawPhone = c.phones[0]?.number ?? rawPhone;
    tokenUserId = c.userId;
    tokenContactId = c.id;
    // Načti VŠECHNA čísla VIP — match misí přes všechna, ne jen phones[0].
    const phones = await prisma.phone.findMany({
      where: { contactId: c.id },
      select: { number: true },
    });
    tokenContactPhones = phones.map((p) => p.number);
  }
}

// Načti VIP mise pro výpis pod formulářem (jen tokenAuthed VIP).
let openMissions: VipMission[] = [];
let doneMissions: VipMission[] = [];
if (tokenAuthed && tokenUserId && tokenContactId) {
  try {
    const r = await loadVipMissions({
      userId: tokenUserId,
      contactId: tokenContactId,
    });
    openMissions = r.open;
    doneMissions = r.done;
  } catch {
    // DB výpadek — sekci skryjeme
  }
}

const normalizedPhone = rawPhone ? normalizePhone(rawPhone) : null;
if (!matchedIsVip && normalizedPhone) {
  try {
    const hit = await prisma.phone.findFirst({
      where: { number: normalizedPhone },
      include: { contact: true },
    });
    if (hit?.contact) {
      phoneKnown = true;
      matchedIsVip = hit.contact.isVip;
      matchedFirstName =
        hit.contact.firstName?.trim() ||
        hit.contact.displayName.split(" ")[0] ||
        null;
      matchedFirstNameVocative = hit.contact.firstNameVocative?.trim() || null;
      matchedGreetingOverride = hit.contact.greetingOverride?.trim() || null;
    }
  } catch {
    // DB výpadek → fallback na ne-VIP variantu
  }
}

// Oslovení pro VIP — priorita:
//   1. greetingOverride (vlastní string typu "Drahá dívko") → použij celý jak je
//   2. vokativ z firstNameVocative → "Ahoj, Karle"
//   3. algoritmus + fallback firstName
const greetingName = matchedIsVip ? vokativ(matchedFirstName, matchedFirstNameVocative) : null;
const customGreeting = matchedIsVip ? matchedGreetingOverride : null;
const hidePhoneField = phoneKnown && Boolean(normalizedPhone);
const prefillPhoneValue = normalizedPhone ?? rawPhone;

// Min datum pro VIP date picker = dnes + 2 dny (Gideon potřebuje aspoň
// 2 pracovní dny na vyřízení; "dnes" / "zítra" by často nestihl).
//
// POZOR na timezone: server běží v UTC, klient v Europe/Prague.
// `toISOString().slice(0,10)` vrátí UTC datum, ne Praha — v ranních hodinách
// (00:00–02:00 Praha) by minDateIso byl o den menší než user vidí. Petr 2026-05-14
// hlásil "VIP nemůže odeslat i když datum je za 2 dny" — možná tady.
// Fix: počítáme Praha datum explicitně přes Intl.
const pragueDateParts = new Intl.DateTimeFormat("sv-SE", {
  timeZone: "Europe/Prague",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).formatToParts(new Date());
const py = Number(pragueDateParts.find((p) => p.type === "year")?.value);
const pm = Number(pragueDateParts.find((p) => p.type === "month")?.value);
const pd = Number(pragueDateParts.find((p) => p.type === "day")?.value);
// new Date(y, m-1, d+2) — JS auto-přetočí pokud d+2 přesáhne počet dní v měsíci
const minDateObj = new Date(py, pm - 1, pd + 2);
const minDateIso = `${minDateObj.getFullYear()}-${String(minDateObj.getMonth() + 1).padStart(2, "0")}-${String(minDateObj.getDate()).padStart(2, "0")}`;

// Vyber správnou sadu textů
const T = matchedIsVip ? VIP_TEXTS : NONVIP_TEXTS;
---

<Base
  title={T.pageTitle}
  appleTitle={T.appleTitle}
  appleCapable={true}
>
  <div class="min-h-screen px-4 pt-10 sm:pt-16 pb-10 relative z-10">
    <div class="w-full max-w-md mx-auto">
      <div class="mb-6 flex justify-center">
        <GideonWordmark size="sm" />
      </div>
      <div class="mb-6 text-center">

        {matchedIsVip && (customGreeting || greetingName) && (
          <div class="text-xs uppercase tracking-[0.22em] text-[var(--tint-rose)] font-mono mb-2">
            {customGreeting ? customGreeting : `${VIP_TEXTS.greetingPrefix} ${greetingName}`} 
          </div>
        )}

        <h1 class="font-serif text-4xl tracking-tight">{T.heading}</h1>
        <p class="mt-3 text-sm text-muted-foreground leading-relaxed">
          {T.intro}
        </p>
      </div>

      <div class="glass-strong rounded-xl p-6">
        <form id="call-log-form" data-vip={matchedIsVip ? "1" : "0"} data-token={rawToken} class="space-y-4">
          <!-- honeypot -->
          <div class="hidden" aria-hidden="true">
            <label>Website: <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
          </div>

          {hidePhoneField ? (
            <input type="hidden" name="phone" value={prefillPhoneValue} />
          ) : (
            <div>
              <label for="phone" class="block text-xs font-mono uppercase tracking-wider text-muted-foreground mb-1.5">
                Tvoje číslo
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                required
                inputmode="tel"
                autocomplete="tel"
                value={prefillPhoneValue}
                placeholder="+420 777 123 456"
                class="w-full px-3 py-2.5 rounded-md bg-background/40 border border-border/60 focus:border-primary focus:outline-none text-base"
              />
            </div>
          )}

          <div>
            <label for="message" class="block text-xs font-mono uppercase tracking-wider text-muted-foreground mb-1.5">
              Zpráva
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              minlength="3"
              maxlength="1000"
              placeholder={T.messagePlaceholder}
              class="w-full px-3 py-2.5 rounded-md bg-background/40 border border-border/60 focus:border-primary focus:outline-none text-base resize-none"
            ></textarea>
          </div>

          {matchedIsVip && (
            <div>
              <label for="dueDate" class="block text-xs font-mono uppercase tracking-wider text-[var(--tint-rose)] mb-1.5">
                {VIP_TEXTS.dueDateLabel}
              </label>
              <input
                id="dueDate"
                name="dueDate"
                type="date"
                min={minDateIso}
                class="w-full px-3 py-2.5 rounded-md bg-background/40 border border-[var(--tint-rose)]/40 focus:border-[var(--tint-rose)] focus:outline-none text-base"
              />
              <p class="mt-1.5 text-[11px] text-muted-foreground">
                {VIP_TEXTS.dueDateHint}
              </p>
            </div>
          )}

          <label class="flex items-center gap-3 py-2 cursor-pointer select-none">
            <input
              type="checkbox"
              name="isUrgent"
              id="isUrgent"
              class="w-5 h-5 rounded border-border/60 bg-background/40"
            />
            <span class="text-sm">
              <strong>{T.urgentLabel}</strong>
              <span class="block text-xs text-muted-foreground mt-0.5">
                {T.urgentSub}
              </span>
            </span>
          </label>

          <button
            type="submit"
            id="submit-btn"
            class="w-full py-3 rounded-md bg-primary text-primary-foreground font-medium text-base hover:opacity-90 transition disabled:opacity-50"
          >
            {T.submit}
          </button>

          <p id="error-msg" class="hidden text-sm text-destructive text-center"></p>
        </form>
      </div>

      <p class="mt-6 text-center text-[11px] text-muted-foreground font-mono tracking-wider">
        {T.footer}
      </p>

      {tokenAuthed && (
        <VipMissionsList open={openMissions} done={doneMissions} />
      )}
    </div>
  </div>

  <script>
    const form = document.getElementById("call-log-form") as HTMLFormElement;
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    const errBox = document.getElementById("error-msg") as HTMLParagraphElement;
    const submitLabel = btn.textContent ?? "Odeslat";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errBox.classList.add("hidden");
      btn.disabled = true;
      btn.textContent = "Odesílám…";

      const fd = new FormData(form);
      const dueRaw = String(fd.get("dueDate") ?? "").trim();
      const body: Record<string, unknown> = {
        phone: String(fd.get("phone") ?? ""),
        message: String(fd.get("message") ?? ""),
        isUrgent: fd.get("isUrgent") === "on",
        website: String(fd.get("website") ?? ""), // honeypot
      };
      // dueDate posíláme jen pokud je vyplněn (server ho stejně ignoruje pro ne-VIP)
      if (dueRaw && /^\d{4}-\d{2}-\d{2}$/.test(dueRaw)) {
        body.dueDate = dueRaw;
      }

      try {
        const res = await fetch("/api/call-log/submit", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(body),
        });
        if (res.ok) {
          // Token přebije phone — VIP token cesta dává plný výpis Giďoušových misí.
          const token = form.dataset.token ?? "";
          if (token) {
            window.location.href = `/call-log/thanks?t=${encodeURIComponent(token)}`;
            return;
          }
          const phoneEnc = encodeURIComponent(String(body.phone ?? ""));
          window.location.href = phoneEnc ? `/call-log/thanks?phone=${phoneEnc}` : "/call-log/thanks";
          return;
        }
        const data = await res.json().catch(() => ({}));
        errBox.textContent = data?.error ?? "Nepodařilo se odeslat. Zkus to za chvíli znovu.";
        errBox.classList.remove("hidden");
      } catch {
        errBox.textContent = "Chyba sítě. Zkus to za chvíli znovu.";
        errBox.classList.remove("hidden");
      } finally {
        btn.disabled = false;
        btn.textContent = submitLabel;
      }
    });
  </script>
</Base>
