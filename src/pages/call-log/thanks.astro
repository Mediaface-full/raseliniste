---
import Base from "../../layouts/Base.astro";
import AnimatedG from "../../components/AnimatedG.astro";
import { prisma } from "../../lib/db";
import { normalizePhone } from "../../lib/phone";
import { resolveCallLogToken } from "../../lib/call-log-token";
import { checkPageRateLimit, getIp } from "../../lib/page-rate-limit";
import { loadVipMissions, type VipMission } from "../../lib/vip-missions";
import VipMissionsList from "../../components/VipMissionsList.astro";

// Rate-limit anti-DoS: 60 req/min/IP. Veřejná stránka, neautentizovaná.
const _ip = getIp(Astro.request, Astro.clientAddress);
if (!checkPageRateLimit(_ip, "call-log-thanks", 60)) {
  return new Response("Too many requests", { status: 429 });
}

// =============================================================================
// TEXTY — Petr edituje zde. VIP a ne-VIP jsou ZÁMĚRNĚ ODDĚLENÉ varianty.
// =============================================================================

const NONVIP_TEXTS = {
  pageTitle: "Vzkaz odeslán",
  appleTitle: "Vzkaz Gideonovi",
  heading: "Vzkaz doručen",
  intro:
    "Požadavek eviduji a ozvu se hned, jak se k němu dostanu. " +
    "Gideon je momentálně zaneprázdněn soustředěnou prací, pak se ozve.",
};

const VIP_TEXTS = {
  pageTitle: "Mise vypuštěna",
  appleTitle: "Gíďo, máš misi",
  heading: "✦ Mise vypuštěna ✦",
  // Dvě věty na samostatných řádcích — první je obřadná, druhá uvolňující.
  intro: "Gíďa už ví. Děj se vůle Gideonova.",
  intro2: "Mezitím — kdyby tě napadlo něco dalšího, klidně mu pošli další misi.",
  nextMission: "Zadej další misi",
};

// =============================================================================
// SERVER LOGIKA
//
// VIP detekce primárně přes ?t=<callLogToken> (privátní per-VIP klíč).
// Phone-based fallback je jen pro zobrazení VIP textů (oslovení), VÝPIS misí
// se zobrazuje POUZE pokud je tokenem ověřený VIP — chrání seznam před
// kýmkoliv kdo zná telefon.
// =============================================================================

const url = new URL(Astro.request.url);
const rawPhone =
  url.searchParams.get("phone") ??
  url.searchParams.get("tel") ??
  "";
const rawToken = url.searchParams.get("t")?.trim() ?? "";

let matchedIsVip = false;
let matchedFirstName: string | null = null;
let matchedUserId: string | null = null;
let tokenAuthed = false;
let tokenContactId: string | null = null;
let tokenContactPhones: string[] = [];

if (rawToken) {
  try {
    const c = await resolveCallLogToken(rawToken);
    if (c) {
      matchedIsVip = true;
      tokenAuthed = true;
      matchedFirstName = c.firstName?.trim() || c.displayName.split(" ")[0] || null;
      matchedUserId = c.userId;
      tokenContactId = c.id;
      // Načti VŠECHNA čísla VIP — pokud zadal misi z jiného než phones[0],
      // výpis ho jinak nezahrne. resolveCallLogToken bere jen take:1, takže
      // doplníme druhý query.
      const phones = await prisma.phone.findMany({
        where: { contactId: c.id },
        select: { number: true },
      });
      tokenContactPhones = phones.map((p) => p.number);
    }
  } catch {
    // ignore — fallback na phone
  }
}

const normalizedPhone = rawPhone ? normalizePhone(rawPhone) : null;
if (!matchedIsVip && normalizedPhone) {
  try {
    const hit = await prisma.phone.findFirst({
      where: { number: normalizedPhone },
      include: { contact: true },
    });
    if (hit?.contact) {
      matchedIsVip = hit.contact.isVip;
      matchedFirstName =
        hit.contact.firstName?.trim() ||
        hit.contact.displayName.split(" ")[0] ||
        null;
      matchedUserId = hit.contact.userId;
    }
  } catch {
    // DB výpadek → fallback na ne-VIP
  }
}

// Výpis misí JEN pro token-ověřené VIP. Phone-only nikdy nedostane seznam.
// Zdrojem pravdy je cron /api/cron/todoist-sync (30 min).
let openMissions: VipMission[] = [];
let doneMissions: VipMission[] = [];

if (tokenAuthed && matchedUserId && tokenContactId) {
  try {
    const r = await loadVipMissions({
      userId: matchedUserId,
      contactId: tokenContactId,
    });
    openMissions = r.open;
    doneMissions = r.done;
  } catch {
    // DB výpadek — sekci prostě skryjeme
  }
}

const T = matchedIsVip ? VIP_TEXTS : NONVIP_TEXTS;
const appleIconPath = "/apple-touch-icon.png"; // G logo (i pro VIP)

// Tlačítko "Zadej další misi" odkazuje zpět na /call-log; přednostně přenese
// token (čistá VIP cesta), jinak phone+name (legacy fallback).
let nextMissionHref = "/call-log";
if (tokenAuthed && rawToken) {
  nextMissionHref = `/call-log?t=${encodeURIComponent(rawToken)}`;
} else if (matchedIsVip && rawPhone) {
  const params = new URLSearchParams();
  params.set("phone", rawPhone);
  if (matchedFirstName) params.set("name", matchedFirstName);
  nextMissionHref = `/call-log?${params.toString()}`;
}
---

<Base
  title={T.pageTitle}
  appleTitle={T.appleTitle}
  appleCapable={true}
  appleIconPath={appleIconPath}
>
  <div class="min-h-screen px-4 pt-16 pb-10 relative z-10">
    <div class="w-full max-w-sm mx-auto text-center">
      <div class="glass-strong rounded-xl p-8">
        {matchedIsVip ? (
          <AnimatedG size={72} />
        ) : (
          <img
            src={appleIconPath}
            alt="Gideon"
            width="64"
            height="64"
            class="mx-auto mb-4 rounded-[14px] shadow-lg shadow-black/40"
          />
        )}
        <div class={`text-3xl mb-2 ${matchedIsVip ? "text-[var(--tint-rose)]" : "text-[var(--tint-sage)]"}`}>
          {matchedIsVip ? "✦" : ""}
        </div>
        <h1 class="text-4xl font-bold tracking-[-0.04em] leading-tight mb-3">{T.heading}</h1>
        <p class="text-sm text-muted-foreground leading-relaxed">
          {T.intro}
        </p>
        {matchedIsVip && VIP_TEXTS.intro2 && (
          <p class="text-sm text-muted-foreground leading-relaxed mt-2">
            {VIP_TEXTS.intro2}
          </p>
        )}

        {matchedIsVip && (
          <a
            href={nextMissionHref}
            class="mt-6 inline-block w-full py-3 rounded-md bg-[var(--tint-rose)]/20 border border-[var(--tint-rose)]/40 text-foreground font-medium text-base hover:bg-[var(--tint-rose)]/30 transition"
          >
            {VIP_TEXTS.nextMission}
          </a>
        )}
      </div>

      {tokenAuthed && (
        <VipMissionsList open={openMissions} done={doneMissions} />
      )}
    </div>
  </div>
</Base>
