---
import Shell from "../layouts/Shell.astro";
import JournalFeed from "../components/JournalFeed";
import { prisma } from "../lib/db";
import { readSession } from "../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

const totalEntries = await prisma.entry.count({
  where: {
    type: "JOURNAL",
    status: { not: "DISCARDED" },
    recording: { userId: session.uid },
  },
});
---

<Shell
  title="Deník · Rašeliniště"
  username={user.username}
  breadcrumb={[{ label: "Organizace" }, { label: "Deník" }]}
>
  <div class="space-y-5 max-w-3xl">
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div>
        <h1 class="font-serif text-[2.25rem] leading-tight">Deník</h1>
        <p class="text-sm text-muted-foreground mt-1">
          Zápisy z diktátu přes iPhone Shortcut i ruční přidané. {totalEntries} záznamů celkem.
        </p>
      </div>
    </div>

    <JournalFeed client:load />
  </div>
</Shell>
