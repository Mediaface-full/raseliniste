---
import Shell from "../../layouts/Shell.astro";
import Base from "../../layouts/Base.astro";
import DayView from "../../components/DayView";
import { prisma } from "../../lib/db";
import { readSession } from "../../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

const dateStr = Astro.params.date;
if (!dateStr || !/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) {
  return Astro.redirect("/day/" + new Date().toISOString().slice(0, 10));
}

const dayStart = new Date(`${dateStr}T00:00:00`);
const dayEnd = new Date(`${dateStr}T23:59:59.999`);

const [events, dayNotes, briefingDigest, ruleViolations] = await Promise.all([
  prisma.calendarEvent.findMany({
    where: {
      deletedRemotely: false,
      // POZOR: `gt` (ne `gte`) — Google/iCal all-day eventy mají endsAt exclusive
      // (sobotní celodenka má endsAt = neděle 00:00), takže `gte` by ji ukázal i v neděli.
      AND: [{ endsAt: { gt: dayStart } }, { startsAt: { lte: dayEnd } }],
    },
    orderBy: { startsAt: "asc" },
  }),
  prisma.dayNote.findMany({
    where: { forDate: dayStart },
    orderBy: [{ done: "asc" }, { createdAt: "asc" }],
  }),
  prisma.briefingDigest.findUnique({ where: { forDate: dayStart } }),
  prisma.ruleViolation.findMany({
    where: { forDate: dayStart },
    orderBy: { createdAt: "asc" },
  }),
]);

// Dedup: stejný title+source+startsAt+endsAt = duplikát (Google někdy posílá
// stejnou událost s různými externalId, nebo je v kalendáři skutečně dvakrát).
// Hack ve view; root cause vyžaduje audit sync logiky.
const seenKeys = new Set<string>();
const dedupedEvents = events.filter((e) => {
  const key = `${e.source}|${e.title}|${e.startsAt.getTime()}|${e.endsAt.getTime()}`;
  if (seenKeys.has(key)) return false;
  seenKeys.add(key);
  return true;
});

const initial = {
  date: dateStr,
  events: dedupedEvents.map((e) => ({
    ...e,
    startsAt: e.startsAt.toISOString(),
    endsAt: e.endsAt.toISOString(),
  })),
  dayNotes: dayNotes.map((n) => ({
    ...n,
    doneAt: n.doneAt?.toISOString() ?? null,
  })),
  briefingDigest: briefingDigest
    ? {
        ...briefingDigest,
        forDate: briefingDigest.forDate.toISOString(),
        generatedAt: briefingDigest.generatedAt.toISOString(),
        pushedAt: briefingDigest.pushedAt?.toISOString() ?? null,
      }
    : null,
  ruleViolations,
};
---

{Astro.url.searchParams.get("naplno") === "1" ? (
  <Base title={`Den ${dateStr} · Rašeliniště`}>
    <div class="max-w-3xl mx-auto p-4">
      <DayView client:load initial={initial} />
    </div>
  </Base>
) : (
  <Shell
    title={`Den ${dateStr} · Rašeliniště`}
    username={user.username}
    breadcrumb={[{ label: "Kalendář" }, { label: "Den" }]}
  >
    <div class="max-w-3xl mx-auto">
      <DayView client:load initial={initial} />
    </div>
  </Shell>
)}
