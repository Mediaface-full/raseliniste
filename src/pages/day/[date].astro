---
import Shell from "../../layouts/Shell.astro";
import Base from "../../layouts/Base.astro";
import DayView from "../../components/DayView";
import { prisma } from "../../lib/db";
import { readSession } from "../../lib/session";
import { generateWeekRituals, generateCustomRituals, getMondayOfWeek } from "../../lib/week-rituals";
import { generateAnniversaryEvents } from "../../lib/anniversary-events";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true, ritualTemplates: true },
});
if (!user) return Astro.redirect("/login");

const dateStr = Astro.params.date;
if (!dateStr || !/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) {
  return Astro.redirect("/day/" + new Date().toISOString().slice(0, 10));
}

const dayStart = new Date(`${dateStr}T00:00:00`);
const dayEnd = new Date(`${dateStr}T23:59:59.999`);

const [events, dayNotes, briefingDigest, ruleViolations] = await Promise.all([
  prisma.calendarEvent.findMany({
    where: {
      deletedRemotely: false,
      // POZOR: `gt` (ne `gte`) — Google/iCal all-day eventy mají endsAt exclusive
      // (sobotní celodenka má endsAt = neděle 00:00), takže `gte` by ji ukázal i v neděli.
      AND: [{ endsAt: { gt: dayStart } }, { startsAt: { lte: dayEnd } }],
    },
    orderBy: { startsAt: "asc" },
  }),
  prisma.dayNote.findMany({
    where: { forDate: dayStart },
    orderBy: [{ done: "asc" }, { createdAt: "asc" }],
  }),
  prisma.briefingDigest.findUnique({ where: { forDate: dayStart } }),
  prisma.ruleViolation.findMany({
    where: { forDate: dayStart },
    orderBy: { createdAt: "asc" },
  }),
]);

// Dedup: stejný title+source+startsAt+endsAt = duplikát (Google někdy posílá
// stejnou událost s různými externalId, nebo je v kalendáři skutečně dvakrát).
// Hack ve view; root cause vyžaduje audit sync logiky.
const seenKeys = new Set<string>();
const dedupedEvents = events.filter((e) => {
  const key = `${e.source}|${e.title}|${e.startsAt.getTime()}|${e.endsAt.getTime()}`;
  if (seenKeys.has(key)) return false;
  seenKeys.add(key);
  return true;
});

// Připoj rituály daného týdne, vyfiltruj jen ty co spadají do dnešního dne.
// Petr potřebuje vidět rituály i na mobilu, ne jen v týdenním desktop pohledu.
const weekMonday = getMondayOfWeek(dayStart);
const customRituals = await prisma.customRitual.findMany({
  where: { userId: session.uid, active: true },
});
const allRituals = [
  ...generateWeekRituals(
    weekMonday,
    user.ritualTemplates as Record<string, string> | null,
  ),
  ...generateCustomRituals(weekMonday, customRituals),
];
const todaysRituals = allRituals.filter((r) => {
  const start = new Date(r.startsAt);
  return start >= dayStart && start <= dayEnd;
});

// Výročí — samostatná entita, nepropsaná do Google/iCloud kalendářů.
// Načteme všechna a filtrujeme na dnešní datum.
const anniversaries = await prisma.anniversary.findMany({
  where: { userId: session.uid },
});
const todaysAnniversaries = generateAnniversaryEvents(
  anniversaries,
  dayStart,
  dayEnd,
);

const initial = {
  date: dateStr,
  events: [
    ...dedupedEvents.map((e) => ({
      ...e,
      startsAt: e.startsAt.toISOString(),
      endsAt: e.endsAt.toISOString(),
    })),
    // Rituály — virtuální eventy s source="RITUAL", DayTimeline je kreslí
    // v peach tintu (sourceTint funkce). Drží se nad reálným syncem,
    // takže každý den 7-8 ráno se vyrenderuje.
    ...todaysRituals.map((r) => ({
      id: r.id,
      title: r.title,
      type: r.type,
      source: r.source,
      startsAt: r.startsAt,
      endsAt: r.endsAt,
      locationText: r.locationText,
      description: r.description,
      prepNote: r.prepNote,
      itemsToBring: r.itemsToBring,
      allDay: r.allDay,
    })),
    ...todaysAnniversaries.map((a) => ({
      id: a.id,
      title: a.title,
      type: a.type,
      source: a.source,
      startsAt: a.startsAt,
      endsAt: a.endsAt,
      locationText: a.locationText,
      description: a.description,
      prepNote: a.prepNote,
      itemsToBring: a.itemsToBring,
      allDay: a.allDay,
    })),
  ],
  dayNotes: dayNotes.map((n) => ({
    ...n,
    doneAt: n.doneAt?.toISOString() ?? null,
  })),
  briefingDigest: briefingDigest
    ? {
        ...briefingDigest,
        forDate: briefingDigest.forDate.toISOString(),
        generatedAt: briefingDigest.generatedAt.toISOString(),
        pushedAt: briefingDigest.pushedAt?.toISOString() ?? null,
      }
    : null,
  ruleViolations,
};
---

{Astro.url.searchParams.get("naplno") === "1" ? (
  <Base title={`Den ${dateStr} · Rašeliniště`}>
    <div class="max-w-3xl mx-auto p-4">
      <DayView client:load initial={initial} />
    </div>
  </Base>
) : (
  <Shell
    title={`Den ${dateStr} · Rašeliniště`}
    username={user.username}
    breadcrumb={[{ label: "Kalendář" }, { label: "Den" }]}
  >
    <div class="max-w-3xl mx-auto">
      <DayView client:load initial={initial} />
    </div>
  </Shell>
)}
