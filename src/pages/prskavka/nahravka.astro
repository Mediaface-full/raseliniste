---
import Shell from "../../layouts/Shell.astro";
import OwnerRecorder from "../../components/OwnerRecorder";
import { prisma } from "../../lib/db";
import { readSession } from "../../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

// Filter — jen Prskavka projekty (osobní)
const projects = await prisma.projectBox.findMany({
  where: { userId: session.uid, archivedAt: null, isPrivate: true },
  select: { id: true, name: true, description: true },
  orderBy: { name: "asc" },
});
---

<Shell
  title="Nahrávka · Prskavka"
  username={user.username}
  heading="Nahrávka — Prskavka"
  breadcrumb={[{ label: "Prskavka", href: "/prskavka" }, { label: "Nahrávka" }]}
>
  <div class="max-w-md mx-auto">
    {/* Petr 2026-05-27 #10: switch zpět na Studánku */}
    <div class="flex items-center justify-center gap-1 mb-2">
      <a
        href="/studna/nahravka"
        class="px-4 py-2 rounded-md text-sm font-mono text-muted-foreground hover:bg-white/5 hover:text-foreground"
      >
        ← Studánka
      </a>
      <span class="px-4 py-2 rounded-md bg-[var(--tint-rose)]/15 border border-[var(--tint-rose)]/30 text-sm font-medium text-[var(--tint-rose)]">
        Prskavka
      </span>
    </div>
    <p class="text-xs text-muted-foreground text-center mb-3">
      Prskavka = osobní záznamy (jen ty). Studánka = sdílené projekty s hostem.
    </p>

    <OwnerRecorder
      client:load
      ownerName={user.username}
      projects={projects}
    />
  </div>
</Shell>
