---
import Shell from "../../../layouts/Shell.astro";
import { prisma } from "../../../lib/db";
import { readSession } from "../../../lib/session";
import { marked } from "marked";
import HealthAnalysisActions from "../../../components/health/HealthAnalysisActions";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

const id = Astro.params.id as string;
let analysis = await prisma.healthAnalysis.findUnique({ where: { id } });
if (!analysis || analysis.userId !== session.uid) {
  return Astro.redirect("/health");
}

// Defenzivní cleanup: pokud AI pipeline padla / kontejner se restartoval,
// processing rows by zůstaly navždy. Po 5 min překlopíme na error.
if (analysis.status === "processing") {
  const ageMs = Date.now() - analysis.createdAt.getTime();
  if (ageMs > 5 * 60 * 1000) {
    analysis = await prisma.healthAnalysis.update({
      where: { id },
      data: { status: "error", processingError: "AI analýza nestihla doběhnout do 5 minut. Zkus znovu." },
    });
  }
}

const html = marked.parse(analysis.text) as string;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("cs-CZ", { day: "numeric", month: "numeric", year: "numeric" });
const fmtDateTime = (d: Date) =>
  d.toLocaleString("cs-CZ");

const periodLabel = `${fmtDate(analysis.periodFrom)} → ${fmtDate(analysis.periodTo)}`;
const fromIso = analysis.periodFrom.toISOString().slice(0, 10);
const toIso = analysis.periodTo.toISOString().slice(0, 10);
const days = Math.round(
  (analysis.periodTo.getTime() - analysis.periodFrom.getTime()) / 86_400_000
);
---

<Shell
  title={`Zdravotní analýza · ${periodLabel}`}
  username={user.username}
  breadcrumb={[{ label: "Zdraví", href: "/health" }, { label: "Analýza" }]}
>
  <div class="max-w-3xl mx-auto space-y-5">
    {/* Header */}
    <div>
      <div class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground font-mono mb-1">
        Zdravotní analýza
      </div>
      <h1 class="text-4xl font-bold tracking-[-0.04em] leading-tight">{periodLabel}</h1>
      <div class="mt-2 text-xs font-mono text-muted-foreground tabular flex flex-wrap gap-x-3 gap-y-1">
        <span>{days} dní</span>
        <span>·</span>
        <span>{(analysis.totalSamples ?? 0).toLocaleString("cs-CZ")} záznamů</span>
        <span>·</span>
        <span>{analysis.metricsWithData ?? 0} metrik</span>
        <span>·</span>
        <span>{analysis.model}</span>
        <span>·</span>
        <span>vygenerováno {fmtDateTime(analysis.createdAt)}</span>
      </div>
      {analysis.focus && (
        <div class="mt-3 text-sm text-muted-foreground italic">
          Pokyn: „{analysis.focus}"
        </div>
      )}
    </div>

    {analysis.status === "processing" ? (
      <div
        class="rounded-lg border border-[var(--tint-butter)]/40 bg-[var(--tint-butter)]/[0.08] p-8 text-center"
        data-poll-status="processing"
        data-id={analysis.id}
      >
        <div class="inline-flex items-center gap-2 text-[var(--tint-butter)]">
          <svg class="size-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25" /><path d="M4 12a8 8 0 0 1 8-8" stroke="currentColor" stroke-width="3" /></svg>
          <span class="font-mono text-sm">AI analyzuje zdravotní data…</span>
        </div>
        <p class="mt-3 text-sm text-muted-foreground max-w-lg mx-auto leading-relaxed">
          Gemini Pro prochází {(analysis.totalSamples ?? 0).toLocaleString("cs-CZ")} záznamů.
          Typicky 30–90 sekund. Stránka se sama obnoví, jakmile bude analýza hotová —
          můžeš ji zavřít a vrátit se kdykoli.
        </p>
      </div>
    ) : analysis.status === "error" ? (
      <div class="rounded-lg border border-destructive/40 bg-destructive/[0.08] p-6 space-y-2">
        <div class="font-mono text-xs uppercase text-destructive">Analýza selhala</div>
        <pre class="text-xs whitespace-pre-wrap text-destructive/90">{analysis.processingError ?? "neznámá chyba"}</pre>
        <p class="text-xs text-muted-foreground">Zkus to znovu z hlavní stránky Zdraví — někdy pomůže menší rozsah dat.</p>
      </div>
    ) : (
      <>
        <HealthAnalysisActions
          client:load
          id={analysis.id}
          text={analysis.text}
          fromIso={fromIso}
          toIso={toIso}
          meta={{
            days,
            totalSamples: analysis.totalSamples ?? 0,
            metricsWithData: analysis.metricsWithData ?? 0,
            model: analysis.model,
            focus: analysis.focus,
            createdAt: analysis.createdAt.toISOString(),
          }}
        />

        <article
          class="prose-rasel rounded-lg border border-white/10 bg-black/20 p-6 text-[15px] leading-relaxed"
          set:html={html}
        />
      </>
    )}
  </div>
</Shell>

{analysis.status === "processing" && (
  <script is:inline>
    // Polling — server-side rendered guard přepíše po dokončení
    setTimeout(() => location.reload(), 5000);
  </script>
)}
