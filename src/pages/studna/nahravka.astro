---
import Shell from "../../layouts/Shell.astro";
import OwnerRecorder from "../../components/OwnerRecorder";
import OwnerUploadAudio from "../../components/OwnerUploadAudio";
import { prisma } from "../../lib/db";
import { readSession } from "../../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

const projects = await prisma.projectBox.findMany({
  where: { userId: session.uid, archivedAt: null, isPrivate: false },
  select: { id: true, name: true, description: true },
  orderBy: { name: "asc" },
});
---

<Shell
  title="Nahrávka · Studánka"
  username={user.username}
  heading="Nahrávka"
  breadcrumb={[{ label: "Studánka", href: "/studna" }, { label: "Nahrávka" }]}
>
  <div class="max-w-md mx-auto space-y-3">
    {/* Petr 2026-05-27 #10: segmentovaný switch Studánka ↔ Prskavka. Tile
        na /start je sloučený do „Záznamy" a vede sem (default Studánka),
        Petr přepne na Prskavku jedním klikem. */}
    <div class="flex items-center justify-center gap-1 mb-2">
      <span class="px-4 py-2 rounded-md bg-[var(--tint-mint)]/15 border border-[var(--tint-mint)]/30 text-sm font-medium text-[var(--tint-mint)]">
        Studánka
      </span>
      <a
        href="/prskavka/nahravka"
        class="px-4 py-2 rounded-md text-sm font-mono text-muted-foreground hover:bg-white/5 hover:text-foreground"
      >
        Prskavka →
      </a>
    </div>
    <p class="text-xs text-muted-foreground text-center mb-3">
      Studánka = sdílené projekty (host + ty). Prskavka = jen tvoje osobní záznamy.
    </p>

    <OwnerRecorder
      client:load
      ownerName={user.username}
      projects={projects}
    />
    {/* Petr 2026-05-14: na /studna/nahravka (link ze /start "Studánka") chyběl
        upload audio souboru — měl jen rekordér. Přidáno pod rekordér. */}
    <OwnerUploadAudio
      client:load
      projects={projects}
    />
  </div>
</Shell>
