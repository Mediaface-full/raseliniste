---
import Shell from "../../layouts/Shell.astro";
import ContactsTable from "../../components/ContactsTable";
import ContactsNewsBanner from "../../components/ContactsNewsBanner";
import ContactsTools from "../../components/ContactsTools";
import { prisma } from "../../lib/db";
import { readSession } from "../../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");

// iCloud connection status pro banner
const integration = await prisma.userIntegration.findUnique({
  where: { userId_provider: { userId: session.uid, provider: "icloud" } },
  select: { lastUsedAt: true, lastError: true, config: true },
});
const config = (integration?.config ?? {}) as { appleId?: string; contactsAddressbookUrl?: string };
const icloudStatus = {
  connected: Boolean(integration),
  username: config.appleId ?? null,
  hasAddressbook: Boolean(config.contactsAddressbookUrl),
  lastUsedAt: integration?.lastUsedAt?.toISOString() ?? null,
  lastError: integration?.lastError ?? null,
};

// Celkový počet pro hero
const totalCount = await prisma.contact.count({ where: { userId: session.uid } });

// Skupiny pro export scope dropdown (Petr 2026-05-15 F8)
const groupRows = await prisma.contactGroup.findMany({
  where: { userId: session.uid },
  select: { name: true },
  orderBy: { name: "asc" },
});
const groupNames = groupRows.map((g) => g.name);
---

<Shell
  title="Kontakty — tabulka · Rašeliniště"
  username={user.username}
  breadcrumb={[{ label: "Kontakty", href: "/contacts" }, { label: "Tabulka" }]}
>
  <div class="max-w-[1400px] space-y-5">
    {/* Banner novinek z mobilu — kontakty_brief.md 5.4 */}
    <ContactsNewsBanner client:load />

    <ContactsTable client:load initialTotal={totalCount} icloudStatus={icloudStatus} />

    {/* Rozbalovací nástroje pod tabulkou — kontakty_brief.md 5.8 + 5.9.
        Duplicity, F&R, +420 normalize, Import VCF/CSV, Backups/Restore,
        Google sync (3-úrovňové párování + cleanup + pull-back), Export. */}
    <ContactsTools client:load groupNames={groupNames} />
  </div>
</Shell>
