---
import Base from "../layouts/Base.astro";
import DiktatRecorder from "../components/DiktatRecorder";
import { prisma } from "../lib/db";
import { readSession } from "../lib/session";

const session = await readSession(Astro.cookies);
if (!session) return Astro.redirect("/login");

const user = await prisma.user.findUnique({
  where: { id: session.uid },
  select: { username: true },
});
if (!user) return Astro.redirect("/login");
---

<Base
  title="Ozvěna · Rašeliniště"
  appleTitle="Ozvěna"
  appleCapable={true}
  manifestPath="/manifest-ozvena.json"
>
  <main class="min-h-screen flex flex-col">
    <div class="border-b border-white/5 px-4 py-3 flex items-center gap-3">
      <a href="/" class="text-xs font-mono text-muted-foreground hover:text-foreground">← Dashboard</a>
      <span class="text-xs font-mono text-muted-foreground">{user.username}</span>
    </div>

    <!-- Petr 2026-05-25: max-w-2xl → max-w-5xl, ať tabulky úkolů a review
         mají dech a nemusí se text wrapovat na desktopu. -->
    <div class="flex-1 flex items-start sm:items-center justify-center p-4 sm:p-6">
      <div class="w-full max-w-5xl">
        <DiktatRecorder client:load />
      </div>
    </div>

    <div class="text-center text-xs font-mono text-muted-foreground/60 pb-4 px-4">
      Tip: <strong>Sdílet → Přidat na plochu</strong> = ikona Ozvěna
    </div>
  </main>
</Base>
