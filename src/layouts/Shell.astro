---
import Base from "./Base.astro";
import LogoutButton from "@/components/LogoutButton";
import SidebarToggle from "@/components/SidebarToggle";
import { Icon } from "astro-icon/components";
import { readSession } from "@/lib/session";
import { getPostaBadgeCount } from "@/lib/posta-badge";

interface Props {
  title: string;
  username: string;
  heading?: string;
  breadcrumb?: { label: string; href?: string }[];
}

const { title, username, heading, breadcrumb = [] } = Astro.props;
const path = Astro.url.pathname;

// Sidebar badge counters — server-side, cache 60s in-memory.
// Jen pokud existuje session (na public stránkách neřešíme).
const session = await readSession(Astro.cookies);
let postaBadge = 0;
if (session) {
  try {
    postaBadge = await getPostaBadgeCount(session.uid);
  } catch {
    // Pošta není nakonfigurovaná, count = 0. Tichý fail, sidebar nesmí padnout.
  }
}

type NavItem = {
  href: string;
  label: string;
  icon: string;
  tint: string;
  enabled?: boolean;
  badge?: number;
};

const nav: { group: string; items: NavItem[] }[] = [
  { group: "Přehled", items: [
    { href: "/", label: "Dashboard", icon: "lucide:layout-dashboard", tint: "peach", enabled: true },
  ]},
  { group: "Capture", items: [
    { href: "/triage",  label: "Triage",       icon: "lucide:inbox",    tint: "peach",    enabled: true },
    { href: "/capture", label: "Ruční vstup",  icon: "lucide:edit-3",   tint: "mint",     enabled: true },
  ]},
  { group: "Organizace", items: [
    { href: "/calendar", label: "Kalendář",  icon: "lucide:calendar",     tint: "sky",    enabled: true },
    { href: "/quickadd", label: "Rychlé zadání", icon: "lucide:zap", tint: "sky", enabled: true },
    { href: `/day/${new Date().toISOString().slice(0, 10)}`, label: "Dnes (briefing)", icon: "lucide:sun", tint: "butter", enabled: true },
    { href: "/calendar/invite", label: "Pozvánka", icon: "lucide:send", tint: "sage", enabled: true },
    { href: "/calendar/away", label: "Dovolená / nomád", icon: "lucide:plane", tint: "rose", enabled: true },
    { href: "/calendar/locations", label: "Lokace", icon: "lucide:map-pin", tint: "lavender", enabled: true },
    { href: "/calendar/settings", label: "Nastavení bookingu", icon: "lucide:settings-2", tint: "mint", enabled: true },
    { href: "/start",    label: "Start (rychlý přístup)", icon: "lucide:sunrise", tint: "peach", enabled: true },
    { href: "/ozvena",   label: "Ozvěna (úkoly+deník)", icon: "lucide:mic", tint: "peach", enabled: true },
    { href: "/ukoly",    label: "Úkoly",     icon: "lucide:check-square", tint: "peach",  enabled: true },
    { href: "/tasks",    label: "Capture inbox", icon: "lucide:inbox",   tint: "peach",  enabled: true },
    { href: "/notes",    label: "Poznámky",  icon: "lucide:notebook-pen", tint: "mint",   enabled: true },
    { href: "/denik",    label: "Deník",     icon: "lucide:book-open",    tint: "butter", enabled: true },
    // { href: "/journal",  label: "Journal (legacy)", icon: "lucide:book-marked", tint: "butter", enabled: true }, // schováno 2026-05-04 — Petr používá /denik (JournalEntry), legacy Entry-based zůstává funkční přes URL
    { href: "/letters",  label: "Dopisy",    icon: "lucide:mail-plus",    tint: "butter", enabled: true },
    { href: "/studna",   label: "Studánka",  icon: "lucide:waves",        tint: "butter", enabled: true },
    { href: "/prskavka", label: "Prskavka",  icon: "lucide:sparkles",     tint: "butter", enabled: true },
    { href: "/spiz",     label: "Spíž",      icon: "lucide:archive",      tint: "mint",   enabled: true },
  ]},
  { group: "Komunikace", items: [
    // Pošta (Email Intelligence) — fáze 1+2 hotové, fáze 3 = tato stránka.
    // Tint cool-blue. Skupina připravena pro budoucí Slack/WhatsApp aggregátor.
    { href: "/posta", label: "Pošta", icon: "lucide:mail", tint: "cool-blue", enabled: true, badge: postaBadge },
    { href: "/posta/uklid", label: "Pošta — úklid", icon: "lucide:trash-2", tint: "rose", enabled: true },
  ]},
  { group: "Data", items: [
    { href: "/health",   label: "Zdraví",    icon: "lucide:heart-pulse", tint: "rose", enabled: true },
    { href: "/contacts", label: "Kontakty",  icon: "lucide:users",  tint: "lavender", enabled: true },
    { href: "/contacts/tabulka", label: "Kontakty — tabulka", icon: "lucide:table-2", tint: "lavender", enabled: true },
    { href: "/vyroci",   label: "Výročí",    icon: "lucide:calendar-heart", tint: "rose", enabled: true },
    { href: "/zijes",    label: "ŽIJEŠ?",    icon: "lucide:heart-pulse", tint: "rose", enabled: true },
    { href: "/bwmys",    label: "Myši",   icon: "lucide:arrow-left-right", tint: "lavender", enabled: true },
    { href: "/firewall", label: "Firewall",  icon: "lucide:shield", tint: "peach",    enabled: true },
    { href: "/finance",  label: "Finance",   icon: "lucide:wallet", tint: "sage" },
    { href: "/files",    label: "Soubory",   icon: "lucide:folder", tint: "pink" },
  ]},
  { group: "AI", items: [
    { href: "/ai/chat",  label: "Gemini chat", icon: "lucide:sparkles", tint: "rose" },
    { href: "/ai/coach", label: "Claude kouč", icon: "lucide:compass",  tint: "lavender" },
  ]},
  { group: "Integrace", items: [
    { href: "/integrations/superlist", label: "Superlist", icon: "lucide:list-todo", tint: "mint" },
    { href: "/integrations/plaud",     label: "Plaud",     icon: "lucide:mic",       tint: "butter" },
  ]},
  { group: "Nastavení", items: [
    { href: "/navody", label: "Návody", icon: "lucide:book-marked", tint: "butter", enabled: true },
    { href: "/settings", label: "Nastavení", icon: "lucide:settings", tint: "lavender", enabled: true },
  ]},
];

const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---

<Base title={title}>
  <div
    data-shell
    class="min-h-screen relative z-10 lg:grid lg:grid-cols-[260px_1fr] lg:gap-3 lg:p-3 p-2
           lg:[&[data-sidebar-collapsed=true]]:grid-cols-[0px_1fr] lg:[&[data-sidebar-collapsed=true]]:gap-0
           lg:transition-[grid-template-columns,gap] lg:duration-200 lg:ease-out"
  >
    {/* Backdrop (mobile only, když je sidebar otevřený) */}
    <div
      class="fixed inset-0 bg-black/40 backdrop-blur-sm z-30 opacity-0 pointer-events-none transition-opacity lg:hidden data-[open]:opacity-100 data-[open]:pointer-events-auto"
      data-sidebar-backdrop
    ></div>

    {/* Sidebar — glass panel; lg: v gridu, pod lg: off-canvas (otevírá se hamburgerem).
        Desktop collapse: data-collapsed=true → opacity 0 + neviditelný, grid kolony se zmenší. */}
    <aside
      data-sidebar
      class="glass rounded-xl flex flex-col overflow-hidden
             lg:sticky lg:top-3 lg:h-[calc(100vh-1.5rem)]
             fixed inset-y-2 left-2 w-[260px] z-40 transform -translate-x-[calc(100%+1rem)] transition-transform
             data-[open]:translate-x-0
             lg:static lg:translate-x-0 lg:inset-auto lg:w-auto
             lg:transition-[opacity,transform] lg:duration-200
             lg:data-[collapsed=true]:opacity-0 lg:data-[collapsed=true]:-translate-x-4 lg:data-[collapsed=true]:pointer-events-none"
    >
      <div class="px-5 py-5 border-b border-white/5">
        <a href="/" class="flex items-baseline gap-2 group">
          <span class="font-serif text-2xl tracking-tight">Rašeliniště</span>
          <span class="text-[10px] uppercase tracking-widest text-muted-foreground font-mono">
            v0.1
          </span>
        </a>
      </div>

      <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-5 text-sm">
        {nav.map((section) => (
          <div>
            <div class="px-2 mb-2 text-[10px] uppercase tracking-[0.15em] text-muted-foreground font-mono">
              {section.group}
            </div>
            <ul class="space-y-0.5">
              {section.items.map((item) => {
                const active = isActive(item.href);
                const disabled = item.enabled === false;
                return (
                  <li>
                    <a
                      href={disabled ? "#" : item.href}
                      aria-disabled={disabled}
                      style={`--c: var(--tint-${item.tint});`}
                      class:list={[
                        "relative flex items-center gap-2.5 px-2.5 py-2 rounded-md transition-all",
                        active
                          ? "bg-[color-mix(in_oklch,var(--c)_16%,transparent)] text-foreground"
                          : "text-foreground/75 hover:bg-white/5 hover:text-foreground",
                        disabled && "opacity-45 cursor-not-allowed pointer-events-none",
                      ]}
                    >
                      {active && (
                        <span class="absolute left-0 top-1.5 bottom-1.5 w-0.5 rounded-r" style="background: var(--c);"></span>
                      )}
                      <Icon name={item.icon} class="size-4 shrink-0" style="color: var(--c);" />
                      <span>{item.label}</span>
                      {item.badge !== undefined && item.badge > 0 && (
                        <span
                          class="ml-auto inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 rounded-full text-[10px] font-mono font-medium"
                          style="background: color-mix(in oklch, var(--c) 22%, transparent); color: var(--c);"
                          title="Aktivní action_required (urgency high nebo escalation)"
                        >
                          {item.badge}
                        </span>
                      )}
                      {disabled && (
                        <span class="ml-auto text-[9px] uppercase tracking-widest text-muted-foreground font-mono">
                          soon
                        </span>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </nav>

      <div class="border-t border-white/5 p-3 flex items-center gap-2.5">
        <div class="size-8 rounded-md bg-white/10 flex items-center justify-center font-serif text-foreground/90">
          {username.slice(0, 1).toUpperCase()}
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-sm truncate">{username}</div>
          <div class="text-[10px] uppercase tracking-widest text-muted-foreground font-mono">
            online
          </div>
        </div>
        <LogoutButton client:load />
      </div>
    </aside>

    {/* Main column — topbar + content, žádný outer glass (content karty nesou glass samy) */}
    <div class="flex flex-col min-w-0 gap-3">
      <header class="glass rounded-xl h-14 px-3 lg:px-5 flex items-center gap-3">
        <SidebarToggle client:load />
        <a
          href="/start"
          class="h-8 px-2 sm:px-3 rounded-md bg-[var(--tint-sky)]/10 border border-[var(--tint-sky)]/30 hover:bg-[var(--tint-sky)]/20 flex items-center gap-1.5 text-[var(--tint-sky)] transition-colors shrink-0"
          aria-label="Zpět na úvodní obrazovku Start"
          title="Zpět na Start"
        >
          <Icon name="lucide:home" class="size-4" />
          <span class="text-xs font-medium hidden sm:inline">Start</span>
        </a>
        <div class="flex items-center gap-2 text-sm text-muted-foreground">
          {breadcrumb.length === 0 ? (
            <span class="text-foreground">{heading ?? title}</span>
          ) : (
            breadcrumb.map((crumb, i) => (
              <>
                {crumb.href ? (
                  <a href={crumb.href} class="hover:text-foreground transition-colors">{crumb.label}</a>
                ) : (
                  <span class="text-foreground">{crumb.label}</span>
                )}
                {i < breadcrumb.length - 1 && (
                  <Icon name="lucide:chevron-right" class="size-3 text-muted-foreground/60" />
                )}
              </>
            ))
          )}
        </div>

        <div class="ml-auto flex items-center gap-1.5">
          {/* Rychlé přepínače pohledů kalendáře — Petr je chce v topbaru */}
          <a
            href="/dnes"
            class="h-8 px-2.5 rounded-md hover:bg-white/5 text-xs font-mono text-muted-foreground hover:text-foreground flex items-center gap-1.5 transition-colors"
            title="Dnešní den"
          >
            <Icon name="lucide:calendar-clock" class="size-3.5" />
            <span class="hidden sm:inline">Den</span>
          </a>
          <a
            href="/calendar/tyden"
            class="h-8 px-2.5 rounded-md hover:bg-white/5 text-xs font-mono text-muted-foreground hover:text-foreground flex items-center gap-1.5 transition-colors"
            title="Týdenní pohled"
          >
            <Icon name="lucide:calendar-days" class="size-3.5" />
            <span class="hidden sm:inline">Týden</span>
          </a>
          <a
            href="/calendar/mesic"
            class="h-8 px-2.5 rounded-md hover:bg-white/5 text-xs font-mono text-muted-foreground hover:text-foreground flex items-center gap-1.5 transition-colors"
            title="Měsíční pohled"
          >
            <Icon name="lucide:calendar" class="size-3.5" />
            <span class="hidden sm:inline">Měsíc</span>
          </a>
          <span class="hidden md:inline-block w-px h-5 bg-white/10 mx-1" />
          <button type="button" class="h-8 px-3 rounded-md hover:bg-white/5 text-sm text-muted-foreground flex items-center gap-2 transition-colors" aria-label="Hledat">
            <Icon name="lucide:search" class="size-4" />
            <span class="hidden md:inline font-mono text-xs">⌘K</span>
          </button>
          <a href="/settings" class="size-8 rounded-md hover:bg-white/5 flex items-center justify-center text-muted-foreground hover:text-foreground transition-colors" aria-label="Nastavení">
            <Icon name="lucide:settings" class="size-4" />
          </a>
        </div>
      </header>

      <main class="flex-1 min-w-0 overflow-y-auto px-1 pb-3">
        {heading && <h1 class="font-serif text-3xl mb-5 tracking-tight">{heading}</h1>}
        <slot />
      </main>
    </div>
  </div>
</Base>
