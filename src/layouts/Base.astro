---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  appleTitle?: string;          // název pod ikonou na ploše iPhone
  appleCapable?: boolean;        // otevřít jako "appka" bez Safari chromu
  manifestPath?: string;         // PWA manifest cesta (pokud máme)
  // Override pro apple-touch-icon. Default = G logo (sdílená ikona pro
  // /call-log, /me/<token> a další veřejné stránky pro hosty/klienty).
  // /start si přepisuje na /tree-touch-icon.png — strom má JEN Petr na své
  // osobní úvodní stránce.
  appleIconPath?: string;
  // Open Graph image pro WhatsApp/Facebook/Telegram link preview.
  // Default = G logo (1200×1200 stačí, social media si rescaluje).
  ogImagePath?: string;
}

const {
  title,
  description = "",
  appleTitle,
  appleCapable = false,
  manifestPath,
  appleIconPath = "/apple-touch-icon.png",
  ogImagePath = appleIconPath,
} = Astro.props;

// Plná URL pro og:image (WhatsApp/Meta vyžaduje absolutní)
const baseUrl = "https://www.raseliniste.cz";
const ogImageUrl = ogImagePath.startsWith("http") ? ogImagePath : `${baseUrl}${ogImagePath}`;
---

<!doctype html>
<html lang="cs" data-theme="rasel">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0920" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href={appleIconPath} />
    {appleTitle && <meta name="apple-mobile-web-app-title" content={appleTitle} />}
    {appleCapable && <meta name="apple-mobile-web-app-capable" content="yes" />}
    {appleCapable && <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />}
    {manifestPath && <link rel="manifest" href={manifestPath} />}

    {/* Open Graph (WhatsApp/Telegram/Facebook link preview) */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || title} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-base-100 text-base-content antialiased">
    <slot />
  </body>
</html>
