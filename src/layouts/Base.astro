---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  appleTitle?: string;          // název pod ikonou na ploše iPhone
  appleCapable?: boolean;        // otevřít jako "appka" bez Safari chromu
  manifestPath?: string;         // PWA manifest cesta (pokud máme)
}

const { title, description = "", appleTitle, appleCapable = false, manifestPath } = Astro.props;
---

<!doctype html>
<html lang="cs" data-theme="rasel">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0920" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {appleTitle && <meta name="apple-mobile-web-app-title" content={appleTitle} />}
    {appleCapable && <meta name="apple-mobile-web-app-capable" content="yes" />}
    {appleCapable && <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />}
    {manifestPath && <link rel="manifest" href={manifestPath} />}
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-base-100 text-base-content antialiased">
    <slot />
  </body>
</html>
